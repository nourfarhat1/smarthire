{% extends 'hr/layout.html.twig' %}

{% block title %}HR Job Offers - SmartHire{% endblock %}

{% block hr_page_title %}My Job Offers{% endblock %}

{% block hr_content %}
<!-- Job Offer Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stats-card text-white" style="background: linear-gradient(135deg, #6c757d 0%, #495057 100%);">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ totalCount }}</h4>
                        <p class="card-text">Total Offers</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-briefcase fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card text-white" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ activeCount }}</h4>
                        <p class="card-text">Active (30 days)</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-check-circle fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card text-white" style="background: linear-gradient(135deg, #6f42c1 0%, #5a32a3 100%);">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ totalApplications }}</h4>
                        <p class="card-text">Total Applications</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-people fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card text-white" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ jobCategories|length }}</h4>
                        <p class="card-text">Categories</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-tags fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filters and Search -->
<div class="card mb-4">
    <div class="card-header text-white" style="background: linear-gradient(135deg, #495057 0%, #343a40 100%);">
        <h5 class="mb-0"><i class="bi bi-funnel me-2"></i>Filter & Search</h5>
    </div>
    <div class="card-body">
        <form method="GET" class="row g-3">
            <div class="col-md-4">
                <label for="search" class="form-label">Search</label>
                <input type="text" class="form-control" id="search" name="search" 
                       value="{{ search }}" placeholder="Search job offers...">
            </div>
            <div class="col-md-3">
                <label for="category" class="form-label">Category</label>
                <select class="form-select" id="category" name="category">
                    <option value="">All Categories</option>
                    {% for jobCategory in jobCategories %}
                        <option value="{{ jobCategory.id }}" 
                                {% if selectedCategory == jobCategory.id %}selected{% endif %}>
                            {{ jobCategory.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3">
                <label for="jobType" class="form-label">Job Type</label>
                <select class="form-select" id="jobType" name="jobType">
                    <option value="">All Types</option>
                    <option value="Full-time" {% if selectedJobType == 'Full-time' %}selected{% endif %}>Full-time</option>
                    <option value="Part-time" {% if selectedJobType == 'Part-time' %}selected{% endif %}>Part-time</option>
                    <option value="Contract" {% if selectedJobType == 'Contract' %}selected{% endif %}>Contract</option>
                    <option value="Internship" {% if selectedJobType == 'Internship' %}selected{% endif %}>Internship</option>
                    <option value="Remote" {% if selectedJobType == 'Remote' %}selected{% endif %}>Remote</option>
                    <option value="Hybrid" {% if selectedJobType == 'Hybrid' %}selected{% endif %}>Hybrid</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">&nbsp;</label><br>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-1"></i> Search
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Action Buttons -->
<div class="row mb-4">
    <div class="col-12">
        <a href="{{ path('app_hr_job_offers_new') }}" class="btn btn-primary me-2">
            <i class="bi bi-plus-circle me-2"></i>Create New Job Offer
        </a>
        <a href="{{ path('app_hr_job_categories') }}" class="btn btn-outline-secondary">
            <i class="bi bi-tags me-2"></i>Manage Categories
        </a>
    </div>
</div>

<!-- Job Offers List -->
<div class="card">
    <div class="card-header text-white" style="background: linear-gradient(135deg, #495057 0%, #343a40 100%);">
        <h5 class="mb-0"><i class="bi bi-briefcase me-2"></i>My Job Offers</h5>
    </div>
    <div class="card-body">
        {% if jobOffers|length > 0 %}
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Type</th>
                            <th>Location</th>
                            <th>Salary Range</th>
                            <th>Posted Date</th>
                            <th>Applications</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for jobOffer in jobOffers %}
                            <tr>
                                <td>
                                    <a href="#" class="text-decoration-none fw-bold">
                                        {{ jobOffer.title }}
                                    </a>
                                    <br>
                                    <small class="text-muted">{{ jobOffer.description|slice(0, 80) }}...</small>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">
                                        {{ jobOffer.category.name ?? 'Uncategorized' }}
                                    </span>
                                </td>
                                <td>
                                    {% if jobOffer.jobType == 'Full-time' %}
                                        <span class="badge bg-primary">Full-time</span>
                                    {% elseif jobOffer.jobType == 'Part-time' %}
                                        <span class="badge bg-info">Part-time</span>
                                    {% elseif jobOffer.jobType == 'Contract' %}
                                        <span class="badge bg-warning text-dark">Contract</span>
                                    {% elseif jobOffer.jobType == 'Internship' %}
                                        <span class="badge bg-success">Internship</span>
                                    {% elseif jobOffer.jobType == 'Remote' %}
                                        <span class="badge bg-secondary">Remote</span>
                                    {% else %}
                                        <span class="badge bg-info">{{ jobOffer.jobType }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <i class="bi bi-geo-alt me-1"></i>{{ jobOffer.location }}
                                </td>
                                <td>
                                    {% if jobOffer.salaryRange %}
                                        <span class="text-success fw-bold">{{ jobOffer.salaryRange }}</span>
                                    {% else %}
                                        <span class="text-muted">Not specified</span>
                                    {% endif %}
                                </td>
                                <td>{{ jobOffer.postedDate|date('M d, Y') }}</td>
                                <td>
                                    <span class="badge bg-info">{{ jobOffer.jobRequests.count }}</span>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('app_hr_job_offers_edit', {'id': jobOffer.id}) }}" 
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="POST" 
                                              action="{{ path('app_hr_job_offers_delete', {'id': jobOffer.id}) }}" 
                                              class="d-inline" 
                                              onsubmit="return confirm('Are you sure you want to delete this job offer?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-center py-5">
                <i class="bi bi-briefcase fs-1 text-muted mb-3"></i>
                <h5 class="text-muted">No job offers found</h5>
                <p class="text-muted">
                    {% if search or selectedCategory or selectedJobType %}
                        Try adjusting your filters or 
                        <a href="{{ path('app_hr_job_offers') }}">clear all filters</a>.
                    {% else %}
                        You haven't created any job offers yet. 
                        <a href="{{ path('app_hr_job_offers_new') }}">Create your first job offer</a>.
                    {% endif %}
                </p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
