{% extends 'hr/layout.html.twig' %}

{% block title %}Event Details - SmartHire{% endblock %}

{% block hr_page_title %}Event Details{% endblock %}

{% block hr_content %}
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header text-white" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);">
                <h5 class="mb-0"><i class="bi bi-calendar-event me-2"></i>{{ event.name }}</h5>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <p><strong><i class="bi bi-calendar me-2"></i>Date:</strong> {{ event.eventDate|date('F d, Y') }}</p>
                        <p><strong><i class="bi bi-clock me-2"></i>Time:</strong> {{ event.eventDate|date('H:i') }}</p>
                        <p><strong><i class="bi bi-geo-alt me-2"></i>Location:</strong> {{ event.location }}</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong><i class="bi bi-people me-2"></i>Max Participants:</strong> {{ event.maxParticipants }}</p>
                        <p><strong><i class="bi bi-person me-2"></i>Organizer:</strong> {{ event.organizer.fullName }}</p>
                        <p><strong><i class="bi bi-tag me-2"></i>Status:</strong> 
                            {% if event.eventDate > date() %}
                                <span class="badge bg-success">Upcoming</span>
                            {% else %}
                                <span class="badge bg-secondary">Completed</span>
                            {% endif %}
                        </p>
                    </div>
                </div>

                <div class="mb-4">
                    <h6><i class="bi bi-text-paragraph me-2"></i>Description</h6>
                    <div class="card bg-light">
                        <div class="card-body">
                            {{ event.description|raw }}
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_hr_events') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Back to Events
                    </a>
                    <div>
                        <a href="{{ path('app_hr_events_edit', {'id': event.id}) }}" class="btn btn-warning">
                            <i class="bi bi-pencil me-2"></i>Edit Event
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header text-white" style="background: linear-gradient(135deg, #6c757d 0%, #495057 100%);">
                <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Event Information</h6>
            </div>
            <div class="card-body">
                <h6>Event Details</h6>
                <ul class="small">
                    <li><strong>Created:</strong> {{ event.createdAt|date('Y-m-d H:i') }}</li>
                    <li><strong>Event ID:</strong> #{{ event.id }}</li>
                    <li><strong>Organizer:</strong> {{ event.organizer.email }}</li>
                </ul>

                <hr>

                <h6>Quick Actions</h6>
                <div class="d-grid gap-2">
                    <a href="{{ path('app_hr_events_edit', {'id': event.id}) }}" class="btn btn-outline-warning btn-sm">
                        <i class="bi bi-pencil me-1"></i>Edit Event
                    </a>
                    <a href="{{ path('app_hr_events') }}" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-list me-1"></i>All Events
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
