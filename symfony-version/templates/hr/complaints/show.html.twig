{% extends 'hr/layout.html.twig' %}

{% block title %}Complaint Details - SmartHire{% endblock %}

{% block hr_page_title %}Complaint Details{% endblock %}

{% block hr_content %}
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header hr-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Complaint Details</h5>
                <div>
                    {% if complaint.status == 'PENDING' %}
                        <span class="badge bg-warning">Pending</span>
                    {% elseif complaint.status == 'OPEN' %}
                        <span class="badge bg-info">Open</span>
                    {% elseif complaint.status == 'RESOLVED' %}
                        <span class="badge bg-success">Resolved</span>
                    {% else %}
                        <span class="badge bg-secondary">{{ complaint.status }}</span>
                    {% endif %}
                </div>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Complaint ID:</strong> #{{ complaint.id }}
                    </div>
                    <div class="col-md-6">
                        <strong>Type:</strong> 
                        <span class="badge bg-secondary">{{ complaint.type.name ?? 'General' }}</span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Priority:</strong> 
                        {% if complaint.priority == 'HIGH' %}
                            <span class="badge bg-danger">High</span>
                        {% elseif complaint.priority == 'MEDIUM' %}
                            <span class="badge bg-warning">Medium</span>
                        {% else %}
                            <span class="badge bg-info">Low</span>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        <strong>Submission Date:</strong> {{ complaint.submissionDate|date('M d, Y H:i') }}
                    </div>
                </div>

                <div class="mb-4">
                    <h6>Subject</h6>
                    <p class="lead">{{ complaint.subject }}</p>
                </div>

                <div class="mb-4">
                    <h6>Description</h6>
                    <div class="p-3 bg-light rounded">
                        <p class="mb-0">{{ complaint.description|nl2br }}</p>
                    </div>
                </div>

                {% if complaint.responses is defined and complaint.responses|length > 0 %}
                    <div class="mb-4">
                        <h6>Admin Responses</h6>
                        {% for response in complaint.responses %}
                            <div class="card mb-2">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between mb-2">
                                        <strong>{{ response.adminName ?? 'Admin' }}</strong>
                                        <small class="text-muted">{{ response.responseDate|date('M d, Y H:i') }}</small>
                                    </div>
                                    <p class="mb-0">{{ response.message|nl2br }}</p>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_hr_complaints') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Back to Complaints
                    </a>
                    <div>
                        {% if complaint.status == 'PENDING' %}
                            <a href="{{ path('app_hr_complaints_edit', {'id': complaint.id}) }}" 
                               class="btn btn-warning me-2">
                                <i class="bi bi-pencil me-2"></i>Edit
                            </a>
                            <button type="button" class="btn btn-danger" 
                                    data-bs-toggle="modal" data-bs-target="#deleteModal">
                                <i class="bi bi-trash me-2"></i>Delete
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header hr-info text-white">
                <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Status Information</h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Current Status:</strong>
                    <div class="mt-1">
                        {% if complaint.status == 'PENDING' %}
                            <span class="badge bg-warning">Pending Review</span>
                            <p class="small text-muted mt-2">Your complaint is waiting for admin review.</p>
                        {% elseif complaint.status == 'OPEN' %}
                            <span class="badge bg-info">Open</span>
                            <p class="small text-muted mt-2">Your complaint is being processed.</p>
                        {% elseif complaint.status == 'RESOLVED' %}
                            <span class="badge bg-success">Resolved</span>
                            <p class="small text-muted mt-2">Your complaint has been resolved.</p>
                        {% endif %}
                    </div>
                </div>

                <div class="mb-3">
                    <strong>Submitted:</strong>
                    <p class="small text-muted">{{ complaint.submissionDate|date('M d, Y H:i') }}</p>
                </div>

                {% if complaint.status == 'PENDING' %}
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Note:</strong> You can edit or delete this complaint while it's pending.
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header hr-warning text-dark">
                <h6 class="mb-0"><i class="bi bi-question-circle me-2"></i>Need Help?</h6>
            </div>
            <div class="card-body">
                <p class="small mb-2">
                    If you have questions about your complaint, contact HR support:
                </p>
                <ul class="small mb-0">
                    <li>Email: hr@smarthare.com</li>
                    <li>Phone: +216 71 234 567</li>
                    <li>Office: HR Department, 2nd Floor</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
{% if complaint.status == 'PENDING' %}
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Complaint</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this complaint?</p>
                    <p class="text-danger">
                        <strong>This action cannot be undone.</strong>
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="POST" action="{{ path('app_hr_complaints_delete', {'id': complaint.id}) }}" class="d-inline">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-2"></i>Delete Complaint
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endif %}

<style>
.hr-primary {
    background: linear-gradient(135deg, #e91e63 0%, #f06292 100%);
}

.hr-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.hr-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}
</style>
{% endblock %}
