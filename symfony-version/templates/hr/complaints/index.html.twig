{% extends 'hr/layout.html.twig' %}

{% block title %}HR Complaints - SmartHire{% endblock %}

{% block hr_page_title %}My Complaints{% endblock %}

{% block hr_content %}
<!-- Complaint Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stats-card hr-dashboard text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ pendingCount }}</h4>
                        <p class="card-text">Pending</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-clock-history fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card hr-info text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ openCount }}</h4>
                        <p class="card-text">Open</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-envelope-open fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card hr-warning text-dark">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ resolvedCount }}</h4>
                        <p class="card-text">Resolved</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-check-circle fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card hr-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ complaints|length }}</h4>
                        <p class="card-text">Total</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-file-text fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filters and Search -->
<div class="card mb-4">
    <div class="card-header hr-primary text-white">
        <h5 class="mb-0"><i class="bi bi-funnel me-2"></i>Filter & Search</h5>
    </div>
    <div class="card-body">
        <form method="GET" class="row g-3">
            <div class="col-md-4">
                <label for="search" class="form-label">Search</label>
                <input type="text" class="form-control" id="search" name="search" 
                       value="{{ search }}" placeholder="Search complaints...">
            </div>
            <div class="col-md-3">
                <label for="status" class="form-label">Status</label>
                <select class="form-select" id="status" name="status">
                    <option value="">All Status</option>
                    <option value="PENDING" {% if selectedStatus == 'PENDING' %}selected{% endif %}>Pending</option>
                    <option value="OPEN" {% if selectedStatus == 'OPEN' %}selected{% endif %}>Open</option>
                    <option value="RESOLVED" {% if selectedStatus == 'RESOLVED' %}selected{% endif %}>Resolved</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="type" class="form-label">Type</label>
                <select class="form-select" id="type" name="type">
                    <option value="">All Types</option>
                    {% for complaintType in complaintTypes %}
                        <option value="{{ complaintType.id }}" 
                                {% if selectedType == complaintType.id %}selected{% endif %}>
                            {{ complaintType.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">&nbsp;</label><br>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-1"></i> Search
                </button>
            </div>
        </form>
    </div>
</div>

<!-- New Complaint Button -->
<div class="row mb-4">
    <div class="col-12">
        <a href="{{ path('app_hr_complaints_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Submit New Complaint
        </a>
    </div>
</div>

<!-- Complaints List -->
<div class="card">
    <div class="card-header hr-info text-white">
        <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>My Complaints</h5>
    </div>
    <div class="card-body">
        {% if complaints|length > 0 %}
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Subject</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Priority</th>
                            <th>Submission Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for complaint in complaints %}
                            <tr>
                                <td>
                                    <a href="{{ path('app_hr_complaints_show', {'id': complaint.id}) }}" 
                                       class="text-decoration-none">
                                        {{ complaint.subject }}
                                    </a>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">
                                        {{ complaint.type.name ?? 'General' }}
                                    </span>
                                </td>
                                <td>
                                    {% if complaint.status == 'PENDING' %}
                                        <span class="badge bg-warning">Pending</span>
                                    {% elseif complaint.status == 'OPEN' %}
                                        <span class="badge bg-info">Open</span>
                                    {% elseif complaint.status == 'RESOLVED' %}
                                        <span class="badge bg-success">Resolved</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ complaint.status }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if complaint.priority == 'HIGH' %}
                                        <span class="badge bg-danger">High</span>
                                    {% elseif complaint.priority == 'MEDIUM' %}
                                        <span class="badge bg-warning">Medium</span>
                                    {% else %}
                                        <span class="badge bg-info">Low</span>
                                    {% endif %}
                                </td>
                                <td>{{ complaint.submissionDate|date('M d, Y') }}</td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('app_hr_complaints_show', {'id': complaint.id}) }}" 
                                           class="btn btn-sm btn-outline-primary" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        {% if complaint.status == 'PENDING' %}
                                            <a href="{{ path('app_hr_complaints_edit', {'id': complaint.id}) }}" 
                                               class="btn btn-sm btn-outline-warning" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form method="POST" 
                                                  action="{{ path('app_hr_complaints_delete', {'id': complaint.id}) }}" 
                                                  class="d-inline" 
                                                  onsubmit="return confirm('Are you sure you want to delete this complaint?')">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
                <h5 class="text-muted">No complaints found</h5>
                <p class="text-muted">
                    {% if search or selectedStatus or selectedType %}
                        Try adjusting your filters or 
                        <a href="{{ path('app_hr_complaints') }}">clear all filters</a>.
                    {% else %}
                        You haven't submitted any complaints yet. 
                        <a href="{{ path('app_hr_complaints_new') }}">Submit your first complaint</a>.
                    {% endif %}
                </p>
            </div>
        {% endif %}
    </div>
</div>

<style>
.hr-dashboard {
    background: linear-gradient(135deg, #e91e63 0%, #f06292 100%);
    box-shadow: 0 4px 15px rgba(233, 30, 99, 0.3);
}

.hr-primary {
    background: linear-gradient(135deg, #e91e63 0%, #f06292 100%);
}

.hr-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.hr-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}
</style>
{% endblock %}
