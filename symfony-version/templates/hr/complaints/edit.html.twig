{% extends 'hr/layout.html.twig' %}

{% block title %}Edit Complaint - SmartHire{% endblock %}

{% block hr_page_title %}Edit Complaint{% endblock %}

{% block hr_content %}
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header hr-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Complaint</h5>
            </div>
            <div class="card-body">
                {% for flash in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        {{ flash }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {% for flash in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        {{ flash }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {% if profanityWords is defined %}
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <strong>Profanity Detected:</strong> Your complaint contains inappropriate language: 
                        <em>{{ profanityWords|join(', ') }}</em>. Please remove these words and try again.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endif %}

                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Note:</strong> You can only edit complaints that are still pending. Once a complaint is opened by admin, you cannot modify it.
                </div>

                <form method="POST" action="{{ path('app_hr_complaints_edit', {'id': complaint.id}) }}">
                    <div class="mb-3">
                        <label for="type" class="form-label">Complaint Type <span class="text-danger">*</span></label>
                        <select class="form-select" id="type" name="type" required>
                            <option value="">Select a type...</option>
                            {% for complaintType in types %}
                                <option value="{{ complaintType.id }}" 
                                        {% if complaint.type and complaint.type.id == complaintType.id %}selected{% endif %}>
                                    {{ complaintType.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="subject" class="form-label">Subject <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="subject" name="subject" 
                               value="{{ filteredSubject|default(complaint.subject) }}" 
                               placeholder="Brief summary of your complaint" required>
                        <div class="form-text">Maximum 100 characters.</div>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="description" name="description" 
                                  rows="6" required placeholder="Provide detailed information about your complaint...">{% if filteredDescription is defined %}{{ filteredDescription }}{% else %}{{ complaint.description }}{% endif %}</textarea>
                        <div class="form-text">Minimum 20 characters. Please be specific and provide all relevant details.</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Original Submission:</strong><br>
                            <small class="text-muted">{{ complaint.submissionDate|date('M d, Y H:i') }}</small>
                        </div>
                        <div class="col-md-6">
                            <strong>Current Status:</strong><br>
                            <span class="badge bg-warning">Pending</span>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Important:</strong>
                        <ul class="mb-0 mt-2">
                            <li>Be respectful and professional in your language</li>
                            <li>Provide specific details and facts</li>
                            <li>Avoid using profanity or inappropriate language</li>
                            <li>After editing, your complaint will be reviewed again</li>
                        </ul>
                    </div>

                    <div class="d-flex justify-content-between">
                        <div>
                            <a href="{{ path('app_hr_complaints_show', {'id': complaint.id}) }}" class="btn btn-secondary me-2">
                                <i class="bi bi-arrow-left me-2"></i>Back to Complaint
                            </a>
                            <a href="{{ path('app_hr_complaints') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-list me-2"></i>All Complaints
                            </a>
                        </div>
                        <div>
                            <button type="button" class="btn btn-danger me-2" 
                                    data-bs-toggle="modal" data-bs-target="#deleteModal">
                                <i class="bi bi-trash me-2"></i>Delete
                            </button>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save me-2"></i>Update Complaint
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header hr-info text-white">
                <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Edit Guidelines</h6>
            </div>
            <div class="card-body">
                <h6>What You Can Edit</h6>
                <ul class="small">
                    <li>Complaint type/category</li>
                    <li>Subject line</li>
                    <li>Detailed description</li>
                    <li>Add missing information</li>
                </ul>

                <hr>

                <h6>Editing Rules</h6>
                <ul class="small">
                    <li>Only pending complaints can be edited</li>
                    <li>Profanity is not allowed</li>
                    <li>Minimum 20 characters for description</li>
                    <li>All fields are required</li>
                </ul>

                <hr>

                <h6>After Editing</h6>
                <ul class="small">
                    <li>Complaint status remains pending</li>
                    <li>Admin will review the changes</li>
                    <li>You'll receive updates via email</li>
                    <li>Edit history is tracked</li>
                </ul>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header hr-warning text-dark">
                <h6 class="mb-0"><i class="bi bi-shield-exclamation me-2"></i>Important Notice</h6>
            </div>
            <div class="card-body">
                <p class="small mb-0">
                    Any false or misleading information in complaints may result in 
                    disciplinary action. Please ensure all information provided is accurate.
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Complaint</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this complaint?</p>
                <p class="text-danger">
                    <strong>This action cannot be undone.</strong><br>
                    The complaint will be permanently removed from the system.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="POST" action="{{ path('app_hr_complaints_delete', {'id': complaint.id}) }}" class="d-inline">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-2"></i>Delete Complaint
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
.hr-primary {
    background: linear-gradient(135deg, #e91e63 0%, #f06292 100%);
}

.hr-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.hr-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}
</style>
{% endblock %}
