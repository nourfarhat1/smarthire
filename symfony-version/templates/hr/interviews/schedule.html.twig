{% extends 'hr/layout.html.twig' %}

{% block title %}Schedule Interview - SmartHire{% endblock %}

{% block hr_page_title %}Schedule Interview{% endblock %}

{% block hr_content %}
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header text-white" style="background: linear-gradient(135deg, #6c757d 0%, #495057 100%);">
                <h5 class="mb-0"><i class="bi bi-calendar-plus me-2"></i>Schedule Interview</h5>
            </div>
            <div class="card-body">
                {% for flash in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        {{ flash }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {% for flash in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        {{ flash }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Candidate Information:</strong>
                    <div class="mt-2">
                        <p class="mb-1"><strong>Name:</strong> {{ jobRequest.candidate.fullName }}</p>
                        <p class="mb-1"><strong>Email:</strong> {{ jobRequest.candidate.email }}</p>
                        {% if jobRequest.candidate.phoneNumber %}
                            <p class="mb-1"><strong>Phone:</strong> {{ jobRequest.candidate.phoneNumber }}</p>
                        {% endif %}
                        <p class="mb-0"><strong>Applied for:</strong> {{ jobRequest.jobOffer.title }}</p>
                    </div>
                </div>

                <form method="POST" action="{{ path('app_hr_interviews_schedule', {'jobRequestId': jobRequest.id}) }}">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="dateTime" class="form-label">Interview Date & Time <span class="text-danger">*</span></label>
                                <input type="datetime-local" class="form-control" id="dateTime" name="dateTime" required>
                                <div class="form-text">Select a future date and time for the interview.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="location" class="form-label">Interview Location <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="location" name="location" 
                                       placeholder="e.g. Office Room 101" required>
                                <div class="form-text">Specify the physical location (online meetings will have auto-generated links).</div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="isOnline" name="isOnline" checked>
                                    <label class="form-check-label" for="isOnline">
                                        <i class="bi bi-camera-video me-2"></i>Online Interview (Google Meet)
                                    </label>
                                    <div class="form-text">Check this to schedule an online interview with automatic Google Meet link generation.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="notes" class="form-label">Interview Notes</label>
                        <textarea class="form-control" id="notes" name="notes" rows="4"
                                  placeholder="Add any special instructions or notes for the interview..."></textarea>
                        <div class="form-text">Optional: Include interview format, topics to cover, or special requirements.</div>
                    </div>

                    <!-- Email and Calendar Integration Info -->
                    <div class="alert alert-success">
                        <i class="bi bi-envelope-check me-2"></i>
                        <strong>Automated Notifications:</strong>
                        <div class="mt-2">
                            <p class="mb-1"><i class="bi bi-check-circle text-success me-1"></i> Email notification will be sent to candidate</p>
                            <p class="mb-1"><i class="bi bi-check-circle text-success me-1"></i> Google Calendar invitation will be created</p>
                            <p class="mb-0"><i class="bi bi-check-circle text-success me-1"></i> Google Meet link will be generated for online interviews</p>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Interview Guidelines:</strong>
                        <ul class="mb-0 mt-2">
                            <li>Allow at least 24 hours notice for the candidate</li>
                            <li>Consider candidate's availability and timezone</li>
                            <li>Provide clear location or video call instructions</li>
                            <li>Include interview duration (usually 30-60 minutes)</li>
                            <li>Prepare interview questions based on job requirements</li>
                        </ul>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="{{ path('app_hr_interviews') }}" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Back to Interviews
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-calendar-plus me-2"></i>Schedule Interview
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header text-white" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);">
                <h6 class="mb-0"><i class="bi bi-question-circle me-2"></i>Scheduling Tips</h6>
            </div>
            <div class="card-body">
                <h6>Best Practices</h6>
                <ul class="small">
                    <li>Schedule interviews during business hours</li>
                    <li>Allow buffer time between interviews</li>
                    <li>Send calendar invitations to candidates</li>
                    <li>Confirm interview details via email</li>
                    <li>Have all necessary documents ready</li>
                </ul>

                <hr>

                <h6>Interview Formats</h6>
                <ul class="small">
                    <li><strong>In-person:</strong> Office meeting room</li>
                    <li><strong>Video call:</strong> Zoom, Teams, or Google Meet</li>
                    <li><strong>Phone call:</strong> For initial screening</li>
                    <li><strong>Panel interview:</strong> Multiple interviewers</li>
                </ul>

                <hr>

                <h6>Preparation Checklist</h6>
                <ul class="small mb-0">
                    <li>Review candidate's CV and cover letter</li>
                    <li>Prepare job-specific questions</li>
                    <li>Set up interview space or video call</li>
                    <li>Have job description available</li>
                    <li>Prepare evaluation criteria</li>
                </ul>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header text-white" style="background: linear-gradient(135deg, #6f42c1 0%, #5a32a3 100%);">
                <h6 class="mb-0"><i class="bi bi-shield-exclamation me-2"></i>Important</h6>
            </div>
            <div class="card-body">
                <p class="small mb-0">
                    Once scheduled, the interview will be visible in your interview dashboard. 
                    The candidate's application status will be updated to "Interview Scheduled".
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
