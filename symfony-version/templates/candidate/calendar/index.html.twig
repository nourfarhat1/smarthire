{% extends 'candidate/layout.html.twig' %}

{% block title %}My Job Applications Calendar{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1><i class="bi bi-calendar3 me-2"></i>My Job Applications Calendar</h1>
                <div>
                    <a href="{{ path('app_candidate_applications') }}" class="btn btn-outline-primary">
                        <i class="bi bi-list-ul me-2"></i>View Applications
                    </a>
                </div>
            </div>
            
            <!-- Legend -->
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Status Legend</h5>
                    <div class="row">
                        <div class="col-md-3 col-sm-6 mb-2">
                            <span class="badge p-2" style="background-color: #28a745; color: white;">
                                <i class="bi bi-check-circle me-1"></i>Accepted
                            </span>
                        </div>
                        <div class="col-md-3 col-sm-6 mb-2">
                            <span class="badge p-2" style="background-color: #dc3545; color: white;">
                                <i class="bi bi-x-circle me-1"></i>Rejected
                            </span>
                        </div>
                        <div class="col-md-3 col-sm-6 mb-2">
                            <span class="badge p-2" style="background-color: #ff69b4; color: white;">
                                <i class="bi bi-person-video me-1"></i>Interviewing
                            </span>
                        </div>
                        <div class="col-md-3 col-sm-6 mb-2">
                            <span class="badge p-2" style="background-color: #ffc107; color: black;">
                                <i class="bi bi-clock me-1"></i>Pending
                            </span>
                        </div>
                        <div class="col-md-3 col-sm-6 mb-2">
                            <span class="badge p-2" style="background-color: #ff8c00; color: white;">
                                <i class="bi bi-exclamation-triangle me-1"></i>Pending + Rejected
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Calendar -->
            <div class="card">
                <div class="card-body">
                    <div id="calendar-holder"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Job Details Modal -->
<div class="modal fade" id="jobDetailsModal" tabindex="-1" aria-labelledby="jobDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="jobDetailsModalLabel">
                    <i class="bi bi-briefcase me-2"></i>Job Application Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-12">
                        <div class="card border-0">
                            <div class="card-body">
                                <h6 class="card-title text-primary">
                                    <i class="bi bi-calendar3 me-2"></i>
                                    Applications for <span id="modalDate">Selected Date</span>
                                </h6>
                                <div class="mt-3" id="applicationsList">
                                    <!-- Applications list will be inserted here -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <a href="{{ path('app_candidate_applications') }}" class="btn btn-primary">
                    <i class="bi bi-list-ul me-2"></i>View All Applications
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            var calendarEl = document.getElementById('calendar-holder');
            
            if (!calendarEl) {
                console.error('Calendar element not found');
                return;
            }
            
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay,listMonth'
                },
                height: 'auto',
                events: '/fc-load-events',
                loading: function(bool) {
                    console.log('Calendar loading:', bool);
                },
                eventSourceSuccess: function(content, xhr) {
                    console.log('Events loaded:', content);
                    return content;
                },
                eventSourceFailure: function(error) {
                    console.error('Failed to load events:', error);
                },
                eventClick: function(info) {
                    // Check if this is a date event
                    if (info.event.extendedProps.isDateEvent) {
                        // Show modal with applications list
                        showApplicationsListModal(info.event.extendedProps);
                    }
                },
                eventDidMount: function(info) {
                    // Style arrows to look better
                    if (info.event.extendedProps.isArrow) {
                        info.el.style.fontSize = '16px';
                        info.el.style.fontWeight = 'bold';
                        info.el.style.cursor = 'pointer';
                        
                        // Add hover effect
                        info.el.addEventListener('mouseenter', function() {
                            this.style.transform = 'scale(1.2)';
                            this.style.transition = 'transform 0.2s';
                        });
                        
                        info.el.addEventListener('mouseleave', function() {
                            this.style.transform = 'scale(1)';
                        });
                    }
                },
                eventTimeFormat: {
                    hour: '2-digit',
                    minute: '2-digit',
                    hour12: false
                },
                displayEventTime: false,
                dayMaxEvents: true,
                moreLinkClick: 'popover'
            });
            calendar.render();
        });

        function showApplicationsListModal(eventProps) {
            // Set modal date
            document.getElementById('modalDate').textContent = eventProps.date || 'N/A';
            
            // Clear and populate applications list
            var applicationsList = document.getElementById('applicationsList');
            applicationsList.innerHTML = '';
            
            if (eventProps.applications && eventProps.applications.length > 0) {
                eventProps.applications.forEach(function(app, index) {
                    var statusColor = getStatusColor(app.status);
                    
                    var appHtml = `
                        <div class="d-flex justify-content-between align-items-center p-2 border-bottom ${index === 0 ? 'border-top' : ''}">
                            <div class="flex-grow-1">
                                <strong>${app.title}</strong>
                                <br>
                                <small class="text-muted">Applied: ${app.appliedDate}</small>
                            </div>
                            <span class="badge ms-2" style="background-color: ${statusColor}; color: white;">
                                ${app.status}
                            </span>
                        </div>
                    `;
                    
                    applicationsList.innerHTML += appHtml;
                });
            } else {
                applicationsList.innerHTML = '<p class="text-muted">No applications found for this date.</p>';
            }
            
            // Show modal
            var modal = new bootstrap.Modal(document.getElementById('jobDetailsModal'));
            modal.show();
        }

        function getStatusColor(status) {
            switch (status) {
                case 'ACCEPTED':
                    return '#28a745'; // Green
                case 'REJECTED':
                    return '#dc3545'; // Red
                case 'INTERVIEWING':
                    return '#ff69b4'; // Pink
                case 'PENDING':
                    return '#ffc107'; // Yellow
                default:
                    return '#6c757d'; // Gray
            }
        }
        
        // Render the calendar - this was missing!
        calendar.render();
        
        // Add a small delay and then manually refresh events to ensure they load
        setTimeout(() => {
            console.log('Manually refreshing events...');
            calendar.refetchEvents();
        }, 500);
        
        // Also try to refresh events after a longer delay as a fallback
        setTimeout(() => {
            console.log('Second attempt to refresh events...');
            calendar.refetchEvents();
        }, 2000);
    </script>
{% endblock %}
