{% extends 'candidate/layout.html.twig' %}

{% block title %}My Applications - SmartHire{% endblock %}

{% block candidate_page_title %}My Applications{% endblock %}

{% block candidate_actions %}
<div class="btn-group" role="group">
    <a href="{{ path('app_candidate_calendar') }}" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-calendar3 me-1"></i>Calendar
    </a>
    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#chatModal">
        <i class="bi bi-chat-dots me-1"></i>Ask AI
    </button>
</div>
{% endblock %}

{% block candidate_content %}
<!-- Application Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stats-card candidate-dashboard text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ totalApplications }}</h4>
                        <p class="card-text">Total Applications</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-file-text fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-info text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ pendingApplications }}</h4>
                        <p class="card-text">Pending Review</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-clock-history fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ acceptedApplications }}</h4>
                        <p class="card-text">Accepted</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-check-circle fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-warning text-dark">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ rejectedApplications }}</h4>
                        <p class="card-text">Rejected</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-x-circle fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Actions and Filters -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header candidate-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-file-text me-2"></i>Application Management</h5>
                    <div>
                        <a href="{{ path('app_candidate_job_marketplace') }}" class="btn btn-light btn-sm me-2">
                            <i class="bi bi-briefcase me-1"></i>Job Marketplace
                        </a>
                        <a href="{{ path('app_candidate_spontaneous_application') }}" class="btn btn-light btn-sm me-2">
                            <i class="bi bi-file-plus me-1"></i>Spontaneous Application
                        </a>
                        <a href="{{ path('app_candidate_training_recommendations') }}" class="btn btn-light btn-sm">
                            <i class="bi bi-mortarboard me-1"></i>Training Recommendations
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-4">
                        <label for="search" class="form-label">Search Applications</label>
                        <input type="text" class="form-control" id="search" name="search" value="{{ search }}" placeholder="Search by job title or company...">
                    </div>
                    <div class="col-md-3">
                        <label for="status" class="form-label">Filter by Status</label>
                        <select class="form-select" id="status" name="status">
                            <option value="">All Status</option>
                            <option value="PENDING" {{ selectedStatus == 'PENDING' ? 'selected' : '' }}>Pending</option>
                            <option value="ACCEPTED" {{ selectedStatus == 'ACCEPTED' ? 'selected' : '' }}>Accepted</option>
                            <option value="REJECTED" {{ selectedStatus == 'REJECTED' ? 'selected' : '' }}>Rejected</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="type" class="form-label">Filter by Type</label>
                        <select class="form-select" id="type" name="type">
                            <option value="all" {{ selectedType == 'all' ? 'selected' : '' }}>All Applications</option>
                            <option value="job" {{ selectedType == 'job' ? 'selected' : '' }}>Job Applications</option>
                            <option value="spontaneous" {{ selectedType == 'spontaneous' ? 'selected' : '' }}>Spontaneous Applications</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">&nbsp;</label>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-outline-success">
                                <i class="bi bi-search me-2"></i>Filter
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Job Applications -->
{% if jobRequests|length > 0 %}
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header candidate-info text-white">
                <h6 class="mb-0"><i class="bi bi-briefcase me-2"></i>Job Applications</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Job Title</th>
                                <th>Company</th>
                                <th>Application Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for jobRequest in jobRequests %}
                                <tr>
                                    <td>
                                        {% if jobRequest.jobOffer %}
                                        <strong>{{ jobRequest.jobOffer.title }}</strong>
                                        <br>
                                        <small class="text-muted">{{ jobRequest.jobOffer.location }}</small>
                                    {% else %}
                                        <strong>Spontaneous Application</strong>
                                        <br>
                                        <small class="text-muted">No specific job</small>
                                    {% endif %}
                                    </td>
                                    <td>
                                        {% if jobRequest.jobOffer and jobRequest.jobOffer.recruiter %}
                                            {{ jobRequest.jobOffer.recruiter.firstName }} {{ jobRequest.jobOffer.recruiter.lastName }}
                                        {% elseif jobRequest.jobOffer %}
                                            {{ jobRequest.jobOffer.title }}
                                        {% else %}
                                            Spontaneous Application
                                        {% endif %}
                                    </td>
                                    <td>{{ jobRequest.submissionDate|date('M d, Y') }}</td>
                                    <td>
                                        <!-- DEBUG: Status = "{{ jobRequest.status }}" -->
                                        {% if jobRequest.status == 'PENDING' %}
                                            <span class="badge bg-warning">Pending</span>
                                        {% elseif jobRequest.status == 'ACCEPTED' %}
                                            <span class="badge bg-success">Accepted</span>
                                        {% elseif jobRequest.status == 'REJECTED' %}
                                            <span class="badge bg-danger">Rejected</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ jobRequest.status }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="{{ path('app_candidate_view_application', {'id': jobRequest.id}) }}" class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-eye me-1"></i>View
                                            </a>
                                            <!-- DEBUG: Checking if status == 'PENDING', current status: "{{ jobRequest.status }}" -->
                                            {% if jobRequest.status == 'PENDING' %}
                                                <!-- DEBUG: Inside PENDING condition - showing buttons -->
                                                <a href="{{ path('app_candidate_edit_application', {'id': jobRequest.id}) }}" class="btn btn-sm btn-outline-warning">
                                                    <i class="bi bi-pencil me-1"></i>Edit
                                                </a>
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete({{ jobRequest.id }})">
                                                    <i class="bi bi-trash me-1"></i>Delete
                                                </button>
                                            {% else %}
                                                <!-- DEBUG: Not PENDING - delete button hidden -->
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}

<!-- Spontaneous Applications -->
{% if spontaneousApplications|length > 0 %}
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header candidate-warning text-dark">
                <h6 class="mb-0"><i class="bi bi-file-plus me-2"></i>Spontaneous Applications</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Subject</th>
                                <th>Category</th>
                                <th>Submission Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for jobRequest in spontaneousApplications %}
                                <tr>
                                    <td>
                                        <strong>{{ jobRequest.jobTitle }}</strong>
                                        <br>
                                        <small class="text-muted">{{ jobRequest.coverLetter|slice(0, 100) }}...</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">{{ jobRequest.categorie }}</span>
                                    </td>
                                    <td>{{ jobRequest.submissionDate|date('M d, Y') }}</td>
                                    <td>
                                        {% if jobRequest.status == 'PENDING' %}
                                            <span class="badge bg-warning">Pending</span>
                                        {% elseif jobRequest.status == 'ACCEPTED' %}
                                            <span class="badge bg-success">Accepted</span>
                                        {% elseif jobRequest.status == 'REJECTED' %}
                                            <span class="badge bg-danger">Rejected</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ jobRequest.status }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="{{ path('app_candidate_view_application', {'id': jobRequest.id}) }}" class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-eye me-1"></i>View
                                            </a>
                                            {% if jobRequest.status == 'PENDING' %}
                                                <a href="{{ path('app_candidate_edit_application', {'id': jobRequest.id}) }}" class="btn btn-sm btn-outline-warning">
                                                    <i class="bi bi-pencil me-1"></i>Edit
                                                </a>
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete({{ jobRequest.id }})">
                                                    <i class="bi bi-trash me-1"></i>Delete
                                                </button>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}

<!-- No Applications -->
{% if jobRequests|length == 0 and spontaneousApplications|length == 0 %}
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-file-text fs-1 text-muted mb-3"></i>
                <h5>No Applications Found</h5>
                <p class="text-muted">
                    You haven't submitted any applications yet. Start browsing job opportunities or submit a spontaneous application!
                </p>
                <div class="d-flex justify-content-center gap-2">
                    <a href="{{ path('app_candidate_job_marketplace') }}" class="btn btn-success">
                        <i class="bi bi-briefcase me-2"></i>Browse Jobs
                    </a>
                    <a href="{{ path('app_candidate_spontaneous_application') }}" class="btn btn-outline-success">
                        <i class="bi bi-file-plus me-2"></i>Spontaneous Application
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}

<style>
.candidate-dashboard {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
    box-shadow: 0 4px 15px rgba(135, 160, 66, 0.3);
}

.candidate-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.candidate-success {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
}

.candidate-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}

.candidate-primary {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
}

.card {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: none;
}

.btn-outline-success {
    border-color: #87a042;
    color: #87a042;
}

.btn-outline-success:hover {
    background-color: #87a042;
    border-color: #87a042;
}
</style>

<!-- Chat Modal -->
<div class="modal fade" id="chatModal" tabindex="-1" aria-labelledby="chatModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header candidate-primary text-white">
                <h5 class="modal-title" id="chatModalLabel">
                    <i class="bi bi-chat-dots me-2"></i>AI Assistant - Job Applications
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Instructions -->
                <div class="alert alert-info mb-3">
                    <h6><i class="bi bi-info-circle me-2"></i>Ask about your applications</h6>
                    <p class="mb-1">Examples:</p>
                    <ul class="mb-0 small">
                        <li>"How many applications do I have?"</li>
                        <li>"What are my pending applications?"</li>
                        <li>"Show me accepted applications"</li>
                    </ul>
                </div>

                <!-- Chat Messages -->
                <div id="chat-messages" class="chat-container mb-3" style="height: 300px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 0.375rem; padding: 1rem; background-color: #f8f9fa;">
                    <div class="text-center text-muted">
                        <i class="bi bi-chat-dots fs-3 mb-2"></i>
                        <p class="mb-0">Ask a question about your job applications</p>
                    </div>
                </div>

                <!-- Input Form -->
                <form id="chat-form" data-turbo="false">
                    <div class="input-group">
                        <input 
                            type="text" 
                            id="chat-input" 
                            class="form-control" 
                            placeholder="Ask about your applications..." 
                            autocomplete="off"
                        >
                        <button class="btn btn-primary" type="submit" id="send-btn">
                            <i class="bi bi-send me-1"></i>Send
                        </button>
                    </div>
                </form>

                <!-- Loading Indicator -->
                <div id="loading-indicator" class="text-center mt-2" style="display: none;">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <small class="text-muted">Processing...</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chat JavaScript -->
<script>
{
    class ApplicationChat {
        constructor() {
            this.form = document.getElementById('chat-form');
            this.input = document.getElementById('chat-input');
            this.messagesContainer = document.getElementById('chat-messages');
            
            if (this.form) {
                this.init();
            }
        }

        init() {
            this.form.addEventListener('submit', (e) => this.handleSubmit(e));
        }

        async handleSubmit(e) {
            e.preventDefault();
            const prompt = this.input.value.trim();
            if (!prompt) return;

            // Add user message to UI
            this.addMessage(prompt, 'user');
            this.input.value = '';

            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    body: JSON.stringify({ prompt: prompt }),
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                this.addMessage(data.answer, 'ai');
            } catch (err) {
                this.addMessage("Connection error: " + err.message, 'error');
            }
        }

        addMessage(text, type) {
            const div = document.createElement('div');
            div.className = `message ${type}-message mb-2 p-2 rounded`;
            div.style.backgroundColor = type === 'user' ? '#e7f3ff' : '#f1f1f1';
            div.innerText = text;
            this.messagesContainer.appendChild(div);
            this.messagesContainer.scrollTop = this.messagesContainer.scrollHeight;
        }
    }

    // Initialize on page load and Turbo navigation
    document.addEventListener('turbo:load', () => {
        new ApplicationChat();
    });

    // Delete confirmation function
    function confirmDelete(applicationId) {
        if (confirm('Are you sure you want to delete this application?')) {
            // Create and submit form
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/candidate/applications/delete/' + applicationId;
            form.style.display = 'none';
            
            // Add CSRF token if needed
            const csrfToken = document.querySelector('meta[name="csrf-token"]');
            if (csrfToken) {
                const csrfInput = document.createElement('input');
                csrfInput.type = 'hidden';
                csrfInput.name = '_token';
                csrfInput.value = csrfToken.getAttribute('content');
                form.appendChild(csrfInput);
            }
            
            document.body.appendChild(form);
            form.submit();
        }
    }
}
</script>
{% endblock %}
