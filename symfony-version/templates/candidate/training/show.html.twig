{% extends 'candidate/layout.html.twig' %}

{% block title %}{{ training.title }} - SmartHire{% endblock %}

{% block candidate_page_title %}{{ training.title }}{% endblock %}

{% block candidate_content %}
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header candidate-primary text-white">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h5 class="mb-1">{{ training.title }}</h5>
                        <small class="text-white-50">{{ training.category }}</small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        {% if userRating %}
                            <span class="badge bg-light text-dark">Rated</span>
                        {% endif %}
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button" id="languageDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-translate me-1"></i>Language
                                <i class="bi bi-chevron-down ms-1"></i>
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="languageDropdown">
                                <li><a class="dropdown-item" href="#" onclick="translatePage('en')">
                                    <i class="bi bi-flag me-2"></i> English
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="translatePage('fr')">
                                    <i class="bi bi-flag me-2"></i> Français
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="translatePage('ar')">
                                    <i class="bi bi-flag me-2"></i> العربية
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="translatePage('es')">
                                    <i class="bi bi-flag me-2"></i> Español
                                </a></li>
                            </ul>
                        </div>
                    </div>
                    {{ gtranslate_widget() }}
                </div>
            </div>
            <div class="card-body">
                <!-- Training Overview -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <strong>Category:</strong><br>
                            <span class="badge bg-info">{{ training.category }}</span>
                        </div>
                        <div class="mb-3">
                            <strong>Created:</strong><br>
                            {{ training.createdAt|date('F j, Y') }}
                        </div>
                        <div class="mb-3">
                            <strong>Rating:</strong><br>
                            <div class="d-flex align-items-center">
                                <div class="me-2">
                                    {% set totalVotes = training.likes + training.dislikes %}
                                    {% if totalVotes > 0 %}
                                        {% set rating = (training.likes / totalVotes) * 5 %}
                                        {% for i in 1..5 %}
                                            {% if i <= rating %}
                                                <i class="bi bi-star-fill text-warning"></i>
                                            {% else %}
                                                <i class="bi bi-star text-muted"></i>
                                            {% endif %}
                                        {% endfor %}
                                            <span class="ms-1">{{ rating|number_format(1) }}</span>
                                        {% else %}
                                            <i class="bi bi-star text-muted"></i>
                                            <i class="bi bi-star text-muted"></i>
                                            <i class="bi bi-star text-muted"></i>
                                            <i class="bi bi-star text-muted"></i>
                                            <i class="bi bi-star text-muted"></i>
                                            <span class="ms-1">No rating</span>
                                        {% endif %}
                                    </div>
                                    <small class="text-muted">({{ totalVotes }} votes)</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <strong>Engagement:</strong><br>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-success me-2">
                                    <i class="bi bi-hand-thumbs-up me-1"></i>{{ training.likes }} Likes
                                </span>
                                <span class="badge bg-danger">
                                    <i class="bi bi-hand-thumbs-down me-1"></i>{{ training.dislikes }} Dislikes
                                </span>
                            </div>
                        </div>
                        {% if training.videoUrl %}
                        <div class="mb-3">
                            <strong>Video Content:</strong><br>
                            <span class="badge bg-success">
                                <i class="bi bi-play-circle me-1"></i>Video Available
                            </span>
                        </div>
                        {% endif %}
                        <div class="mb-3">
                            <strong>Admin:</strong><br>
                            {% if training.admin %}
                                {{ training.admin.firstName }} {{ training.admin.lastName }}
                            {% else %}
                                System Admin
                            {% endif %}
                        </div>
                    </div>
                </div>

                <!-- Training Description -->
                <div class="mb-4">
                    <h6><i class="bi bi-info-circle me-2"></i>Description</h6>
                    <div class="p-3 bg-light rounded">
                        {{ training.description|nl2br }}
                    </div>
                </div>

                <!-- Video Content -->
                {% if training.videoUrl %}
                <div class="mb-4">
                    <h6><i class="bi bi-play-circle me-2"></i>Video Content</h6>
                    <div class="ratio ratio-16x9">
                        <iframe src="{{ training.videoUrl }}" title="{{ training.title }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                    </div>
                </div>
                {% endif %}

                <!-- Actions -->
                <div class="mb-4">
                    <h6><i class="bi bi-hand-thumbs-up me-2"></i>Rate This Training</h6>
                    <div class="d-flex gap-2">
                        {% set userVote = null %}
                        {% if app.user %}
                            {% for vote in training.userVotes %}
                                {% if vote.user.id == app.user.id %}
                                    {% set userVote = vote %}
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                        
                        <div class="d-flex gap-2" id="voting-section">
                            <button type="button" class="btn {% if userVote and userVote.isLike() %}btn-success disabled{% else %}btn-outline-success{% endif %}" 
                                    {% if userVote and userVote.isLike() %}disabled{% endif %}"
                                    id="like-btn-{{ training.id }}"
                                    onclick="vote({{ training.id }}, 'like')">
                                <i class="bi bi-hand-thumbs-up me-2"></i>
                                <span id="like-count-{{ training.id }}">{% if userVote and userVote.isLike() %}Liked{% else %}Like{% endif %} ({{ training.likes }})</span>
                            </button>
                            <button type="button" class="btn {% if userVote and userVote.isDislike() %}btn-secondary disabled{% else %}btn-outline-secondary{% endif %}"
                                    {% if userVote and userVote.isDislike() %}disabled{% endif %}"
                                    id="dislike-btn-{{ training.id }}"
                                    onclick="vote({{ training.id }}, 'dislike')">
                                <i class="bi bi-hand-thumbs-down me-2"></i>
                                <span id="dislike-count-{{ training.id }}">{% if userVote and userVote.isDislike() %}Disliked{% else %}Dislike{% endif %} ({{ training.dislikes }})</span>
                            </button>
                        </div>
                    </div>
                    {% if userVote %}
                        <small class="text-muted mt-2 d-block">
                            <i class="bi bi-info-circle me-1"></i>
                            You can change your vote by clicking the other option.
                        </small>
                    {% endif %}
                </div>

                            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header candidate-info text-white">
                <h6 class="mb-0"><i class="bi bi-lightbulb me-2"></i>Learning Tips</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-success">
                    <h6><i class="bi bi-check-circle me-2"></i>Best Practices</h6>
                    <ul class="mb-0">
                        <li>Watch videos in a quiet environment</li>
                        <li>Take notes during the training</li>
                        <li>Practice what you learn immediately</li>
                        <li>Share your progress with peers</li>
                    </ul>
                </div>
                
                <div class="alert alert-warning">
                    <h6><i class="bi bi-exclamation-triangle me-2"></i>Remember</h6>
                    <ul class="mb-0">
                        <li>Consistency is key to learning</li>
                        <li>Don't skip practice exercises</li>
                        <li>Ask questions when confused</li>
                        <li>Apply skills to real projects</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header candidate-warning text-dark">
                <h6 class="mb-0"><i class="bi bi-graph-up me-2"></i>Related Categories</h6>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <a href="{{ path('app_candidate_training', {'category': training.category}) }}" class="list-group-item list-group-item-action">
                        <i class="bi bi-tag me-2"></i>{{ training.category }}
                        <span class="badge bg-secondary float-end">View All</span>
                    </a>
                    <a href="{{ path('app_candidate_training') }}" class="list-group-item list-group-item-action">
                        <i class="bi bi-grid me-2"></i>All Trainings
                        <span class="badge bg-secondary float-end">Browse</span>
                    </a>
                </div>
            </div>
        </div>

        
        <div class="card mt-3">
            <div class="card-header candidate-primary text-white">
                <h6 class="mb-0"><i class="bi bi-share me-2"></i>Share This Training</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <button class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-linkedin me-1"></i>Share on LinkedIn
                    </button>
                    <button class="btn btn-sm btn-outline-info">
                        <i class="bi bi-twitter me-1"></i>Share on Twitter
                    </button>
                    <button class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-envelope me-1"></i>Email to Friend
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.candidate-primary {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
}

.candidate-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.candidate-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}

.candidate-success {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
}

.card {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: none;
}

.btn-outline-success {
    border-color: #87a042;
    color: #87a042;
}

.btn-outline-success:hover {
    background-color: #87a042;
    border-color: #87a042;
}
</style>
{% endblock %}

{% block javascripts %}
<script>
function vote(trainingId, voteType) {
    const likeBtn = document.getElementById(`like-btn-${trainingId}`);
    const dislikeBtn = document.getElementById(`dislike-btn-${trainingId}`);
    const likeCount = document.getElementById(`like-count-${trainingId}`);
    const dislikeCount = document.getElementById(`dislike-count-${trainingId}`);
    
    // Disable both buttons during request
    likeBtn.disabled = true;
    dislikeBtn.disabled = true;
    
    const route = voteType === 'like' 
        ? `{{ path('app_candidate_training_like', {'id': 'PLACEHOLDER'}) }}`.replace('PLACEHOLDER', trainingId)
        : `{{ path('app_candidate_training_dislike', {'id': 'PLACEHOLDER'}) }}`.replace('PLACEHOLDER', trainingId);
    
    fetch(route, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: `vote_type=${voteType}`
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Update button states and counts
            if (voteType === 'like') {
                likeBtn.classList.add('btn-success');
                likeBtn.classList.remove('btn-outline-success');
                likeBtn.disabled = true;
                likeBtn.innerHTML = '<i class="bi bi-hand-thumbs-up me-2"></i>Liked';
                
                dislikeBtn.classList.remove('btn-secondary');
                dislikeBtn.classList.add('btn-outline-secondary');
                dislikeBtn.disabled = false;
                dislikeBtn.innerHTML = '<i class="bi bi-hand-thumbs-down me-2"></i>Dislike';
            } else {
                dislikeBtn.classList.add('btn-secondary');
                dislikeBtn.classList.remove('btn-outline-secondary');
                dislikeBtn.disabled = true;
                dislikeBtn.innerHTML = '<i class="bi bi-hand-thumbs-down me-2"></i>Disliked';
                
                likeBtn.classList.remove('btn-success');
                likeBtn.classList.add('btn-outline-success');
                likeBtn.disabled = false;
                likeBtn.innerHTML = '<i class="bi bi-hand-thumbs-up me-2"></i>Like';
            }
            
            // Update counts
            if (likeCount) likeCount.textContent = data.likes;
            if (dislikeCount) dislikeCount.textContent = data.dislikes;
            
            // Show success message
            showNotification(data.message, 'success');
        } else {
            // Re-enable buttons if there was an error
            likeBtn.disabled = false;
            dislikeBtn.disabled = false;
            showNotification(data.error || 'Vote failed', 'error');
        }
    })
    .catch(error => {
        // Re-enable buttons on error
        likeBtn.disabled = false;
        dislikeBtn.disabled = false;
        showNotification('Network error occurred', 'error');
    });
}

function showNotification(message, type) {
    // Create notification element
    const notification = document.createElement('div');
    notification.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
    notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        min-width: 250px;
}

function translatePage(language) {
    // Store selected language in localStorage
    localStorage.setItem('selectedLanguage', language);
    
    // Reload page with language parameter
    const currentUrl = new URL(window.location.href);
    currentUrl.searchParams.set('lang', language);
    window.location.href = currentUrl.toString();
}

// Set language on page load based on localStorage
document.addEventListener('DOMContentLoaded', function() {
    const savedLanguage = localStorage.getItem('selectedLanguage');
    if (savedLanguage) {
        const currentUrl = new URL(window.location.href);
        currentUrl.searchParams.set('lang', savedLanguage);
        window.location.href = currentUrl.toString();
    }
});
    `;
    notification.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    `;
    
    document.body.appendChild(notification);
    
    // Auto-remove after 3 seconds
    setTimeout(() => {
        if (notification.parentNode) {
            notification.parentNode.removeChild(notification);
        }
    }, 3000);
}
</script>
{% endblock %}
