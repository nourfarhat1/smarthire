{% extends 'admin/layout.html.twig' %}

{% block title %}Change Password - SmartHire{% endblock %}

{% block admin_page_title %}Change Password{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="bi bi-lock me-2"></i>Change Password
                </h4>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                
                <div class="mb-3">
                    {{ form_label(form.currentPassword, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.currentPassword, {'attr': {'class': 'form-control', 'placeholder': 'Enter your current password'}}) }}
                    {{ form_errors(form.currentPassword) }}
                    <div class="form-text">For security, please enter your current password</div>
                </div>
                
                <div class="mb-3">
                    {{ form_label(form.newPassword, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.newPassword, {'attr': {'class': 'form-control', 'placeholder': 'Enter your new password'}}) }}
                    {{ form_errors(form.newPassword) }}
                    <div class="form-text">Min 8 characters, must contain uppercase, lowercase, and number</div>
                </div>
                
                <div class="mb-3">
                    {{ form_label(form.confirmPassword, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.confirmPassword, {'attr': {'class': 'form-control', 'placeholder': 'Confirm your new password'}}) }}
                    {{ form_errors(form.confirmPassword) }}
                    <div class="form-text">Re-enter your new password to confirm</div>
                </div>
                
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Back to Profile
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-shield-check me-2"></i>Change Password
                    </button>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
        
        <!-- Enhanced Security Information -->
        <div class="card mt-4">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="bi bi-shield-check me-2"></i>Enhanced Security Information
                </h6>
            </div>
            <div class="card-body">
                <div class="alert alert-danger">
                    <h6><i class="bi bi-exclamation-triangle me-2"></i>Admin Security Requirements:</h6>
                    <ul class="mb-0">
                        <li>Use a unique, complex password for admin access</li>
                        <li>Include uppercase, lowercase, numbers, and special characters</li>
                        <li>Avoid using common words or personal information</li>
                        <li>Change your password every 60 days</li>
                        <li>Never share your admin credentials</li>
                        <li>Enable two-factor authentication when available</li>
                    </ul>
                </div>
                
                <div class="row text-center">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <i class="bi bi-check-circle text-success fs-3"></i>
                            <p class="mb-0"><strong>Encrypted Storage</strong></p>
                            <small class="text-muted">Your password is securely encrypted</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <i class="bi bi-clock-history text-warning fs-3"></i>
                            <p class="mb-0"><strong>Regular Updates</strong></p>
                            <small class="text-muted">Update passwords every 60 days</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <i class="bi bi-shield-lock text-danger fs-3"></i>
                            <p class="mb-0"><strong>Maximum Security</strong></p>
                            <small class="text-muted">Admin accounts require extra protection</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Admin Account Status -->
        <div class="card mt-4">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="bi bi-person-badge me-2"></i>Admin Account Status
                </h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p class="mb-2"><strong>Account Type:</strong> <span class="badge bg-danger">Administrator</span></p>
                        <p class="mb-2"><strong>Last Password Change:</strong> <span class="text-muted">Not recorded</span></p>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-2"><strong>Account Status:</strong> <span class="badge bg-success">Active</span></p>
                        <p class="mb-2"><strong>Security Level:</strong> <span class="badge bg-warning">High</span></p>
                    </div>
                </div>
                
                <div class="alert alert-info mt-3">
                    <h6><i class="bi bi-info-circle me-2"></i>System Access:</h6>
                    <p class="mb-0">Your administrator account has access to all system features and user data. Please ensure your password is strong and secure to protect the integrity of the SmartHire platform.</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
