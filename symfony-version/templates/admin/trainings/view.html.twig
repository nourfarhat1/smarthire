{% extends 'admin/layout.html.twig' %}

{% block admin_page_title %}View Training{% endblock %}

{% block upper %}
    <!-- Page Header -->
    <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0">View Training: {{ training.title }}</h1>
            <div class="d-flex gap-2">
                {% block admin_actions %}{% endblock %}
                {{ gtranslate_widget() }}
            </div>
        </div>
    </div>
{% endblock %}

{% block admin_content %}
<style>
.stats-card {
    border: none;
    border-radius: 15px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
}

.stats-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 12px rgba(0,0,0,0.12);
}

.stats-card .card-body {
    padding: 1.5rem;
}

/* Soft, professional color palette */
.soft-blue {
    background: linear-gradient(135deg, #6B8CAE, #4A6FA5);
    color: white;
}

.soft-teal {
    background: linear-gradient(135deg, #5D9C9E, #4A7C7E);
    color: white;
}

.soft-sage {
    background: linear-gradient(135deg, #87A96B, #6B8E5A);
    color: white;
}

.soft-coral {
    background: linear-gradient(135deg, #E6B89C, #D4A574);
    color: white;
}

.soft-lavender {
    background: linear-gradient(135deg, #9B8FB3, #7F6B8F);
    color: white;
}

.soft-cream {
    background: linear-gradient(135deg, #F5E6D3, #E8DCC0);
    color: #333;
}
</style>
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header soft-coral text-white">
                <h4 class="mb-0">
                    <i class="bi bi-play-circle me-2"></i>{{ training.title }}
                </h4>
            </div>
            <div class="card-body">
                <!-- Training Details -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6>Category</h6>
                        <span class="badge bg-info">{{ training.category }}</span>
                    </div>
                    <div class="col-md-6">
                        <h6>Created By</h6>
                        <span class="text-muted">{{ training.adminName|default('Admin') }}</span>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6>Created Date</h6>
                        <span class="text-muted">{{ training.createdAt|date('M d, Y H:i') }}</span>
                    </div>
                    <div class="col-md-6">
                        <h6>Engagement</h6>
                        <div class="d-flex gap-2">
                            <span class="badge bg-success">
                                <i class="bi bi-hand-thumbs-up"></i> {{ training.likes }}
                            </span>
                            <span class="badge bg-danger">
                                <i class="bi bi-hand-thumbs-down"></i> {{ training.dislikes }}
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Description -->
                <div class="card bg-light mb-4">
                    <div class="card-body">
                        <h6 class="card-title">Description</h6>
                        <div class="p-3 bg-white rounded">
                            {{ training.description|raw|nl2br }}
                        </div>
                    </div>
                </div>

                <!-- Video Section -->
                {% if training.videoUrl %}
                <div class="card bg-light mb-4">
                    <div class="card-body">
                        <h6 class="card-title">Training Video</h6>
                        <div class="ratio ratio-16x9">
                            <iframe src="{{ training.videoUrl }}" 
                                    class="embed-responsive-item" 
                                    frameborder="0" 
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                    allowfullscreen>
                            </iframe>
                        </div>
                        <div class="mt-3">
                            <a href="{{ training.videoUrl }}" target="_blank" class="btn btn-outline-info">
                                <i class="bi bi-box-arrow-up-right me-2"></i>Open in New Tab
                            </a>
                        </div>
                    </div>
                </div>
                {% endif %}

                <!-- Actions -->
                <div class="d-flex gap-2">
                    <a href="{{ path('app_admin_trainings_edit', {'id': training.id}) }}" class="btn btn-primary">
                        <i class="bi bi-pencil me-2"></i>Edit Training
                    </a>
                    <form method="post" action="{{ path('app_admin_trainings_delete', {'id': training.id}) }}" 
                          onsubmit="return confirm('Are you sure you want to delete this training?');" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete') }}">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-2"></i>Delete Training
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="bi bi-info-circle me-2"></i>Training Statistics
                </h6>
            </div>
            <div class="card-body">
                <div class="text-center mb-4">
                    <div class="mb-3">
                        <h2 class="text-success">{{ training.likes }}</h2>
                        <p class="text-muted mb-0">Likes</p>
                    </div>
                    <div class="mb-3">
                        <h2 class="text-danger">{{ training.dislikes }}</h2>
                        <p class="text-muted mb-0">Dislikes</p>
                    </div>
                    <div class="progress mb-3">
                        {% set total = training.likes + training.dislikes %}
                        {% set likePercentage = total > 0 ? (training.likes / total) * 100 : 0 %}
                        <div class="progress-bar bg-success" style="width: {{ likePercentage }}%"></div>
                    </div>
                    <small class="text-muted">{{ likePercentage|round(1) }}% positive feedback</small>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="bi bi-gear me-2"></i>Quick Actions
                </h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('app_admin_trainings_edit', {'id': training.id}) }}" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-pencil me-2"></i>Edit Training
                    </a>
                    {% if training.videoUrl %}
                    <a href="{{ training.videoUrl }}" target="_blank" class="btn btn-outline-info btn-sm">
                        <i class="bi bi-play-circle me-2"></i>Watch Video
                    </a>
                    {% endif %}
                    <form method="post" action="{{ path('app_admin_trainings_delete', {'id': training.id}) }}" 
                          onsubmit="return confirm('Are you sure you want to delete this training?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete') }}">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                            <i class="bi bi-trash me-2"></i>Delete Training
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="bi bi-lightbulb me-2"></i>Training Tips
                </h6>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <h6><i class="bi bi-info-circle me-2"></i>Best Practices</h6>
                    <ul class="mb-0">
                        <li>Keep content updated regularly</li>
                        <li>Monitor user engagement</li>
                        <li>Respond to feedback</li>
                        <li>Maintain video quality</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.card {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: none;
}

.btn-primary {
    background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
    border: none;
}

.btn-primary:hover {
    background: linear-gradient(135deg, #0056b3 0%, #004085 100%);
}

.ratio {
    position: relative;
    width: 100%;
}

.ratio::before {
    display: block;
    padding-top: 56.25%;
    content: "";
}

.ratio > * {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}
</style>
{% endblock %}
