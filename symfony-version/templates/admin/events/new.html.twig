{% extends 'base.html.twig' %}

{% block title %}New Event - Admin - SmartHire{% endblock %}

{% block page_title %}Create New Event{% endblock %}

{% block page_actions %}
<a href="{{ path('app_admin_events') }}" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-2"></i>Back to Events
</a>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">
                    <i class="bi bi-calendar-plus me-2"></i>Create New Event
                </h4>
            </div>
            <div class="card-body">
                <form method="post" class="needs-validation" novalidate>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="name" class="form-label">Event Name *</label>
                                <input type="text" 
                                       id="name" 
                                       name="name" 
                                       class="form-control" 
                                       placeholder="Enter event name"
                                       value="{{ event.name|default('') }}"
                                       required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="max_participants" class="form-label">Max Participants *</label>
                                <input type="number" 
                                       id="max_participants" 
                                       name="max_participants" 
                                       class="form-control" 
                                       placeholder="Maximum number of participants"
                                       value="{{ event.maxParticipants|default:'' }}"
                                       min="1"
                                       required>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="location" class="form-label">Location *</label>
                        <input type="text" 
                               id="location" 
                               name="location" 
                               class="form-control" 
                               placeholder="Event location (e.g., Conference Room A, Online)"
                               value="{{ event.location|default:'' }}"
                               required>
                    </div>

                    <div class="mb-3">
                        <label for="event_date" class="form-label">Event Date & Time *</label>
                        <input type="datetime-local" 
                               id="event_date" 
                               name="event_date" 
                               class="form-control"
                               value="{{ event.eventDate|default:''|date('Y-m-d\\TH:i') }}"
                               required>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea id="description" 
                                  name="description" 
                                  class="form-control" 
                                  rows="4"
                                  placeholder="Describe the event, agenda, and what participants should expect">{{ event.description|default:'' }}</textarea>
                    </div>

                    <div class="alert alert-info">
                        <h6><i class="bi bi-info-circle me-2"></i>Event Tips:</h6>
                        <ul class="mb-0">
                            <li>Choose a clear, descriptive name for the event</li>
                            <li>Set appropriate participant limits based on venue capacity</li>
                            <li>Provide detailed description to attract the right audience</li>
                            <li>Consider accessibility requirements for the location</li>
                        </ul>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Create Event
                        </button>
                        <a href="{{ path('app_admin_events') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
