{% extends 'admin/layout.html.twig' %}

{% block title %}Add Complaint Type - SmartHire Admin{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Add Complaint Type</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <a href="{{ path('app_admin_complaint_types') }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Types
            </a>
        </div>
    </div>
</div>

{% for flash in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ flash }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% for flash in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ flash }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Create New Complaint Type</h5>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                
                <div class="mb-3">
                    {{ form_label(form.name, 'Type Name', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'e.g. Harassment, Discrimination, Safety Issue'}}) }}
                    {{ form_errors(form.name) }}
                    <div class="form-text">Enter a clear name for the complaint type.</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.urgencyLevel, 'Urgency Level', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.urgencyLevel, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.urgencyLevel) }}
                    <div class="form-text">Select the urgency level for this complaint type.</div>
                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Guidelines:</strong>
                    <ul class="mb-0 mt-2">
                        <li>Use clear, descriptive names</li>
                        <li>Keep names concise but informative</li>
                        <li>Set appropriate urgency levels</li>
                        <li>Examples: "Harassment" (High), "Safety Issue" (Critical), "General Inquiry" (Low)</li>
                    </ul>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_admin_complaint_types') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Create Complaint Type
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Help</h6>
            </div>
            <div class="card-body">
                <h6>What are Complaint Types?</h6>
                <p class="small">
                    Complaint types categorize different kinds of complaints users can submit. 
                    This helps organize and manage complaints effectively.
                </p>

                <hr>

                <h6>Best Practices</h6>
                <ul class="small">
                    <li>Use simple, clear language</li>
                    <li>Avoid technical jargon</li>
                    <li>Be specific but concise</li>
                    <li>Consider all possible complaint scenarios</li>
                </ul>

                <hr>

                <h6>Examples</h6>
                <ul class="small mb-0">
                    <li>Harassment</li>
                    <li>Discrimination</li>
                    <li>Safety Issue</li>
                    <li>Policy Violation</li>
                    <li>Workplace Conflict</li>
                </ul>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h6 class="mb-0">Important</h6>
            </div>
            <div class="card-body">
                <p class="small mb-0">
                    Once created, complaint types can be used by users when submitting complaints. 
                    Make sure the types cover all common scenarios in your organization.
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
