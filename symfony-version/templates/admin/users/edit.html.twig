{% extends 'admin/layout.html.twig' %}

{% block admin_page_title %}Edit User{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Edit User</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <a href="{{ path('app_admin_users') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Edit User</h5>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                
                <div class="mb-3">
                    {{ form_label(form.fullName, 'Full Name', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.fullName, {'attr': {'class': 'form-control', 'placeholder': 'Enter full name', 'value': user.fullName}}) }}
                    {{ form_errors(form.fullName) }}
                    <div class="form-text">Enter the user's full name</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.email, 'Email Address', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'Enter email address', 'value': user.email}}) }}
                    {{ form_errors(form.email) }}
                    <div class="form-text">Enter the user's email address</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.phoneNumber, 'Phone Number', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.phoneNumber, {'attr': {'class': 'form-control', 'placeholder': 'Enter phone number', 'value': user.phoneNumber}}) }}
                    {{ form_errors(form.phoneNumber) }}
                    <div class="form-text">Enter the user's phone number</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.roleId, 'Role', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.roleId, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.roleId) }}
                    <div class="form-text">Select the user's role</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.password.first, 'Password', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.password.first, {'attr': {'class': 'form-control', 'placeholder': 'Enter new password (leave blank to keep current)'}}) }}
                    {{ form_errors(form.password.first) }}
                    <div class="form-text">Enter new password or leave blank to keep current</div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <button type="submit" class="btn btn-gradient">
                            <i class="bi bi-save me-2"></i>Save Changes
                        </button>
                        <a href="{{ path('app_admin_users') }}" class="btn btn-secondary">
                            <i class="bi bi-x-circle me-2"></i>Cancel
                        </a>
                    </div>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">User Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    {% if user.isBanned %}
                        <form method="post" action="{{ path('app_admin_users_unban', {'id': user.id}) }}" onsubmit="return confirm('Are you sure you want to unban this user?');" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('unban' ~ user.id) }}">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-shield-check me-2"></i>Unban User
                            </button>
                        </form>
                    {% else %}
                        <form method="post" action="{{ path('app_admin_users_ban', {'id': user.id}) }}" onsubmit="return confirm('Are you sure you want to ban this user?');" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('ban' ~ user.id) }}">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-shield-x me-2"></i>Ban User
                            </button>
                        </form>
                    {% endif %}
                </div>

                <div class="d-grid gap-2">
                    {% if user.isVerified %}
                        <form method="post" action="{{ path('app_admin_users_unverify', {'id': user.id}) }}" onsubmit="return confirm('Are you sure you want to unverify this user?');" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('unverify' ~ user.id) }}">
                            <button type="submit" class="btn btn-outline-warning">
                                <i class="bi bi-x-circle me-2"></i>Unverify User
                            </button>
                        </form>
                    {% else %}
                        <form method="post" action="{{ path('app_admin_users_verify', {'id': user.id}) }}" onsubmit="return confirm('Are you sure you want to verify this user?');" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('verify' ~ user.id) }}">
                            <button type="submit" class="btn btn-outline-success">
                                <i class="bi bi-check-circle me-2"></i>Verify User
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
