{% extends 'base.html.twig' %}

{% block title %}Reset Password - SmartHire{% endblock %}

{% block page_title %}Set New Password{% endblock %}

{% block page_actions %}
<a href="{{ path('app_login') }}" class="btn btn-outline-secondary">
    <i class="bi bi-box-arrow-in-left me-2"></i>Back to Login
</a>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">
                    <i class="bi bi-shield-lock me-2"></i>Set New Password
                </h4>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                
                <div class="mb-3">
                    <p class="text-muted">Enter your new password below.</p>
                </div>

                <div class="mb-3">
                    {{ form_label(form.password.first, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.password.first, {'attr': {'class': 'form-control', 'placeholder': 'Enter new password'}}) }}
                    {{ form_errors(form.password.first) }}
                    <div class="form-text">Min 8 characters, must contain uppercase, lowercase, and number</div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.password.second, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.password.second, {'attr': {'class': 'form-control', 'placeholder': 'Confirm new password'}}) }}
                    {{ form_errors(form.password.second) }}
                    <div class="form-text">Please re-enter your new password</div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-shield-check me-2"></i>Reset Password
                    </button>
                    <a href="{{ path('app_login') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-box-arrow-in-left me-2"></i>Back to Login
                    </a>
                </div>

                {{ form_end(form) }}

                <div class="text-center mt-3">
                    <small class="text-muted">
                        Remember your password? 
                        <a href="{{ path('app_login') }}">Try to login</a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
