    </div>
    
    <!-- Right Side - Registration Form -->
    <div class="col-lg-6">
        <div class="h-100 d-flex align-items-center justify-content-center p-4">
            <div class="w-100" style="max-width: 500px;">
                <div class="text-center mb-4">
