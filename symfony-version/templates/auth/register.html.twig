                        <div class="role-icon mx-auto" id="selectedRoleIcon" style="background: #6c757d;">
                            <i class="bi bi-person-plus"></i>
                        </div>
                    </div>
                    <h2 class="fw-bold">Create Your Account</h2>
                    <p class="text-muted" id="roleText">Join SmartHire today</p>
