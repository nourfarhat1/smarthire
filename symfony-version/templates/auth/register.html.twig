{% extends 'base.html.twig' %}

{% block title %}Register - SmartHire{% endblock %}

{% block stylesheets %}
<style>
/* Role-specific color schemes */
.role-hr {
    --role-primary: #e91e63;
    --role-gradient: linear-gradient(135deg, #e91e63 0%, #c2185b 100%);
    --role-light: #fce4ec;
}

.role-candidate {
    --role-primary: #87a042;
    --role-gradient: linear-gradient(135deg, #87a042 0%, #6b8a35 100%);
    --role-light: #f1f8e9;
}

.role-admin {
    --role-primary: #2196f3;
    --role-gradient: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
    --role-light: #e3f2fd;
}

.role-default {
    --role-primary: #6c757d;
    --role-gradient: linear-gradient(135deg, #6c757d 0%, #495057 100%);
    --role-light: #f8f9fa;
}

.register-bg {
    background: var(--role-gradient);
    position: relative;
    overflow: hidden;
}

.register-bg::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
    background-size: 20px 20px;
    animation: float 20s linear infinite;
}

@keyframes float {
    0% { transform: translate(0, 0) rotate(0deg); }
    100% { transform: translate(50px, 50px) rotate(360deg); }
}

.role-card {
    transition: all 0.3s ease;
    cursor: pointer;
    border: 2px solid transparent;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
}

.role-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    background: rgba(255,255,255,0.15);
}

.role-card.active {
    border-color: var(--role-primary);
    background: rgba(255,255,255,0.2);
}

.role-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: white;
    margin-bottom: 1rem;
    transition: all 0.3s ease;
}

.role-card:hover .role-icon {
    transform: scale(1.1);
}

.form-control:focus {
    border-color: var(--role-primary);
    box-shadow: 0 0 0 0.2rem rgba(135, 160, 66, 0.25);
}

.btn-role {
    background: var(--role-gradient);
    border: none;
    color: white;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-role:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

.password-strength {
    height: 4px;
    border-radius: 2px;
    margin-top: 5px;
    transition: all 0.3s ease;
}

.strength-weak { background: #dc3545; width: 33%; }
.strength-medium { background: #ffc107; width: 66%; }
.strength-strong { background: #28a745; width: 100%; }

.feature-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(10px);
    margin-bottom: 1rem;
    transition: all 0.3s ease;
}

.feature-card:hover .feature-icon {
    transform: scale(1.1) rotate(5deg);
    background: rgba(255,255,255,0.3);
}

.progress-steps {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
}

.step {
    display: flex;
    align-items: center;
    color: rgba(255,255,255,0.6);
    font-size: 0.875rem;
}

.step.active {
    color: white;
}

.step-number {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 8px;
    font-weight: bold;
    transition: all 0.3s ease;
}

.step.active .step-number {
    background: var(--role-primary);
    transform: scale(1.1);
}

.step-line {
    width: 50px;
    height: 2px;
    background: rgba(255,255,255,0.2);
    margin: 0 10px;
}

.loading {
    position: relative;
    pointer-events: none;
    opacity: 0.7;
}

.loading::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 20px;
    margin: -10px 0 0 -10px;
    border: 2px solid transparent;
    border-top: 2px solid white;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

[data-tooltip] {
    position: relative;
    cursor: help;
}

[data-tooltip]:hover::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.8);
    color: white;
    padding: 5px 10px;
    border-radius: 4px;
    font-size: 0.75rem;
    white-space: nowrap;
    z-index: 1000;
    margin-bottom: 5px;
}

.requirements {
    font-size: 0.75rem;
    margin-top: 5px;
}

.requirement {
    color: #6c757d;
    transition: color 0.3s ease;
}

.requirement.met {
    color: #28a745;
}

.requirement-icon {
    margin-right: 5px;
}

/* Face Login Section */
.face-login-section {
    border: 2px dashed #dee2e6;
    border-radius: 12px;
    padding: 1.25rem;
    transition: border-color 0.3s ease;
}

.face-login-section.enrolled {
    border-color: #28a745;
    background-color: #f0fff4;
}

.face-login-section.enrolled .face-status {
    color: #28a745;
    font-weight: 600;
}
</style>
{% endblock %}

{% block body %}
