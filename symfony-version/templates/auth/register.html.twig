{% block javascripts %}
{{ parent() }}

<script src="https://cdn.faceio.net/fio.js"></script>

<script>
let currentRole = 'default';
let faceio = null;

const roleInfo = {
    'candidate': {
        title: 'Candidate Account',
        description: 'As a candidate, you can:<ul class="mb-0"><li>Browse and apply for jobs</li><li>Take AI-powered assessments</li><li>Track application status</li><li>Manage your professional profile</li></ul>',
        color: '#87a042'
    },
    'hr': {
        title: 'HR Manager Account',
        description: 'As an HR manager, you can:<ul class="mb-0"><li>Post job opportunities</li><li>Review candidate applications</li><li>Schedule interviews</li><li>Manage recruitment process</li></ul>',
        color: '#e91e63'
    },
    'admin': {
        title: 'Administrator Account',
        description: 'As an administrator, you can:<ul class="mb-0"><li>Manage system settings</li><li>Oversee all users</li><li>Monitor platform performance</li><li>Handle administrative tasks</li></ul>',
        color: '#2196f3'
    }
};

document.addEventListener('DOMContentLoaded', function () {

    // Initialize Faceio
    faceio = new faceIO('{{ faceio_app_id }}');

    selectRole('candidate');
    document.getElementById('{{ form.firstName.vars.id }}').focus();

    // Enroll face button
    document.getElementById('enrollFaceBtn').addEventListener('click', enrollFace);
    document.getElementById('reEnrollFaceBtn').addEventListener('click', enrollFace);

    // Password strength
    document.getElementById('{{ form.password.vars.id }}').addEventListener('input', function () {
        checkPasswordStrength(this.value);
    });

    // Email validation
    document.getElementById('{{ form.email.vars.id }}').addEventListener('blur', function () {
        const emailHelp = document.getElementById('emailHelp');
        if (this.value && !this.value.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
            emailHelp.textContent = 'Please enter a valid email address';
            emailHelp.className = 'form-text text-danger';
        } else {
            emailHelp.textContent = "We'll never share your email with anyone else.";
            emailHelp.className = 'form-text';
        }
    });

    // Role dropdown change
    document.getElementById('{{ form.roleId.vars.id }}').addEventListener('change', function () {
        const roleMap = { '2': 'candidate', '3': 'hr', '4': 'admin' };
        const role = roleMap[this.value] || 'default';
        const roleCard = document.querySelector(`[onclick="selectRole('${role}')"]`);
        if (roleCard) roleCard.click();
    });

    // Form submit
    document.getElementById('registerForm').addEventListener('submit', function (e) {
        if (!document.getElementById('terms').checked) {
            e.preventDefault();
            alert('Please accept the Terms of Service and Privacy Policy to continue.');
            return;
        }
        const btn = document.getElementById('registerBtn');
        btn.classList.add('loading');
        document.getElementById('btnText').textContent = 'Creating Account...';
        updateProgress(2);
    });

    // Keyboard shortcut
    document.addEventListener('keydown', function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
            document.getElementById('registerForm').submit();
        }
    });
});

async function enrollFace() {
    const statusDiv = document.getElementById('faceEnrollStatus');
    const enrollBtn = document.getElementById('enrollFaceBtn');

    enrollBtn.disabled = true;
    enrollBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Scanning...';
    statusDiv.innerHTML = '';

    try {
        const response = await faceio.enroll({
            locale: 'auto',
            payload: {
                email: document.getElementById('{{ form.email.vars.id }}').value || 'pending'
            }
        });

        // Store the facialId in the hidden input
        document.getElementById('faceioIdInput').value = response.facialId;

        // Show success state
        document.getElementById('faceNotEnrolled').classList.add('d-none');
        document.getElementById('faceEnrolled').classList.remove('d-none');
        document.getElementById('faceLoginSection').classList.add('enrolled');

        statusDiv.innerHTML = `
            <div class="alert alert-success py-2 mb-0 mt-2">
                <small><i class="bi bi-check-circle me-1"></i>Face scanned and ready. It will be saved when you create your account.</small>
            </div>`;

    } catch (err) {
        console.error('Faceio enrollment error:', err);
        statusDiv.innerHTML = `
            <div class="alert alert-warning py-2 mb-0 mt-2">
                <small><i class="bi bi-exclamation-triangle me-1"></i>Face scan failed or was skipped. You can enable face login later from your profile.</small>
            </div>`;
        enrollBtn.disabled = false;
        enrollBtn.innerHTML = '<i class="bi bi-camera me-2"></i>Scan My Face Now';
    }
}

function selectRole(role) {
    currentRole = role;
    const bg = document.getElementById('registerBg');
    const icon = document.getElementById('selectedRoleIcon');
    const text = document.getElementById('roleText');
    const roleSelect = document.getElementById('{{ form.roleId.vars.id }}');
    const roleHelp = document.getElementById('roleHelp');
    const roleDesc = document.getElementById('roleDescription');

    bg.classList.remove('role-hr', 'role-candidate', 'role-admin', 'role-default');
    bg.classList.add(`role-${role}`);

    const icons = { 'candidate': 'bi-person-briefcase', 'hr': 'bi-people', 'admin': 'bi-gear', 'default': 'bi-person-plus' };
    const colors = { 'candidate': '#87a042', 'hr': '#e91e63', 'admin': '#2196f3', 'default': '#6c757d' };
    const texts = { 'candidate': 'Start your job search journey', 'hr': 'Begin managing recruitment', 'admin': 'Access system administration', 'default': 'Join SmartHire today' };

    icon.style.background = colors[role];
    icon.innerHTML = `<i class="bi ${icons[role]}"></i>`;
    text.textContent = texts[role];

    if (roleInfo[role]) {
        roleDesc.innerHTML = `<h6>${roleInfo[role].title}</h6>${roleInfo[role].description}`;
        roleHelp.textContent = `Selected: ${roleInfo[role].title}`;
    }

    document.querySelectorAll('.role-card').forEach(card => card.classList.remove('active'));
    const activeCard = document.querySelector(`[onclick="selectRole('${role}')"]`);
    if (activeCard) activeCard.classList.add('active');

    if (roleSelect) {
        const roleMap = { 'candidate': '2', 'hr': '3', 'admin': '4' };
        if (roleMap[role]) roleSelect.value = roleMap[role];
    }

    updateProgress(1);
}

function togglePassword() {
    const input = document.getElementById('{{ form.password.vars.id }}');
    const icon = document.getElementById('passwordToggle');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
    }
}

function checkPasswordStrength(password) {
    const strengthBar = document.getElementById('passwordStrength');
    let strength = 0;

    const checks = [
        { id: 'req-length', test: password.length >= 8 },
        { id: 'req-uppercase', test: /[A-Z]/.test(password) },
        { id: 'req-lowercase', test: /[a-z]/.test(password) },
        { id: 'req-number', test: /[0-9]/.test(password) },
    ];

    checks.forEach(({ id, test }) => {
        const el = document.getElementById(id);
        const icon = el.querySelector('.requirement-icon');
        if (test) {
            strength++;
            el.classList.add('met');
            icon.className = 'bi bi-check-circle requirement-icon';
        } else {
            el.classList.remove('met');
            icon.className = 'bi bi-circle requirement-icon';
        }
    });

    strengthBar.className = 'password-strength';
    if (strength <= 1) strengthBar.classList.add('strength-weak');
    else if (strength === 2) strengthBar.classList.add('strength-medium');
    else strengthBar.classList.add('strength-strong');
}

function updateProgress(step) {
    document.querySelectorAll('.step').forEach((stepEl, index) => {
        if (index < step) stepEl.classList.add('active');
        else stepEl.classList.remove('active');
    });
}

function showTerms() {
    alert('Terms of Service: This is a placeholder.');
}

function showPrivacy() {
    alert('Privacy Policy: This is a placeholder.');
}
</script>
{% endblock %}
