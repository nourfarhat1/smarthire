{% extends 'candidate/layout.html.twig' %}

{% block title %}Edit Profile - SmartHire{% endblock %}

{% block candidate_page_title %}Edit Profile{% endblock %}

{% block stylesheets %}
<style>
.edit-profile-container {
    max-width: 900px;
    margin: 0 auto;
}

.edit-profile-card {
    border: none;
    border-radius: 12px;
    overflow: hidden;
}

.edit-profile-card .card-header {
    background: linear-gradient(135deg, #87a042 0%, #6b8a35 100%);
    border: none;
    padding: 1.25rem;
}

.edit-profile-card .card-body {
    padding: 2rem;
}

.form-label {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
}

.form-control {
    border-radius: 8px;
    border: 1px solid #dee2e6;
    padding: 0.75rem;
    transition: all 0.3s ease;
}

.form-control:focus {
    border-color: #87a042;
    box-shadow: 0 0 0 0.2rem rgba(135, 160, 66, 0.25);
}

.face-recognition-section {
    border: 2px solid #e9ecef;
    border-radius: 12px;
    overflow: hidden;
}

.face-recognition-section .card-header {
    background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
}

@media (max-width: 768px) {
    .edit-profile-card .card-body {
        padding: 1.5rem;
    }
    
    .col-lg-7 {
        padding: 0 15px;
    }
}
</style>
{% endblock %}

{% block page_actions %}
<a href="{{ path('app_profile') }}" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-2"></i>Back to Profile
</a>
{% endblock %}

{% block candidate_content %}
<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">
        <div class="card shadow-sm edit-profile-card">
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="bi bi-person-gear me-2"></i>Edit Profile Information
                </h4>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            {{ form_label(form.firstName, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.firstName, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.firstName) }}
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            {{ form_label(form.lastName, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.lastName, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.lastName) }}
                        </div>
                    </div>
                </div>
                
                <div class="mb-3">
                    {{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.email) }}
                </div>
                
                <div class="mb-3">
                    {{ form_label(form.phoneNumber, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.phoneNumber, {'attr': {'class': 'form-control', 'placeholder': '8 digits only'}}) }}
                    {{ form_errors(form.phoneNumber) }}
                    <div class="form-text">Enter your 8-digit phone number (e.g., 12345678)</div>
                </div>
                
                <div class="mb-3">
                    {{ form_label(form.profilePicture, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.profilePicture, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.profilePicture) }}
                    <div class="form-text">Upload a profile picture (JPEG, PNG, or GIF, max 2MB)</div>
                </div>
                
                <div class="mb-3">
                    {{ form_label(form.plainPassword, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Leave blank to keep current password'}}) }}
                    {{ form_errors(form.plainPassword) }}
                    <div class="form-text">Enter a new password if you want to change it (min 8 characters, must contain uppercase, lowercase, and number)</div>
                </div>
                
                <!-- Face Recognition Section -->
                <div class="card face-recognition-section mb-4">
                    <div class="card-header text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-camera-video me-2"></i>Face Recognition Settings
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="faceLoginToggle" 
                                           {% if app.user.faceLoginEnabled %}checked{% endif %}>
                                    <label class="form-check-label" for="faceLoginToggle">
                                        <strong>Enable Face Recognition Login</strong>
                                    </label>
                                </div>
                                <p class="text-muted small mb-0 mt-2">
                                    Use your face to quickly and securely log in to your account.
                                </p>
                            </div>
                            <div class="col-md-4 text-end">
                                <span id="faceStatus" class="badge 
                                    {% if app.user.faceLoginEnabled %}bg-success{% else %}bg-secondary{% endif %}">
                                    {% if app.user.faceLoginEnabled %}Enabled{% else %}Disabled{% endif %}
                                </span>
                            </div>
                        </div>
                        
                        {% if app.user.faceLoginEnabled %}
                        <div class="mt-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="text-muted">
                                        <i class="bi bi-info-circle me-1"></i>
                                        {% if app.user.faceTokens|length > 0 %}
                                            You have {{ app.user.faceTokens|length }} face(s) enrolled
                                        {% else %}
                                            No faces enrolled yet
                                        {% endif %}
                                    </small>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-primary" id="addFaceBtn">
                                        <i class="bi bi-plus-circle me-1"></i>Add Face
                                    </button>
                                    {% if app.user.faceTokens|length > 0 %}
                                    <button type="button" class="btn btn-sm btn-outline-danger" id="removeFacesBtn">
                                        <i class="bi bi-trash me-1"></i>Remove All
                                    </button>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>
                
                <!-- Face Enrollment Modal -->
                <div class="modal fade" id="faceEnrollModal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">
                                    <i class="bi bi-camera-video me-2"></i>Enroll Your Face
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body text-center">
                                <div id="faceEnrollStatus"></div>
                                <div id="cameraContainer" class="d-none">
                                    <video id="faceEnrollVideo" width="100%" height="240" autoplay style="border-radius: 8px;"></video>
                                    <canvas id="faceEnrollCanvas" class="d-none"></canvas>
                                    <div class="mt-3">
                                        <button type="button" class="btn btn-success" id="captureEnrollBtn">
                                            <i class="bi bi-camera-fill me-1"></i>Capture Face
                                        </button>
                                        <button type="button" class="btn btn-secondary ms-2" id="cancelEnrollBtn">
                                            <i class="bi bi-x-circle me-1"></i>Cancel
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-2"></i>Save Changes
                    </button>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const faceLoginToggle = document.getElementById('faceLoginToggle');
    const addFaceBtn = document.getElementById('addFaceBtn');
    const removeFacesBtn = document.getElementById('removeFacesBtn');
    
    // Toggle face login
    if (faceLoginToggle) {
        faceLoginToggle.addEventListener('change', function() {
            if (this.checked) {
                showFaceEnrollModal();
            } else {
                if (confirm('Are you sure you want to disable face login? You will need to re-enroll your face to use this feature.')) {
                    disableFaceLogin();
                } else {
                    this.checked = true; // Revert if cancelled
                }
            }
        });
    }
    
    // Add face button
    if (addFaceBtn) {
        addFaceBtn.addEventListener('click', function() {
            showFaceEnrollModal();
        });
    }
    
    // Remove faces button
    if (removeFacesBtn) {
        removeFacesBtn.addEventListener('click', function() {
            if (confirm('Are you sure you want to remove all enrolled faces? You will need to re-enroll your face to use face recognition login.')) {
                removeAllFaces();
            }
        });
    }
});

function updateFaceLoginStatus(isEnabled) {
    fetch('{{ path('app_face_login_disable') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            const faceStatus = document.getElementById('faceStatus');
            if (isEnabled) {
                faceStatus.textContent = 'Enabled';
                faceStatus.className = 'badge bg-success';
                location.reload(); // Reload to show face management options
            } else {
                faceStatus.textContent = 'Disabled';
                faceStatus.className = 'badge bg-secondary';
                // Hide face management options
                const faceSection = document.querySelector('.card.border-primary .mt-3');
                if (faceSection) faceSection.style.display = 'none';
            }
        }
    })
    .catch(error => {
        console.error('Error updating face login status:', error);
        // Revert toggle on error
        document.getElementById('faceLoginToggle').checked = !isEnabled;
    });
}

function showFaceEnrollModal() {
    const modal = new bootstrap.Modal(document.getElementById('faceEnrollModal'));
    modal.show();
    
    // Start camera automatically
    setTimeout(startEnrollCamera, 500);
}

function startEnrollCamera() {
    const statusDiv = document.getElementById('faceEnrollStatus');
    const cameraDiv = document.getElementById('cameraContainer');
    const videoElement = document.getElementById('faceEnrollVideo');
    
    statusDiv.innerHTML = '<div class="alert alert-info">Starting camera...</div>';
    
    navigator.mediaDevices.getUserMedia({ 
        video: { 
            width: { ideal: 640 },
            height: { ideal: 480 },
            facingMode: 'user'
        } 
    })
    .then(stream => {
        enrollStream = stream;
        videoElement.srcObject = stream;
        cameraDiv.classList.remove('d-none');
        statusDiv.innerHTML = '<div class="alert alert-info">Position your face in the camera and click "Capture Face"</div>';
    })
    .catch(err => {
        console.error('Camera access error:', err);
        statusDiv.innerHTML = '<div class="alert alert-danger">Camera access denied. Please allow camera access.</div>';
    });
}

function stopEnrollCamera() {
    if (enrollStream) {
        enrollStream.getTracks().forEach(track => track.stop());
        enrollStream = null;
    }
    
    const videoElement = document.getElementById('faceEnrollVideo');
    const cameraDiv = document.getElementById('cameraContainer');
    const statusDiv = document.getElementById('faceEnrollStatus');
    
    videoElement.srcObject = null;
    cameraDiv.classList.add('d-none');
    statusDiv.innerHTML = '';
}

function captureEnrollFace() {
    const videoElement = document.getElementById('faceEnrollVideo');
    const canvas = document.getElementById('faceEnrollCanvas');
    const statusDiv = document.getElementById('faceEnrollStatus');
    
    canvas.width = videoElement.videoWidth;
    canvas.height = videoElement.videoHeight;
    
    const context = canvas.getContext('2d');
    context.drawImage(videoElement, 0, 0, canvas.width, canvas.height);
    
    const imageData = canvas.toDataURL('image/jpeg', 0.8);
    
    statusDiv.innerHTML = '<div class="alert alert-info"><span class="spinner-border spinner-border-sm me-2"></span>Processing face...</div>';
    
    // First detect the face
    fetch('{{ path('app_face_login_detect') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: new URLSearchParams({ image: imageData })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Now enroll the face
            return fetch('{{ path('app_face_login_enroll_process') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: new URLSearchParams({ face_token: data.face_token })
            });
        } else {
            throw new Error(data.error);
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            statusDiv.innerHTML = '<div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>Face enrolled successfully!</div>';
            stopEnrollCamera();
            
            // Close modal after success
            setTimeout(() => {
                bootstrap.Modal.getInstance(document.getElementById('faceEnrollModal')).hide();
                location.reload(); // Reload to show updated face count
            }, 2000);
        } else {
            throw new Error(data.error);
        }
    })
    .catch(err => {
        console.error('Face enrollment error:', err);
        statusDiv.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>' + err.message + '</div>';
    });
}

function removeAllFaces() {
    fetch('{{ path('app_face_login_disable') }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload(); // Reload to show updated status
        }
    })
    .catch(error => {
        console.error('Error removing faces:', error);
    });
}

// Face enrollment modal buttons
document.getElementById('captureEnrollBtn')?.addEventListener('click', captureEnrollFace);
document.getElementById('cancelEnrollBtn')?.addEventListener('click', stopEnrollCamera);
</script>
{% endblock %}
