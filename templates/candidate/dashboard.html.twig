{% extends 'candidate/layout.html.twig' %}

{% block title %}Candidate Dashboard - SmartHire{% endblock %}

{% block page_title %}Candidate Dashboard{% endblock %}

{% block candidate_page_title %}Candidate Dashboard{% endblock %}

{% block candidate_content %}
<!-- Candidate Dashboard Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stats-card candidate-dashboard text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ stats.total_applications ?? 0 }}</h4>
                        <p class="card-text">Total Applications</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-file-text fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-dashboard text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ stats.pending_applications ?? 0 }}</h4>
                        <p class="card-text">Pending</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-clock-history fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-dashboard text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ stats.success_rate ?? 0 }}%</h4>
                        <p class="card-text">Success Rate</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-graph-up fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-dashboard text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ stats.profile_completion ?? 0 }}%</h4>
                        <p class="card-text">Profile Complete</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-person-check fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header candidate-primary text-white">
                <h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <a href="{{ path('app_jobs') }}" class="btn btn-outline-success w-100 h-100 d-flex flex-column justify-content-center align-items-center" style="min-height: 100px;">
                            <i class="bi bi-search fs-1 mb-2"></i>
                            <span>Browse Jobs</span>
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="{{ path('app_applications') }}" class="btn btn-outline-primary w-100 h-100 d-flex flex-column justify-content-center align-items-center" style="min-height: 100px;">
                            <i class="bi bi-file-text fs-1 mb-2"></i>
                            <span>My Applications</span>
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="{{ path('app_candidate_quizzes') }}" class="btn btn-outline-warning w-100 h-100 d-flex flex-column justify-content-center align-items-center" style="min-height: 100px;">
                            <i class="bi bi-question-circle fs-1 mb-2"></i>
                            <span>Take Quiz</span>
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="{{ path('app_profile') }}" class="btn btn-outline-info w-100 h-100 d-flex flex-column justify-content-center align-items-center" style="min-height: 100px;">
                            <i class="bi bi-person fs-1 mb-2"></i>
                            <span>Edit Profile</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Application Status Tracking -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header candidate-info text-white">
                <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Application Status Tracking</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Accepted</span>
                        <span class="badge bg-success">{{ stats.accepted_applications ?? 0 }}</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-success" style="width: {{ stats.total_applications > 0 ? (stats.accepted_applications / stats.total_applications) * 100 : 0 }}%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Pending</span>
                        <span class="badge bg-warning">{{ stats.pending_applications ?? 0 }}</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-warning" style="width: {{ stats.total_applications > 0 ? (stats.pending_applications / stats.total_applications) * 100 : 0 }}%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Rejected</span>
                        <span class="badge bg-danger">{{ stats.rejected_applications ?? 0 }}</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-danger" style="width: {{ stats.total_applications > 0 ? (stats.rejected_applications / stats.total_applications) * 100 : 0 }}%"></div>
                    </div>
                </div>
                <div class="text-center mt-3">
                    <small class="text-muted">{{ stats.applications_this_month ?? 0 }} applications this month</small>
                    <br>
                    <small class="text-success"><strong>{{ stats.success_rate ?? 0 }}%</strong> success rate</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header candidate-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-trophy me-2"></i>Job Search Progress</h5>
            </div>
            <div class="card-body">
                <div class="row text-center mb-3">
                    <div class="col-4">
                        <div class="progress-circle" data-progress="{{ stats.profile_completion ?? 0 }}">
                            <svg width="60" height="60">
                                <circle cx="30" cy="30" r="25" stroke="#e9ecef" stroke-width="5" fill="none"></circle>
                                <circle cx="30" cy="30" r="25" stroke="#87a042" stroke-width="5" fill="none"
                                        stroke-dasharray="{{ (stats.profile_completion ?? 0) * 1.57 }} 157"
                                        transform="rotate(-90 30 30)"></circle>
                            </svg>
                            <div class="progress-text">{{ stats.profile_completion ?? 0 }}%</div>
                        </div>
                        <small class="text-muted d-block">Profile Complete</small>
                    </div>
                    <div class="col-4">
                        <div class="progress-circle" data-progress="{{ stats.success_rate ?? 0 }}">
                            <svg width="60" height="60">
                                <circle cx="30" cy="30" r="25" stroke="#e9ecef" stroke-width="5" fill="none"></circle>
                                <circle cx="30" cy="30" r="25" stroke="#28a745" stroke-width="5" fill="none"
                                        stroke-dasharray="{{ (stats.success_rate ?? 0) * 1.57 }} 157"
                                        transform="rotate(-90 30 30)"></circle>
                            </svg>
                            <div class="progress-text">{{ stats.success_rate ?? 0 }}%</div>
                        </div>
                        <small class="text-muted d-block">Success Rate</small>
                    </div>
                    <div class="col-4">
                        <div class="progress-circle" data-progress="{{ min((stats.applications_this_month ?? 0) * 10, 100) }}">
                            <svg width="60" height="60">
                                <circle cx="30" cy="30" r="25" stroke="#e9ecef" stroke-width="5" fill="none"></circle>
                                <circle cx="30" cy="30" r="25" stroke="#ffc107" stroke-width="5" fill="none"
                                        stroke-dasharray="{{ min((stats.applications_this_month ?? 0) * 10, 100) * 1.57 }} 157"
                                        transform="rotate(-90 30 30)"></circle>
                            </svg>
                            <div class="progress-text">{{ stats.applications_this_month ?? 0 }}</div>
                        </div>
                        <small class="text-muted d-block">This Month</small>
                    </div>
                </div>
                
                <div class="mt-3">
                    <h6>Activity Level</h6>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar bg-{{ (stats.applications_this_month ?? 0) > 5 ? 'success' : (stats.applications_this_month ?? 0) > 2 ? 'warning' : 'secondary' }}" 
                             style="width: {{ min((stats.applications_this_month ?? 0) * 20, 100) }}%"></div>
                    </div>
                    <small class="text-muted">
                        {% if (stats.applications_this_month ?? 0) > 5 %}
                            Highly Active - Keep up the great work!
                        {% elseif (stats.applications_this_month ?? 0) > 2 %}
                            Moderately Active - Consider applying to more jobs
                        {% else %}
                            Low Activity - Increase your job applications
                        {% endif %}
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity & Personalized Recommendations -->
<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header candidate-success text-white">
                <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Applications</h5>
            </div>
            <div class="card-body">
                {% if recent_applications|length > 0 %}
                    <div class="list-group list-group-flush">
                        {% for application in recent_applications %}
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">{{ application.jobOffer ? application.jobOffer.title : 'Unknown Job' }}</h6>
                                    <small class="text-muted">
                                        {% if application.jobOffer and application.jobOffer.recruiter %}
                                            {{ application.jobOffer.recruiter.firstName }} {{ application.jobOffer.recruiter.lastName }}
                                        {% else %}
                                            Unknown Recruiter
                                        {% endif %}
                                    </small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-{{ application.status == 'Accepted' ? 'success' : application.status == 'Rejected' ? 'danger' : 'warning' }}">{{ application.status }}</span>
                                    <small class="text-muted d-block">{{ application.submissionDate|date('M d, Y') }}</small>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-muted">No recent applications</p>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header candidate-primary text-white">
                <h5 class="mb-0"><i class="bi bi-stars me-2"></i>Recommended Jobs</h5>
            </div>
            <div class="card-body">
                {% if recommended_jobs|length > 0 %}
                    <div class="list-group list-group-flush">
                        {% for job in recommended_jobs %}
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">{{ job ? job.title : 'Unknown Job' }}</h6>
                                    <small class="text-muted">
                                        {% if job and job.recruiter %}
                                            {{ job.recruiter.firstName }} {{ job.recruiter.lastName }} • {{ job.location }}
                                        {% else %}
                                            Unknown Location
                                        {% endif %}
                                    </small>
                                </div>
                                <div>
                                    {% if job %}
                                        <a href="{{ path('app_jobs_show', {'id': job.id}) }}" class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center">
                        <i class="bi bi-search fs-1 text-muted mb-3"></i>
                        <h6>No Recommendations Yet</h6>
                        <p class="text-muted">Complete your profile to get personalized job recommendations</p>
                        <a href="{{ path('app_profile') }}" class="btn btn-success">
                            <i class="bi bi-person me-2"></i>Complete Profile
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<style>
.candidate-dashboard {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
    box-shadow: 0 4px 15px rgba(135, 160, 66, 0.3);
}

.candidate-primary {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
}

.candidate-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.candidate-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}

.candidate-success {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
}

.progress-circle {
    position: relative;
    display: inline-block;
}

.progress-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 12px;
    font-weight: bold;
}

.card {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: none;
}

.btn-outline-success {
    border-color: #87a042;
    color: #87a042;
}

.btn-outline-success:hover {
    background-color: #87a042;
    border-color: #87a042;
}

.btn-outline-primary {
    border-color: #17a2b8;
    color: #17a2b8;
}

.btn-outline-primary:hover {
    background-color: #17a2b8;
    border-color: #17a2b8;
}
</style>
{% endblock %}
