{% extends 'candidate/layout.html.twig' %}

{% block title %}Quizzes - SmartHire{% endblock %}

{% block page_title %}Available Quizzes{% endblock %}

{% block candidate_content %}
<div class="container-fluid">
    <div class="row">
        <!-- Main Content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">{% block candidate_page_title %}Available Quizzes{% endblock %}</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    {% block candidate_actions %}{% endblock %}
                </div>
            </div>

            <!-- Flash Messages -->
            {% for flash_message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{ flash_message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}

            {% for flash_message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{ flash_message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}

            <!-- Available Quizzes -->
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="bi bi-list-ul me-2"></i>
                                Available Quizzes
                            </h5>
                        </div>
                        <div class="card-body">
                            {% if available_quizzes is empty %}
                                <div class="text-center py-5">
                                    <i class="bi bi-inbox display-4 text-muted"></i>
                                    <h5 class="text-muted">No quizzes available</h5>
                                    <p class="text-muted">There are no quizzes available at the moment. Please check back later.</p>
                                </div>
                            {% else %}
                                <div class="row">
                                    {% for quiz in available_quizzes %}
                                        <div class="col-md-6 col-lg-4 mb-4">
                                            <div class="card h-100">
                                                <div class="card-body">
                                                    <h6 class="card-title">
                                                        {{ quiz.title }}
                                                    </h6>
                                                    <p class="card-text">
                                                        <small class="text-muted">{{ quiz.description|default('No description available') }}</small>
                                                    </p>
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <span class="badge bg-info">
                                                                <i class="bi bi-clock me-1"></i>
                                                                {{ quiz.durationMinutes }} min
                                                            </span>
                                                            <span class="badge bg-warning">
                                                                <i class="bi bi-trophy me-1"></i>
                                                                {{ quiz.passingScore }}% to pass
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div class="mt-3">
                                                        {% set completedQuiz = false %}
                                                        {% set completedQuizResult = null %}
                                                        {% for quizResult in completed_quizzes %}
                                                            {% if quizResult.quiz.id == quiz.id %}
                                                                {% set completedQuiz = true %}
                                                                {% set completedQuizResult = quizResult %}
                                                            {% endif %}
                                                        {% endfor %}
                                                        
                                                        {% if completedQuiz %}
                                                            <a href="{{ path('app_candidate_quiz_result', {'id': completedQuizResult.id}) }}" class="btn btn-outline-success btn-sm">
                                                                <i class="bi bi-check-circle me-1"></i> View Results
                                                            </a>
                                                        {% else %}
                                                            <a href="{{ path('app_candidate_quiz_take', {'id': quiz.id}) }}" class="btn btn-primary btn-sm">
                                                                <i class="bi bi-play-circle me-1"></i> Take Quiz
                                                            </a>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </div>
                                        {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Completed Quizzes -->
            {% if completed_quizzes is not empty %}
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    <i class="bi bi-check-circle me-2"></i>
                                    Your Quiz Results
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover">
                                        <thead>
                                            <tr>
                                                <th>Quiz Title</th>
                                                <th>Score</th>
                                                <th>Status</th>
                                                <th>Date Taken</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for result in completed_quizzes %}
                                                <tr>
                                                    <td>{{ result.quiz.title }}</td>
                                                    <td>
                                                        <span class="badge {% if result.score >= result.quiz.passingScore %}bg-success{% else %}bg-danger{% endif %}">
                                                            {{ result.score }}%
                                                        </span>
                                                    </td>
                                                    <td>
                                                        {% if result.isPassed %}
                                                            <span class="badge bg-success">Passed</span>
                                                        {% else %}
                                                            <span class="badge bg-danger">Failed</span>
                                                        {% endif %}
                                                    </td>
                                                    <td>
                                                        {{ result.attemptDate|date('M d, Y H:i') }}
                                                    </td>
                                                    <td>
                                                        <a href="{{ path('app_candidate_quiz_result', {'id': result.id}) }}" class="btn btn-outline-info btn-sm">
                                                            <i class="bi bi-eye me-1"></i> View Details
                                                        </a>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
        </main>
    </div>
</div>

<style>
.card {
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    border: 1px solid rgba(0, 0, 0, 0.125);
    transition: transform 0.15s ease-in-out;
}

.card:hover {
    transform: translateY(-2px);
}

.card-title {
    color: #495057;
    font-weight: 600;
    margin-bottom: 0.5rem;
}

.table th {
    border-top: none;
    font-weight: 600;
    background-color: #f8f9fa;
}

.table td {
    vertical-align: middle;
}

.btn-sm {
    padding: 0.25rem 0.5rem;
    font-size: 0.875rem;
}
</style>
{% endblock %}
