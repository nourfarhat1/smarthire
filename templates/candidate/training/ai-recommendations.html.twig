{% extends 'candidate/layout.html.twig' %}

{% block title %}AI Training Recommendations - SmartHire{% endblock %}

{% block candidate_page_title %}AI Training Recommendations{% endblock %}

{% block candidate_content %}
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header candidate-primary text-white">
                <h5 class="mb-0"><i class="bi bi-magic me-2"></i>AI-Powered Training Recommendations</h5>
            </div>
            <div class="card-body">
                <!-- Introduction -->
                <div class="alert alert-info">
                    <h6><i class="bi bi-cpu me-2"></i>Smart Learning Assistant</h6>
                    <p class="mb-0">
                        Our AI analyzes your job applications, skills, and career goals to provide personalized 
                        training recommendations that will help you stand out in the job market.
                    </p>
                </div>

                {% if recommendations|length > 0 %}
                    <!-- Recommended Trainings -->
                    <div class="row">
                        {% for recommendation in recommendations %}
                            {% set training = recommendation.training %}
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card h-100 border-0 shadow-sm training-card">
                                    <div class="card-header candidate-info text-white">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-1">{{ training.title }}</h6>
                                                <small class="text-white-50">{{ training.category }}</small>
                                            </div>
                                            <div>
                                                <span class="badge bg-light text-dark">
                                                    {{ recommendation.match_score }}% Match
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <p class="card-text">{{ training.description|slice(0, 120) }}...</p>
                                        </div>
                                        
                                        <div class="mb-2">
                                            <small class="text-muted">
                                                <i class="bi bi-heart me-1"></i>{{ training.likes }} likes
                                                <i class="bi bi-heart-fill text-danger ms-2 me-1"></i>{{ training.dislikes }} dislikes
                                            </small>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <small class="text-muted">
                                                    <i class="bi bi-calendar3 me-1"></i>
                                                    {{ training.createdAt|date('M d, Y') }}
                                                </small>
                                                {% if training.videoUrl %}
                                                    <small class="text-success">
                                                        <i class="bi bi-play-circle me-1"></i>Video Available
                                                    </small>
                                                {% endif %}
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <small class="text-primary">
                                                <i class="bi bi-lightbulb me-1"></i>
                                                <strong>Why recommended:</strong> {{ recommendation.reason }}
                                            </small>
                                        </div>

                                        <div class="d-grid gap-2">
                                            <a href="{{ path('app_candidate_training_show', {'id': training.id}) }}" class="btn btn-sm btn-success">
                                                <i class="bi bi-eye me-1"></i>View Details
                                            </a>
                                            <div class="btn-group" role="group">
                                                <form method="post" action="{{ path('app_candidate_training_like', {'id': training.id}) }}" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                                        <i class="bi bi-hand-thumbs-up me-1"></i>Like
                                                    </button>
                                                </form>
                                                <form method="post" action="{{ path('app_candidate_training_dislike', {'id': training.id}) }}" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                        <i class="bi bi-hand-thumbs-down me-1"></i>Dislike
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <!-- No Recommendations -->
                    <div class="text-center py-5">
                        <div class="mb-4">
                            <i class="bi bi-magic text-muted" style="font-size: 4rem;"></i>
                        </div>
                        <h5 class="text-muted">No AI Recommendations Available</h5>
                        <p class="text-muted">
                            Start applying for jobs to get personalized AI training recommendations based on your career interests.
                        </p>
                        <div class="mt-3">
                            <a href="{{ path('app_candidate_job_marketplace') }}" class="btn btn-success">
                                <i class="bi bi-briefcase me-2"></i>Browse Jobs
                            </a>
                            <a href="{{ path('app_candidate_training') }}" class="btn btn-outline-success ms-2">
                                <i class="bi bi-book me-2"></i>Browse All Trainings
                            </a>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<!-- Sidebar -->
<div class="row mt-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header candidate-warning text-dark">
                <h6 class="mb-0"><i class="bi bi-cpu me-2"></i>How AI Recommendations Work</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-success">
                    <h6><i class="bi bi-robot me-2"></i>Smart Analysis</h6>
                    <p class="mb-0">
                        Our AI analyzes your job applications to identify skill gaps and career goals.
                    </p>
                </div>
                
                <div class="alert alert-info">
                    <h6><i class="bi bi-target me-2"></i>Personalized Matching</h6>
                    <p class="mb-0">
                        Each training is scored based on how well it matches your career aspirations.
                    </p>
                </div>
                
                <div class="alert alert-warning">
                    <h6><i class="bi bi-graph-up me-2"></i>Continuous Learning</h6>
                    <p class="mb-0">
                        Recommendations evolve as you apply to more jobs and develop new skills.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header candidate-info text-white">
                <h6 class="mb-0"><i class="bi bi-trending-up me-2"></i>Trending Skills</h6>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <a href="#" class="list-group-item list-group-item-action">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1">JavaScript/React</h6>
                                <small class="text-muted">Web Development</small>
                            </div>
                            <span class="badge bg-success">High Demand</span>
                        </div>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1">Data Science</h6>
                                <small class="text-muted">Analytics & ML</small>
                            </div>
                            <span class="badge bg-info">Growing</span>
                        </div>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1">Cloud Computing</h6>
                                <small class="text-muted">AWS/Azure/GCP</small>
                            </div>
                            <span class="badge bg-warning">Essential</span>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header candidate-success text-white">
                <h6 class="mb-0"><i class="bi bi-lightbulb me-2"></i>Learning Strategy</h6>
            </div>
            <div class="card-body">
                <div class="alert alert-light">
                    <h6><i class="bi bi-check-circle me-2"></i>Success Tips</h6>
                    <ul class="mb-0">
                        <li>Follow AI recommendations in order</li>
                        <li>Focus on high-match score trainings</li>
                        <li>Complete related skill bundles</li>
                        <li>Track your learning progress</li>
                    </ul>
                </div>
                
                <div class="text-center mt-3">
                    <a href="{{ path('app_candidate_training') }}" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-book me-1"></i>Explore All Trainings
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.candidate-primary {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
}

.candidate-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.candidate-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}

.candidate-success {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
}

.card {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: none;
}

.training-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
}

.btn-outline-success {
    border-color: #87a042;
    color: #87a042;
}

.btn-outline-success:hover {
    background-color: #87a042;
    border-color: #87a042;
}
</style>
{% endblock %}
