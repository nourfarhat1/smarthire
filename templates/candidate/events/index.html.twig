{% extends 'candidate/layout.html.twig' %}

{% block title %}Events - SmartHire{% endblock %}

{% block candidate_page_title %}Events{% endblock %}

{% block candidate_content %}
<!-- Event Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stats-card candidate-dashboard text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ totalEvents }}</h4>
                        <p class="card-text">Total Events</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-calendar-event fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-info text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ upcomingEvents }}</h4>
                        <p class="card-text">Upcoming</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-clock-history fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-warning text-dark">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ pastEvents }}</h4>
                        <p class="card-text">Past Events</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-calendar-check fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ joinedEvents }}</h4>
                        <p class="card-text">Joined</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-check-circle fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Actions and Filters -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header candidate-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-calendar-event me-2"></i>Browse Events</h5>
                    <div>
                        <a href="{{ path('app_candidate_events_my') }}" class="btn btn-light btn-sm me-2">
                            <i class="bi bi-person-check me-1"></i>My Events
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-6">
                        <label for="search" class="form-label">Search Events</label>
                        <input type="text" class="form-control" id="search" name="search" value="{{ search }}" placeholder="Search by name or description...">
                    </div>
                    <div class="col-md-4">
                        <label for="status" class="form-label">Filter by Status</label>
                        <select class="form-select" id="status" name="status">
                            <option value="">All Events</option>
                            <option value="upcoming" {{ selectedStatus == 'upcoming' ? 'selected' : '' }}>Upcoming</option>
                            <option value="past" {{ selectedStatus == 'past' ? 'selected' : '' }}>Past Events</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">&nbsp;</label>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-outline-success">
                                <i class="bi bi-search me-2"></i>Filter
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Events List -->
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                {% if events|length > 0 %}
                    <div class="row">
                        {% for event in events %}
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card h-100 border-0 shadow-sm">
                                    <div class="card-header candidate-info text-white">
                                        <h6 class="mb-0">{{ event.name }}</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-2">
                                            <small class="text-muted">
                                                <i class="bi bi-calendar3 me-1"></i>
                                                {{ event.eventDate|date('M d, Y H:i') }}
                                            </small>
                                        </div>
                                        <div class="mb-2">
                                            <small class="text-muted">
                                                <i class="bi bi-geo-alt me-1"></i>
                                                {{ event.location }}
                                            </small>
                                        </div>
                                        <div class="mb-2">
                                            <small class="text-muted">
                                                <i class="bi bi-people me-1"></i>
                                                {{ event.participants|length }}/{{ event.maxParticipants }} participants
                                            </small>
                                        </div>
                                        <p class="card-text small">{{ event.description|slice(0, 100) }}...</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                {% if event.eventDate >= date() %}
                                                    <span class="badge bg-success">Upcoming</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Past</span>
                                                {% endif %}
                                            </div>
                                            <a href="{{ path('app_candidate_events_show', {'id': event.id}) }}" class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-eye me-1"></i>View Details
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-event fs-1 text-muted mb-3"></i>
                        <h5>No Events Found</h5>
                        <p class="text-muted">
                            {% if search or selectedStatus %}
                                No events match your search criteria. Try adjusting your filters.
                            {% else %}
                                No events are currently scheduled. Check back later for new opportunities.
                            {% endif %}
                        </p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<style>
.candidate-dashboard {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
    box-shadow: 0 4px 15px rgba(135, 160, 66, 0.3);
}

.candidate-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.candidate-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}

.candidate-success {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
}

.candidate-primary {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
}

.card {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: none;
}

.btn-outline-success {
    border-color: #87a042;
    color: #87a042;
}

.btn-outline-success:hover {
    background-color: #87a042;
    border-color: #87a042;
}
</style>
{% endblock %}
