{% extends 'candidate/layout.html.twig' %}

{% block title %}My Events - SmartHire{% endblock %}

{% block candidate_page_title %}My Events{% endblock %}

{% block candidate_content %}
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header candidate-primary text-white">
                <h5 class="mb-0"><i class="bi bi-person-check me-2"></i>My Registered Events</h5>
            </div>
            <div class="card-body">
                {% if participants|length > 0 %}
                    <div class="row">
                        {% for participant in participants %}
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card h-100 border-0 shadow-sm">
                                    <div class="card-header candidate-info text-white">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <h6 class="mb-0">{{ participant.event.name }}</h6>
                                            <span class="badge bg-light text-dark">{{ participant.status }}</span>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-2">
                                            <small class="text-muted">
                                                <i class="bi bi-calendar3 me-1"></i>
                                                {{ participant.event.eventDate|date('M d, Y H:i') }}
                                            </small>
                                        </div>
                                        <div class="mb-2">
                                            <small class="text-muted">
                                                <i class="bi bi-geo-alt me-1"></i>
                                                {{ participant.event.location }}
                                            </small>
                                        </div>
                                        <div class="mb-2">
                                            <small class="text-muted">
                                                <i class="bi bi-calendar-check me-1"></i>
                                                Registered: {{ participant.joinedAt|date('M d, Y') }}
                                            </small>
                                        </div>
                                        <p class="card-text small">{{ participant.event.description|slice(0, 80) }}...</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                {% if participant.event.eventDate >= date() %}
                                                    <span class="badge bg-success">Upcoming</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Past</span>
                                                {% endif %}
                                            </div>
                                            <div class="btn-group" role="group">
                                                <a href="{{ path('app_candidate_events_show', {'id': participant.event.id}) }}" class="btn btn-sm btn-outline-success">
                                                    <i class="bi bi-eye me-1"></i>View
                                                </a>
                                                {% if participant.event.eventDate >= date() %}
                                                    <a href="{{ path('app_candidate_events_ticket', {'id': participant.event.id}) }}" class="btn btn-sm btn-outline-info">
                                                        <i class="bi bi-qr-code me-1"></i>Ticket
                                                    </a>
                                                    <form method="post" action="{{ path('app_candidate_events_cancel', {'id': participant.event.id}) }}" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-warning" onclick="return confirm('Are you sure you want to cancel your registration?');">
                                                            <i class="bi bi-x-circle me-1"></i>Cancel
                                                        </button>
                                                    </form>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-x fs-1 text-muted mb-3"></i>
                        <h5>No Registered Events</h5>
                        <p class="text-muted">
                            You haven't registered for any events yet. Browse available events and join the ones that interest you!
                        </p>
                        <a href="{{ path('app_candidate_events') }}" class="btn btn-success">
                            <i class="bi bi-calendar-event me-2"></i>Browse Events
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<!-- Event Statistics -->
<div class="row mt-4">
    <div class="col-md-3">
        <div class="card stats-card candidate-dashboard text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ participants|length }}</h4>
                        <p class="card-text">Total Registered</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-calendar-check fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-info text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ participants|filter(p => p.event.eventDate >= date())|length }}</h4>
                        <p class="card-text">Upcoming</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-clock-history fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-warning text-dark">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ participants|filter(p => p.event.eventDate < date())|length }}</h4>
                        <p class="card-text">Past Events</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-calendar-check fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ participants|filter(p => p.status == 'CONFIRMED')|length }}</h4>
                        <p class="card-text">Confirmed</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-check-circle fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.candidate-dashboard {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
    box-shadow: 0 4px 15px rgba(135, 160, 66, 0.3);
}

.candidate-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.candidate-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}

.candidate-success {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
}

.candidate-primary {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
}

.card {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: none;
}

.btn-outline-success {
    border-color: #87a042;
    color: #87a042;
}

.btn-outline-success:hover {
    background-color: #87a042;
    border-color: #87a042;
}
</style>
{% endblock %}
