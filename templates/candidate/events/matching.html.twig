{% extends 'candidate/layout.html.twig' %}

{% block title %}Matching Events - SmartHire{% endblock %}

{% block candidate_page_title %}🎯 Events Matched to Your Skills{% endblock %}

{% block candidate_content %}
<div class="container-fluid">
    <!-- Your Skills Section -->
    <div class="card mb-4">
        <div class="card-header candidate-primary text-white">
            <h5 class="mb-0"><i class="bi bi-stars me-2"></i>Your Detected Skills</h5>
        </div>
        <div class="card-body">
            {% if userSkills|length > 0 %}
                {% for skill in userSkills %}
                    <span class="badge bg-success me-2 mb-2 p-2 fs-6">
                        <i class="bi bi-check-circle-fill"></i> {{ skill }}
                    </span>
                {% endfor %}
            {% else %}
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle"></i> No skills detected. Please upload your CV.
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Matched Events Section -->
    <div class="card">
        <div class="card-header candidate-primary text-white">
            <h5 class="mb-0"><i class="bi bi-robot me-2"></i>AI-Powered Event Recommendations</h5>
        </div>
        <div class="card-body">
            {% if matches|length > 0 %}
                <div class="row">
                    {% for match in matches %}
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 event-card">
                                <div class="card-header {% if match.score >= 70 %}bg-success text-white{% elseif match.score >= 40 %}bg-warning{% else %}bg-secondary text-white{% endif %}">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0">{{ match.event.name }}</h6>
                                        <span class="badge bg-light text-dark">
                                            {{ match.score }}% Match
                                        </span>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="mb-2">
                                        <small class="text-muted">
                                            <i class="bi bi-calendar"></i> {{ match.event.eventDate|date('d/m/Y H:i') }}
                                        </small>
                                    </div>
                                    <div class="mb-2">
                                        <small class="text-muted">
                                            <i class="bi bi-geo-alt"></i> {{ match.event.location }}
                                        </small>
                                    </div>
                                    <p class="card-text small">{{ match.recommendation }}</p>
                                    
                                    {% if match.score >= 70 %}
                                        <div class="alert alert-success py-1 mb-0 small">
                                            <i class="bi bi-star-fill"></i> Excellent match for you!
                                        </div>
                                    {% elseif match.score >= 40 %}
                                        <div class="alert alert-warning py-1 mb-0 small">
                                            <i class="bi bi-hand-thumbs-up"></i> Good potential match
                                        </div>
                                    {% else %}
                                        <div class="alert alert-secondary py-1 mb-0 small">
                                            <i class="bi bi-arrow-up"></i> Consider improving skills
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="card-footer">
                                    <a href="{{ path('app_candidate_events_show', {'id': match.event.id}) }}" class="btn btn-sm btn-primary w-100">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> No upcoming events found. Check back later!
                </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
.event-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.event-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
}
.candidate-primary {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
}
</style>
{% endblock %}