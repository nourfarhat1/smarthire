{% extends 'candidate/layout.html.twig' %}

{% block title %}Quiz Result - {{ quiz.title }}{% endblock %}

{% block page_title %}Quiz Result - {{ quiz.title }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Candidate Sidebar -->
        <nav class="col-md-3 col-lg-2 d-md-block sidebar">
            {{ include('candidate/sidebar.html.twig') }}
        </nav>
        
        <!-- Main Content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">{% block candidate_page_title %}Quiz Result{% endblock %}</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    {% block candidate_actions %}
                        <a href="{{ path('app_candidate_quizzes') }}" class="btn btn-outline-primary">
                            <i class="bi bi-arrow-left me-2"></i> Back to Quizzes
                        </a>
                        <a href="{{ path('app_candidate_profile') }}" class="btn btn-outline-info">
                            <i class="bi bi-person-circle me-2"></i> My Profile
                        </a>
                    {% endblock %}
                </div>
            </div>

            <!-- Result Card -->
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">
                                <i class="bi bi-clipboard-check me-2"></i>
                                Quiz Results
                            </h5>
                        </div>
                        <div class="card-body">
                            <!-- Success/Failure Status -->
                            <div class="text-center mb-4">
                                {% if quizResult.status == 'passed' %}
                                    <div class="alert alert-success">
                                        <h4 class="alert-heading">
                                            <i class="bi bi-check-circle-fill me-2"></i>
                                            Congratulations! You Passed!
                                        </h4>
                                        <p class="mb-0">You have successfully completed the quiz "{{ quiz.title }}".</p>
                                    </div>
                                {% else %}
                                    <div class="alert alert-danger">
                                        <h4 class="alert-heading">
                                            <i class="bi bi-x-circle-fill me-2"></i>
                                            Not Passed
                                        </h4>
                                        <p class="mb-0">You did not pass the quiz "{{ quiz.title }}".</p>
                                    </div>
                                {% endif %}
                            </div>

                            <!-- Score Details -->
                            <div class="row mb-4">
                                <div class="col-md-3">
                                    <div class="card text-center">
                                        <div class="card-body">
                                            <h3 class="text-primary">{{ quizResult.score }}%</h3>
                                            <p class="text-muted mb-0">Your Score</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card text-center">
                                        <div class="card-body">
                                            <h3 class="text-success">{{ quiz.passingScore }}%</h3>
                                            <p class="text-muted mb-0">Passing Score</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card text-center">
                                        <div class="card-body">
                                            <h3 class="text-info">{{ quizResult.correctAnswers }}/{{ quizResult.totalQuestions }}</h3>
                                            <p class="text-muted mb-0">Correct Answers</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Time Information -->
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <strong>Start Time:</strong> 
                                    {% if quizResult.startTime %}
                                        {{ quizResult.startTime|date('M d, Y H:i:s') }}
                                    {% else %}
                                        Not recorded
                                    {% endif %}
                                </div>
                                <div class="col-md-6">
                                    <strong>End Time:</strong> 
                                    {% if quizResult.endTime %}
                                        {{ quizResult.endTime|date('M d, Y H:i:s') }}
                                    {% else %}
                                        Not recorded
                                    {% endif %}
                                </div>
                            </div>

                            <!-- Duration Calculation -->
                            {% if quizResult.startTime and quizResult.endTime %}
                                {% set duration = date(quizResult.endTime).getTimestamp() - date(quizResult.startTime).getTimestamp() %}
                                <div class="row mb-4">
                                    <div class="col-12">
                                        <strong>Time Taken:</strong> 
                                        <span class="badge bg-info">
                                            {{ (duration // 60) }} minutes {{ (duration % 60) }} seconds
                                        </span>
                                    </div>
                                </div>
                            {% endif %}

                            <!-- Performance Message -->
                            <div class="alert alert-info">
                                {% if quizResult.status == 'passed' %}
                                    <h5><i class="bi bi-trophy me-2"></i> Excellent Work!</h5>
                                    <p>You demonstrated good knowledge of the subject matter. Keep up the great work!</p>
                                {% elseif quizResult.score >= 70 %}
                                    <h5><i class="bi bi-hand-thumbs-up me-2"></i> Good Effort!</h5>
                                    <p>You showed understanding of most concepts. A little more practice could help you reach the passing score.</p>
                                {% elseif quizResult.score >= 50 %}
                                    <h5><i class="bi bi-info-circle me-2"></i> Room for Improvement</h5>
                                    <p>You have some understanding but need to study more. Review the questions you missed and try again.</p>
                                {% else %}
                                    <h5><i class="bi bi-book me-2"></i> Keep Studying</h5>
                                    <p>This topic needs more attention. Consider reviewing the study materials and taking the quiz again after preparation.</p>
                                {% endif %}
                            </div>

                            <!-- Action Buttons -->
                            <div class="d-flex justify-content-between mt-4">
                                <div>
                                    <a href="{{ path('app_candidate_quizzes') }}" class="btn btn-outline-primary">
                                        <i class="bi bi-list me-2"></i> Take Another Quiz
                                    </a>
                                </div>
                                <div>
                                    <button onclick="window.print()" class="btn btn-outline-secondary">
                                        <i class="bi bi-printer me-2"></i> Print Results
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Print Styles -->
<style>
@media print {
    .sidebar {
        display: none;
    }
    
    .col-md-9 {
        flex: 0 0 100%;
        max-width: 100%;
    }
    
    .btn-toolbar {
        display: none;
    }
    
    .card {
        break-inside: avoid;
    }
    
    .alert {
        break-inside: avoid;
    }
}
</style>
{% endblock %}
