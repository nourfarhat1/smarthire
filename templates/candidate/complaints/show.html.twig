{% extends 'candidate/layout.html.twig' %}

{% block title %}Complaint #{{ complaint.id }} - SmartHire{% endblock %}

{% block candidate_page_title %}Complaint Details{% endblock %}

{% block candidate_content %}
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header candidate-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Complaint #{{ complaint.id }}</h5>
                    <div>
                        {% if complaint.status == 'PENDING' %}
                            <span class="badge bg-warning">Pending</span>
                        {% elseif complaint.status == 'OPEN' %}
                            <span class="badge bg-primary">Open</span>
                        {% elseif complaint.status == 'RESOLVED' %}
                            <span class="badge bg-success">Resolved</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ complaint.status }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Subject:</strong><br>
                        {{ complaint.subject }}
                    </div>
                    <div class="col-md-6">
                        <strong>Type:</strong><br>
                        {% if complaint.type %}
                            <span class="badge bg-info">{{ complaint.type.name }}</span>
                        {% else %}
                            <span class="badge bg-secondary">General</span>
                        {% endif %}
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Priority:</strong><br>
                        {% if complaint.priority == 'HIGH' %}
                            <span class="badge bg-danger">High</span>
                        {% elseif complaint.priority == 'MEDIUM' %}
                            <span class="badge bg-warning">Medium</span>
                        {% else %}
                            <span class="badge bg-info">Low</span>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        <strong>Submitted:</strong><br>
                        {{ complaint.submissionDate|date('F j, Y H:i') }}
                    </div>
                </div>

                <div class="mb-3">
                    <strong>Description:</strong>
                    <div class="mt-2 p-3 bg-light rounded">
                        {{ complaint.description|nl2br }}
                    </div>
                </div>

                {% if complaint.status == 'RESOLVED' and complaint.resolutionDate %}
                    <div class="alert alert-success">
                        <h6><i class="bi bi-check-circle me-2"></i>Resolution Information</h6>
                        <p class="mb-1"><strong>Resolved on:</strong> {{ complaint.resolutionDate|date('F j, Y H:i') }}</p>
                        {% if complaint.resolution %}
                            <p><strong>Resolution:</strong> {{ complaint.resolution }}</p>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Responses Section -->
        {% if complaint.responses|length > 0 %}
            <div class="card mt-3">
                <div class="card-header candidate-info text-white">
                    <h5 class="mb-0"><i class="bi bi-chat-dots me-2"></i>Responses & Updates</h5>
                </div>
                <div class="card-body">
                    {% for response in complaint.responses %}
                        <div class="d-flex mb-3">
                            <div class="flex-shrink-0">
                                {% if response.admin %}
                                    <div class="avatar-circle bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        {{ response.admin.firstName|first }}{{ response.admin.lastName|first }}
                                    </div>
                                {% else %}
                                    <div class="avatar-circle bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <i class="bi bi-person"></i>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <div class="d-flex justify-content-between">
                                    <h6 class="mb-1">
                                        {% if response.admin %}
                                            {{ response.admin.firstName }} {{ response.admin.lastName }}
                                            <small class="badge bg-success ms-2">Support Team</small>
                                        {% else %}
                                            System
                                        {% endif %}
                                    </h6>
                                    <small class="text-muted">{{ response.createdAt|date('M d, Y H:i') }}</small>
                                </div>
                                <p class="mb-0">{{ response.content|nl2br }}</p>
                            </div>
                        </div>
                        {% if not loop.last %}
                            <hr>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>

    <div class="col-md-4">
        <!-- Actions Card -->
        <div class="card">
            <div class="card-header candidate-warning text-dark">
                <h6 class="mb-0"><i class="bi bi-gear me-2"></i>Actions</h6>
            </div>
            <div class="card-body">
                {% if complaint.status == 'PENDING' %}
                    <div class="d-grid gap-2">
                        <a href="{{ path('app_candidate_complaints_edit', {'id': complaint.id}) }}" class="btn btn-warning">
                            <i class="bi bi-pencil me-2"></i>Edit Complaint
                        </a>
                        <form method="post" action="{{ path('app_candidate_complaints_delete', {'id': complaint.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ complaint.id) }}">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this complaint?');">
                                <i class="bi bi-trash me-2"></i>Delete Complaint
                            </button>
                        </form>
                    </div>
                    <hr>
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        You can only edit or delete pending complaints.
                    </small>
                {% else %}
                    <div class="alert alert-info">
                        <i class="bi bi-lock me-2"></i>
                        This complaint cannot be edited as it's already being processed.
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Status Timeline -->
        <div class="card mt-3">
            <div class="card-header candidate-success text-white">
                <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Status Timeline</h6>
            </div>
            <div class="card-body">
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-marker bg-warning"></div>
                        <div class="timeline-content">
                            <small class="text-muted">{{ complaint.submissionDate|date('M d, Y H:i') }}</small>
                            <p class="mb-0">Complaint submitted</p>
                        </div>
                    </div>
                    
                    {% if complaint.status != 'PENDING' %}
                        <div class="timeline-item">
                            <div class="timeline-marker bg-primary"></div>
                            <div class="timeline-content">
                                <small class="text-muted">Processing started</small>
                                <p class="mb-0">Complaint is being reviewed</p>
                            </div>
                        </div>
                    {% endif %}
                    
                    {% if complaint.status == 'RESOLVED' %}
                        <div class="timeline-item">
                            <div class="timeline-marker bg-success"></div>
                            <div class="timeline-content">
                                <small class="text-muted">{{ complaint.resolutionDate|date('M d, Y H:i') }}</small>
                                <p class="mb-0">Complaint resolved</p>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.candidate-primary {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
}

.candidate-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.candidate-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}

.candidate-success {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
}

.card {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: none;
}

.avatar-circle {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
    box-shadow: 0 2px 8px rgba(135, 160, 66, 0.3);
}

.timeline {
    position: relative;
    padding-left: 20px;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 0;
    height: 100%;
    width: 2px;
    background: #e9ecef;
}

.timeline-item {
    position: relative;
    margin-bottom: 20px;
}

.timeline-marker {
    position: absolute;
    left: -12px;
    top: 0;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid white;
}

.timeline-content {
    margin-left: 10px;
}

.timeline-content small {
    display: block;
    margin-bottom: 4px;
}
</style>
{% endblock %}
