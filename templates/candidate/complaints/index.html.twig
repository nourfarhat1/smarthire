{% extends 'candidate/layout.html.twig' %}

{% block title %}My Complaints - SmartHire{% endblock %}

{% block candidate_page_title %}My Complaints{% endblock %}

{% block candidate_content %}
<!-- Complaint Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stats-card candidate-dashboard text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ pendingCount }}</h4>
                        <p class="card-text">Pending</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-clock-history fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-info text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ openCount }}</h4>
                        <p class="card-text">Open</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-envelope-open fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-warning text-dark">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ resolvedCount }}</h4>
                        <p class="card-text">Resolved</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-check-circle fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card candidate-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h4 class="card-title">{{ complaints|length }}</h4>
                        <p class="card-text">Total</p>
                    </div>
                    <div class="align-self-center">
                        <i class="bi bi-file-text fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Actions and Filters -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header candidate-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Support Tickets</h5>
                    <a href="{{ path('app_candidate_complaints_new') }}" class="btn btn-light btn-sm">
                        <i class="bi bi-plus-circle me-2"></i>New Complaint
                    </a>
                </div>
            </div>
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-4">
                        <label for="search" class="form-label">Search</label>
                        <input type="text" class="form-control" id="search" name="search" value="{{ search }}" placeholder="Search complaints...">
                    </div>
                    <div class="col-md-3">
                        <label for="status" class="form-label">Status</label>
                        <select class="form-select" id="status" name="status">
                            <option value="">All Status</option>
                            <option value="PENDING" {{ selectedStatus == 'PENDING' ? 'selected' : '' }}>Pending</option>
                            <option value="OPEN" {{ selectedStatus == 'OPEN' ? 'selected' : '' }}>Open</option>
                            <option value="RESOLVED" {{ selectedStatus == 'RESOLVED' ? 'selected' : '' }}>Resolved</option>
                            <option value="CLOSED" {{ selectedStatus == 'CLOSED' ? 'selected' : '' }}>Closed</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="type" class="form-label">Type</label>
                        <select class="form-select" id="type" name="type">
                            <option value="">All Types</option>
                            {% for type in complaintTypes %}
                                <option value="{{ type.id }}" {{ selectedType == type.id ? 'selected' : '' }}>{{ type.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">&nbsp;</label>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-outline-success">
                                <i class="bi bi-search me-2"></i>Filter
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Complaints List -->
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                {% if complaints|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Subject</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th>Priority</th>
                                    <th>Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for complaint in complaints %}
                                    <tr>
                                        <td><span class="badge bg-secondary">#{{ complaint.id }}</span></td>
                                        <td>
                                            <strong>{{ complaint.subject }}</strong>
                                            <br>
                                            <small class="text-muted">{{ complaint.description|slice(0, 50) }}...</small>
                                        </td>
                                        <td>
                                            {% if complaint.type %}
                                                <span class="badge bg-info">{{ complaint.type.name }}</span>
                                            {% else %}
                                                <span class="badge bg-secondary">General</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if complaint.status == 'PENDING' %}
                                                <span class="badge bg-warning">Pending</span>
                                            {% elseif complaint.status == 'OPEN' %}
                                                <span class="badge bg-primary">Open</span>
                                            {% elseif complaint.status == 'RESOLVED' %}
                                                <span class="badge bg-success">Resolved</span>
                                            {% else %}
                                                <span class="badge bg-secondary">{{ complaint.status }}</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if complaint.priority == 'HIGH' %}
                                                <span class="badge bg-danger">High</span>
                                            {% elseif complaint.priority == 'MEDIUM' %}
                                                <span class="badge bg-warning">Medium</span>
                                            {% else %}
                                                <span class="badge bg-info">Low</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <small>{{ complaint.submissionDate|date('M d, Y') }}</small>
                                            <br>
                                            <small class="text-muted">{{ complaint.submissionDate|date('H:i') }}</small>
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="{{ path('app_candidate_complaints_show', {'id': complaint.id}) }}" class="btn btn-sm btn-outline-success">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                {% if complaint.status == 'PENDING' %}
                                                    <a href="{{ path('app_candidate_complaints_edit', {'id': complaint.id}) }}" class="btn btn-sm btn-outline-warning">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <form method="post" action="{{ path('app_candidate_complaints_delete', {'id': complaint.id}) }}" style="display: inline;">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ complaint.id) }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this complaint?');">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-exclamation-triangle fs-1 text-muted mb-3"></i>
                        <h5>No Complaints Found</h5>
                        <p class="text-muted">
                            {% if search or selectedStatus or selectedType %}
                                No complaints match your search criteria. Try adjusting your filters.
                            {% else %}
                                You haven't submitted any complaints yet. If you need help, click the button below to create a new complaint.
                            {% endif %}
                        </p>
                        {% if not search and not selectedStatus and not selectedType %}
                            <a href="{{ path('app_candidate_complaints_new') }}" class="btn btn-success">
                                <i class="bi bi-plus-circle me-2"></i>Create Your First Complaint
                            </a>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<style>
.candidate-dashboard {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
    box-shadow: 0 4px 15px rgba(135, 160, 66, 0.3);
}

.candidate-info {
    background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
}

.candidate-warning {
    background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
}

.candidate-success {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
}

.candidate-primary {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
}

.card {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: none;
}

.table-hover tbody tr:hover {
    background-color: rgba(135, 160, 66, 0.05);
}

.btn-outline-success {
    border-color: #87a042;
    color: #87a042;
}

.btn-outline-success:hover {
    background-color: #87a042;
    border-color: #87a042;
}
</style>
{% endblock %}
