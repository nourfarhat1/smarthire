{% extends 'candidate/layout.html.twig' %}

{% block title %}Edit Spontaneous Application - SmartHire{% endblock %}

{% block candidate_page_title %}Edit Spontaneous Application{% endblock %}

{% block candidate_content %}
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header candidate-primary text-white">
                <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Spontaneous Application</h5>
            </div>
            <div class="card-body">
                <!-- Current Application Status -->
                <div class="alert alert-info">
                    <h6><i class="bi bi-info-circle me-2"></i>Application Status</h6>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong>Current Status:</strong> 
                            <span class="badge bg-warning">PENDING</span>
                        </div>
                        <div>
                            <strong>Applied:</strong> {{ jobRequest.submissionDate|date('M d, Y') }}
                        </div>
                    </div>
                    <p class="mb-0 mt-2">
                        <small class="text-muted">
                            You can only edit your spontaneous application while it's in "Pending" status. Once reviewed, changes cannot be made.
                        </small>
                    </p>
                </div>

                <!-- Spontaneous Application Information -->
                <div class="card bg-light mb-4">
                    <div class="card-body">
                        <h6 class="card-title">Spontaneous Application Details</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <strong>Subject:</strong><br>
                                {{ jobRequest.jobTitle|default('N/A') }}
                            </div>
                            <div class="col-md-6">
                                <strong>Preferred Category:</strong><br>
                                {{ jobRequest.categorie|default('N/A') }}
                            </div>
                        </div>
                    </div>
                </div>

                {% if jobRequest.status != 'PENDING' %}
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Cannot Edit:</strong> This application has already been reviewed and its status is "{{ jobRequest.status }}". 
                        Applications can only be edited while in "PENDING" status.
                    </div>
                    
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('app_candidate_applications') }}" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Back to Applications
                        </a>
                    </div>
                {% else %}
                    <!-- Edit Form -->
                    <form method="post" id="edit-spontaneous-form" novalidate data-turbo="false">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label for="subject" class="form-label">Subject *</label>
                                    <input type="text" class="form-control" id="subject" name="subject" required 
                                           value="{{ jobRequest.jobTitle|default('') }}"
                                           placeholder="e.g., Experienced Software Developer seeking opportunities">
                                    <div class="form-text">
                                        <i class="bi bi-info-circle me-1"></i>
                                        A clear, compelling subject line helps recruiters understand your intent quickly.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="category" class="form-label">Preferred Category *</label>
                                    <select class="form-select" id="category" name="category" required>
                                        <option value="">Select a category</option>
                                        <option value="IT/Software" {{ jobRequest.categorie == 'IT/Software' ? 'selected' : '' }}>IT/Software</option>
                                        <option value="Marketing" {{ jobRequest.categorie == 'Marketing' ? 'selected' : '' }}>Marketing</option>
                                        <option value="Sales" {{ jobRequest.categorie == 'Sales' ? 'selected' : '' }}>Sales</option>
                                        <option value="Human Resources" {{ jobRequest.categorie == 'Human Resources' ? 'selected' : '' }}>Human Resources</option>
                                        <option value="Finance" {{ jobRequest.categorie == 'Finance' ? 'selected' : '' }}>Finance</option>
                                        <option value="Operations" {{ jobRequest.categorie == 'Operations' ? 'selected' : '' }}>Operations</option>
                                        <option value="Customer Service" {{ jobRequest.categorie == 'Customer Service' ? 'selected' : '' }}>Customer Service</option>
                                        <option value="Other" {{ jobRequest.categorie == 'Other' ? 'selected' : '' }}>Other</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="location" class="form-label">Preferred Location</label>
                                    <input type="text" class="form-control" id="location" name="location"
                                           value="{{ jobRequest.location|default('') }}"
                                           placeholder="e.g., Tunis, Remote, etc.">
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="description" class="form-label">Your Message *</label>
                            <textarea class="form-control" id="description" name="description" rows="8" required
                                      placeholder="Introduce yourself, highlight your key skills and experiences, and explain what type of opportunities you're looking for...">{{ jobRequest.coverLetter|default('') }}</textarea>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>
                                Be specific about your skills, experience, and career goals. This helps recruiters match you with suitable opportunities.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="skills" class="form-label">Key Skills</label>
                            <input type="text" class="form-control" id="skills" name="skills"
                                   value="{{ jobRequest.candidate.skillsString|default('') }}"
                                   placeholder="e.g., PHP, Symfony, JavaScript, Project Management">
                            <div class="form-text">These skills come from your profile. <a href="{{ path('app_candidate_profile') }}">Edit profile</a> to update them.</div>
                        </div>

                        <!-- Form Actions -->
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_candidate_applications') }}" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                            <div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save me-2"></i>Save Changes
                                </button>
                            </div>
                        </div>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-md-4">
        <!-- Tips Card -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0"><i class="bi bi-lightbulb me-2"></i>Tips for Success</h6>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Be specific about your skills</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Mention years of experience</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Highlight key achievements</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>State your career goals</li>
                    <li class="mb-0"><i class="bi bi-check-circle text-success me-2"></i>Keep it professional and concise</li>
                </ul>
            </div>
        </div>

        <!-- Your Profile Card -->
        <div class="card">
            <div class="card-header bg-secondary text-white">
                <h6 class="mb-0"><i class="bi bi-person me-2"></i>Your Profile</h6>
            </div>
            <div class="card-body">
                <p class="mb-2"><strong>Name:</strong> {{ app.user.fullName }}</p>
                <p class="mb-2"><strong>Email:</strong> {{ app.user.email }}</p>
                {% if app.user.phoneNumber %}
                    <p class="mb-0"><strong>Phone:</strong> {{ app.user.phoneNumber }}</p>
                {% endif %}
                <hr>
                <a href="{{ path('app_candidate_profile') }}" class="btn btn-outline-secondary btn-sm w-100">
                    <i class="bi bi-pencil me-1"></i>Edit Profile
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
