{% extends 'base.html.twig' %}

{% block title %}Forgot Password - SmartHire{% endblock %}

{% block stylesheets %}
<style>
/* Role-specific color schemes */
.role-hr {
    --role-primary: #e91e63;
    --role-gradient: linear-gradient(135deg, #e91e63 0%, #c2185b 100%);
    --role-light: #fce4ec;
}

.role-candidate {
    --role-primary: #87a042;
    --role-gradient: linear-gradient(135deg, #87a042 0%, #6b8a35 100%);
    --role-light: #f1f8e9;
}

.role-admin {
    --role-primary: #2196f3;
    --role-gradient: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
    --role-light: #e3f2fd;
}

.role-default {
    --role-primary: #6c757d;
    --role-gradient: linear-gradient(135deg, #6c757d 0%, #495057 100%);
    --role-light: #f8f9fa;
}

/* Animated background */
.login-bg {
    background: var(--role-gradient);
    position: relative;
    overflow: hidden;
}

.login-bg::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
    background-size: 20px 20px;
    animation: float 20s linear infinite;
}

@keyframes float {
    0% { transform: translate(0, 0) rotate(0deg); }
    100% { transform: translate(50px, 50px) rotate(360deg); }
}

/* Form enhancements */
.form-control:focus {
    border-color: var(--role-primary);
    box-shadow: 0 0 0 0.2rem rgba(233, 30, 99, 0.25);
}

.btn-role {
    background: linear-gradient(135deg, #87a042 0%, #6b8a35 100%);
    border: none;
    color: white;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(135, 160, 66, 0.3);
}

.btn-role:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(135, 160, 66, 0.4);
}

.btn-outline-role {
    background: transparent;
    border: 2px solid #87a042;
    color: #87a042;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-outline-role:hover {
    background: #87a042;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(135, 160, 66, 0.3);
}

/* Feature icons */
.feature-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(10px);
    margin-bottom: 1rem;
    transition: all 0.3s ease;
}

.feature-card:hover .feature-icon {
    transform: scale(1.1) rotate(5deg);
    background: rgba(255,255,255,0.3);
}

/* Session info */
.session-info {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    border-radius: 10px;
    padding: 15px;
    margin-bottom: 20px;
    border: 1px solid rgba(255,255,255,0.2);
}

/* Loading state */
.loading {
    position: relative;
    pointer-events: none;
    opacity: 0.7;
}

.loading::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 20px;
    margin: -10px 0 0 -10px;
    border: 2px solid transparent;
    border-top: 2px solid white;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}
</style>
{% endblock %}

{% block body %}
<div class="row min-vh-100">
    <!-- Left Side - Password Reset Info -->
    <div class="col-lg-6 d-none d-lg-block">
        <div class="h-100 d-flex align-items-center justify-content-center login-bg role-default" id="loginBg">
            <div class="text-center text-white p-5">
                <h1 class="display-4 fw-bold mb-4">SmartHire</h1>
                <p class="lead mb-5">Password Reset Assistant</p>
                
                <!-- Session Information -->
                <div class="session-info mb-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-shield-check me-2"></i>
                            <span>Secure Reset</span>
                        </div>
                        <div>
                            <i class="bi bi-clock me-2"></i>
                            <span id="currentTime"></span>
                        </div>
                    </div>
                </div>
                
                <!-- Reset Process Steps -->
                <div class="mb-5">
                    <h4 class="mb-3">How It Works</h4>
                    <div class="row g-3 text-start">
                        <div class="col-md-12">
                            <div class="d-flex align-items-center mb-3">
                                <div class="feature-icon me-3">
                                    <i class="bi bi-envelope-fill fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1">Step 1: Enter Email</h6>
                                    <small class="opacity-75">Provide your registered email address</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="d-flex align-items-center mb-3">
                                <div class="feature-icon me-3">
                                    <i class="bi bi-key-fill fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1">Step 2: Receive Code</h6>
                                    <small class="opacity-75">Get 6-digit verification code via email</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="d-flex align-items-center mb-3">
                                <div class="feature-icon me-3">
                                    <i class="bi bi-lock-fill fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1">Step 3: Reset Password</h6>
                                    <small class="opacity-75">Enter code and set new password</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Access -->
                <div class="d-flex justify-content-center gap-2">
                    <a href="{{ path('app_login') }}" class="btn btn-outline-light">
                        <i class="bi bi-box-arrow-in-left me-1"></i> Back to Login
                    </a>
                    <a href="{{ path('app_register') }}" class="btn btn-outline-light">
                        <i class="bi bi-person-plus me-1"></i> Create Account
                    </a>
                </div>

                <!-- Security Features -->
                <div class="row text-start mt-5">
                    <div class="col-md-6 mb-3">
                        <div class="feature-card">
                            <div class="feature-icon mx-auto">
                                <i class="bi bi-shield-fill fs-4"></i>
                            </div>
                            <h6 class="mb-0">Secure Process</h6>
                            <small class="opacity-75">Encrypted verification</small>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="feature-card">
                            <div class="feature-icon mx-auto">
                                <i class="bi bi-clock-fill fs-4"></i>
                            </div>
                            <h6 class="mb-0">15-Min expiry</h6>
                            <small class="opacity-75">Time-sensitive codes</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Right Side - Forgot Password Form -->
    <div class="col-lg-6">
        <div class="h-100 d-flex align-items-center justify-content-center p-4">
            <div class="w-100" style="max-width: 400px;">
                <div class="text-center mb-4">
                    <div class="mb-3">
                        <div class="role-icon mx-auto" style="background: #6c757d;">
                            <i class="bi bi-key"></i>
                        </div>
                    </div>
                    <h2 class="fw-bold">Reset Password</h2>
                    <p class="text-muted">Enter your email to receive a verification code</p>
                </div>

                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                            <i class="bi bi-{{ type == 'success' ? 'check-circle' : type == 'error' ? 'exclamation-triangle' : 'info-circle' }} me-2"></i>
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'forgotPasswordForm'}}) }}
                    <div class="mb-3">
                        <label for="{{ form.email.vars.id }}" class="form-label">
                            <i class="bi bi-envelope me-1"></i>Email Address
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-envelope"></i>
                            </span>
                            {{ form_widget(form.email, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Enter your registered email', 'autofocus': true}}) }}
                        </div>
                        {{ form_errors(form.email) }}
                        <div class="form-text">
                            We'll send a verification code to this email address.
                        </div>
                    </div>

                    <div class="d-grid mb-3">
                        {{ form_widget(form.submit, {'attr': {'class': 'btn btn-role btn-lg', 'id': 'submitBtn'}}) }}
                    </div>

                    <div class="text-center">
                        <p class="mb-0">Remember your password?</p>
                        <a href="{{ path('app_login') }}" class="btn btn-outline-role">
                            <i class="bi bi-box-arrow-in-left me-2"></i>Back to Login
                        </a>
                    </div>
                {{ form_end(form) }}

                <!-- Additional Information -->
                <div class="mt-4 text-center">
                    <small class="text-muted">
                        <i class="bi bi-shield-check me-1"></i>
                        Your password reset is secure and encrypted
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function updateTime() {
    const now = new Date();
    const timeString = now.toLocaleTimeString('en-US', { 
        hour: '2-digit', 
        minute: '2-digit',
        hour12: true 
    });
    document.getElementById('currentTime').textContent = timeString;
}

// Form submission handling
document.getElementById('forgotPasswordForm').addEventListener('submit', function(e) {
    const btn = document.getElementById('submitBtn');
    
    // Show loading state
    btn.classList.add('loading');
    btn.disabled = true;
    
    // Reset loading state after 3 seconds (in case of redirect issues)
    setTimeout(() => {
        btn.classList.remove('loading');
        btn.disabled = false;
    }, 3000);
});

// Email validation
document.getElementById('{{ form.email.vars.id }}').addEventListener('blur', function() {
    const email = this.value;
    const formText = this.closest('.mb-3').querySelector('.form-text');
    
    if (email && !email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
        formText.textContent = 'Please enter a valid email address';
        formText.className = 'form-text text-danger';
    } else {
        formText.textContent = "We'll send a verification code to this email address.";
        formText.className = 'form-text';
    }
});

// Initialize
document.addEventListener('DOMContentLoaded', function() {
    updateTime();
    setInterval(updateTime, 1000);
    
    // Focus on email field
    document.getElementById('{{ form.email.vars.id }}').focus();
});
</script>
{% endblock %}
