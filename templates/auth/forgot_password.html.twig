{% extends 'base.html.twig' %}

{% block title %}Forgot Password - SmartHire{% endblock %}

{% block page_title %}Reset Password{% endblock %}

{% block page_actions %}
<a href="{{ path('app_login') }}" class="btn btn-outline-secondary">
    <i class="bi bi-box-arrow-in-left me-2"></i>Back to Login
</a>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card shadow">
            <div class="card-header bg-warning text-white py-3">
                <h4 class="mb-0">
                    <i class="bi bi-lock me-2"></i>Reset Your Password
                </h4>
            </div>
            <div class="card-body p-4">

                <p class="text-muted mb-4">
                    Enter your email address and we'll send a <strong>6-digit verification code</strong>
                    to your email and phone number.
                </p>

                <form method="POST" action="{{ path('app_forgot_password') }}">
                    <div class="mb-4">
                        <label class="form-label">
                            <i class="bi bi-envelope me-1"></i>Email Address
                        </label>
                        <input type="email" name="email" class="form-control form-control-lg"
                               placeholder="Enter your registered email" required autofocus>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning btn-lg">
                            <i class="bi bi-send me-2"></i>Send Verification Code
                        </button>
                        <a href="{{ path('app_login') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-box-arrow-in-left me-2"></i>Back to Login
                        </a>
                    </div>
                </form>

            </div>
        </div>

        <div class="text-center mt-3">
            <small class="text-muted">
                Remember your password?
                <a href="{{ path('app_login') }}">Log in here</a>
            </small>
        </div>
    </div>
</div>
{% endblock %}
