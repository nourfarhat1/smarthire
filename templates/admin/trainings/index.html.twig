{% extends 'base.html.twig' %}

{% block title %}Training Management - Admin - SmartHire{% endblock %}

{% block page_title %}Training Management{% endblock %}

{% block page_actions %}
<a href="{{ path('app_admin_trainings_new') }}" class="btn btn-primary">
    <i class="bi bi-plus-circle me-2"></i>Create Training
</a>
<a href="{{ path('app_admin_trainings_analytics') }}" class="btn btn-info">
    <i class="bi bi-graph-up me-2"></i>Analytics
</a>
{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="bi bi-play-circle me-2"></i>Training Materials
                </h4>
            </div>
            <div class="card-body">
                {% if trainings|length > 0 %}
                <div class="row">
                    {% for training in trainings %}
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">{{ training.title }}</h5>
                                <div class="text-muted small mb-2">
                                    <i class="bi bi-tag me-1"></i>{{ training.category }}
                                    <span class="ms-2">
                                        <i class="bi bi-person me-1"></i>{{ training.adminName|default('Admin') }}
                                    </span>
                                </div>
                                <p class="card-text">{{ training.description|slice(0, 100) ~ '...' }}</p>
                                
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="badge bg-success me-2">
                                            <i class="bi bi-hand-thumbs-up"></i> {{ training.likes }}
                                        </span>
                                        <span class="badge bg-danger">
                                            <i class="bi bi-hand-thumbs-down"></i> {{ training.dislikes }}
                                        </span>
                                    </div>
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('app_admin_trainings_edit', {'id': training.id}) }}" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        {% if training.videoUrl %}
                                        <a href="{{ training.videoUrl }}" target="_blank" 
                                           class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-play-circle"></i>
                                        </a>
                                        {% endif %}
                                        <form method="post" 
                                              action="{{ path('app_admin_trainings_delete', {'id': training.id}) }}" 
                                              onsubmit="return confirm('Are you sure you want to delete this training?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete') }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                {% else %}
                <div class="text-center py-5">
                    <i class="bi bi-play-circle fs-1 text-muted"></i>
                    <h4 class="text-muted">No Training Materials Found</h4>
                    <p class="text-muted">Start by creating your first training material to help users develop their skills.</p>
                    <a href="{{ path('app_admin_trainings_new') }}" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Create First Training
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
