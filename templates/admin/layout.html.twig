{% extends 'base.html.twig' %}

{% block title %}Admin - SmartHire{% endblock %}

{% block page_title %}Admin Dashboard{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Admin Sidebar -->
        <nav class="col-md-3 col-lg-2 d-md-block sidebar">
            <div class="position-sticky pt-3">
                <!-- Admin Menu (Blue header #4686c2) -->
                <div class="admin-menu mb-4">
                    <div class="role-header text-center py-2 mb-3 rounded" style="background-color: #4686c2;">
                        <small class="text-white fw-bold">ADMINISTRATOR</small>
                    </div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link text-white {{ app.request.get('_route') == 'app_admin_quizzes' ? 'active' : '' }}" href="{{ path('app_admin_quizzes') }}">
                                <i class="bi bi-question-circle me-2"></i> Quiz Management
                                <small class="text-muted">(View Only)</small>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white {{ app.request.get('_route') starts with 'app_admin_events' ? 'active' : '' }}" href="{{ path('app_admin_events') }}">
                                <i class="bi bi-calendar-event me-2"></i> Admin Events
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white {{ app.request.get('_route') == 'app_admin_complaint_types' ? 'active' : '' }}" href="{{ path('app_admin_complaint_types') }}">
                                <i class="bi bi-tags me-2"></i> Complaint Types
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white {{ app.request.get('_route') starts with 'app_admin_reclamations' ? 'active' : '' }}" href="{{ path('app_admin_reclamations') }}">
                                <i class="bi bi-exclamation-triangle me-2"></i> Manage Complaints
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white {{ app.request.get('_route') == 'app_admin_job_categories' ? 'active' : '' }}" href="{{ path('app_admin_job_categories') }}">
                                <i class="bi bi-tags me-2"></i> Job Categories
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white {{ app.request.get('_route') starts with 'app_admin_jobs' ? 'active' : '' }}" href="{{ path('app_admin_jobs') }}">
                                <i class="bi bi-briefcase me-2"></i> Manage Job Offers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white {{ app.request.get('_route') starts with 'app_admin_applications' ? 'active' : '' }}" href="{{ path('app_admin_applications') }}">
                                <i class="bi bi-file-text me-2"></i> Manage Applications
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white {{ app.request.get('_route') == 'app_admin_users' ? 'active' : '' }}" href="{{ path('app_admin_users') }}">
                                <i class="bi bi-people me-2"></i> Manage Users
                            </a>
                        </li>
                        <li class="nav-item">
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white {{ app.request.get('_route') starts with 'app_admin_trainings' ? 'active' : '' }}" href="{{ path('app_admin_trainings') }}">
                                <i class="bi bi-book me-2"></i> Manage Trainings
                            </a>
                        </li>
                    </ul>
                    
                    <!-- Profile & Logout Section -->
                    <div class="mt-4 pt-3 border-top border-light">
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link text-white {{ app.request.get('_route') == 'app_admin_profile' ? 'active' : '' }}" href="{{ path('app_admin_profile') }}">
                                    <i class="bi bi-person-circle me-2"></i> My Profile
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
        
        <!-- Main Content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">{% block admin_page_title %}Admin Dashboard{% endblock %}</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    {% block admin_actions %}{% endblock %}
                </div>
            </div>

            <!-- Flash Messages -->
            {% for flash_message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{ flash_message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}

            {% for flash_message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{ flash_message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}

            {% for flash_message in app.flashes('failure') %}
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    {{ flash_message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}

            <!-- Page Content -->
            {% block admin_content %}{% endblock %}
        </main>
    </div>
</div>

<style>
.sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 100;
    padding: 48px 0 0;
    box-shadow: inset -1px 0 0 rgba(0, 0, 0, .1);
}

.sidebar-heading {
    font-size: .75rem;
    text-transform: uppercase;
}

.sidebar .nav-link {
    font-weight: 500;
    color: #333;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    margin: 0.125rem 0.75rem;
}

.sidebar .nav-link:hover {
    color: #007bff;
    background-color: rgba(0, 123, 255, 0.1);
}

.sidebar .nav-link.active {
    color: #007bff;
    background-color: rgba(0, 123, 255, 0.1);
    font-weight: 600;
}

.sidebar .nav-link.disabled {
    color: #6c757d;
    background-color: transparent;
    cursor: not-allowed;
}

.sidebar .nav-link.disabled:hover {
    color: #6c757d;
    background-color: transparent;
}

.sidebar .nav-link.disabled small {
    font-size: 0.7em;
    display: block;
    margin-top: 2px;
}

.sidebar .nav-link i {
    width: 16px;
    text-align: center;
}

@media (max-width: 767.98px) {
    .sidebar {
        position: relative;
        height: auto;
        padding: 0;
    }
}

main {
    margin-left: 0;
}

@media (min-width: 768px) {
    main {
        margin-left: 240px;
    }
}
</style>
{% endblock %}
