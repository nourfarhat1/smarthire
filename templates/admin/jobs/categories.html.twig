{% extends 'admin/layout.html.twig' %}

{% block title %}Job Categories - SmartHire Admin{% endblock %}

{% block admin_page_title %}Job Categories Management{% endblock %}

{% block admin_content %}
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header admin-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-tags me-2"></i>Job Categories</h5>
                    <button class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                        <i class="bi bi-plus-circle me-1"></i>Add Category
                    </button>
                </div>
            </div>
            <div class="card-body">
                <!-- Flash Messages -->
                {% if app.session.flashbag.has('error') %}
                    {% for message in app.session.flashbag.get('error') %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                {% endif %}
                
                {% if app.session.flashbag.has('success') %}
                    {% for message in app.session.flashbag.get('success') %}
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                {% endif %}
                
                <!-- Search and Filter -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control" id="categorySearch" placeholder="Search categories...">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" id="statusFilter">
                            <option value="">All Status</option>
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" id="sortBy">
                            <option value="name">Sort by Name</option>
                            <option value="jobs">Sort by Job Count</option>
                            <option value="created">Sort by Created Date</option>
                        </select>
                    </div>
                </div>

                <!-- Categories Table -->
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Job Count</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="categoriesTable">
                            {% for category in categories %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="category-icon me-2">
                                            <i class="bi bi-tag-fill text-primary"></i>
                                        </div>
                                        <div>
                                            <strong>{{ category.name }}</strong>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <small class="text-muted">Job category for {{ category.name }} positions</small>
                                </td>
                                <td>
                                    <span class="badge bg-info">{{ category.jobOffers|length }} Jobs</span>
                                </td>
                                <td>
                                    <span class="badge bg-success">Active</span>
                                </td>
                                <td>
                                    <small>N/A</small>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <button type="button" class="btn btn-sm btn-outline-primary edit-category" 
                                                data-id="{{ category.id }}" data-name="{{ category.name }}">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        {% if category.jobOffers|length > 0 %}
                                            <button type="button" class="btn btn-sm btn-outline-warning" 
                                                    data-bs-toggle="modal" data-bs-target="#forceDeleteModal"
                                                    data-id="{{ category.id }}" 
                                                    data-name="{{ category.name }}"
                                                    data-job-count="{{ category.jobOffers|length }}">
                                                <i class="bi bi-exclamation-triangle"></i>
                                            </button>
                                        {% else %}
                                            <form class="d-inline" method="post" 
                                                  action="{{ path('app_admin_job_categories_delete', {'id': category.id}) }}" 
                                                  onsubmit="return confirm('Are you sure you want to delete this category? This action cannot be undone.')">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-4">
                                    <div class="text-muted">
                                        <i class="bi bi-tags" style="font-size: 3rem;"></i>
                                        <p class="mt-2">No job categories found</p>
                                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                                            <i class="bi bi-plus-circle me-1"></i>Add First Category
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                {% if categories|length > 0 %}
                <nav aria-label="Categories pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item disabled">
                            <a class="page-link" href="#" tabindex="-1">Previous</a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                            <a class="page-link" href="#">Next</a>
                        </li>
                    </ul>
                </nav>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row mt-4">
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="text-primary">{{ categories|length }}</h4>
                        <p class="text-muted mb-0">Total Categories</p>
                    </div>
                    <div class="text-primary">
                        <i class="bi bi-tags" style="font-size: 2rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="text-success">{{ categories|length }}</h4>
                        <p class="text-muted mb-0">Active Categories</p>
                    </div>
                    <div class="text-success">
                        <i class="bi bi-check-circle" style="font-size: 2rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="text-info">{{ categories|reduce((sum, c) => sum + c.jobOffers|length, 0) }}</h4>
                        <p class="text-muted mb-0">Total Jobs</p>
                    </div>
                    <div class="text-info">
                        <i class="bi bi-briefcase" style="font-size: 2rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="text-warning">{{ categories|length > 0 ? (categories|reduce((sum, c) => sum + c.jobOffers|length, 0) / categories|length)|round(1) : 0 }}</h4>
                        <p class="text-muted mb-0">Avg Jobs/Category</p>
                    </div>
                    <div class="text-warning">
                        <i class="bi bi-graph-up" style="font-size: 2rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Category Modal -->
<div class="modal fade" id="addCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header admin-primary text-white">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Add New Category</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="{{ path('app_admin_job_categories_add') }}" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="categoryName" class="form-label">Category Name *</label>
                        <input type="text" class="form-control" id="categoryName" name="name" required>
                        <div class="form-text">Enter a descriptive name for the job category</div>
                        {% if app.session.flashbag.has('error') %}
                            {% for message in app.session.flashbag.get('error') %}
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    {{ message }}
                                    {% if 'associated job offer' in message %}
                                        <div class="mt-2">
                                            <form method="post" action="{{ path('app_admin_job_categories_force_delete', {'id': category.id}) }}" onsubmit="return confirm('WARNING: This will permanently delete the category AND all associated job offers and applications. This action cannot be undone. Are you absolutely sure?')">
                                                <button type="submit" class="btn btn-danger btn-sm">
                                                    <i class="bi bi-exclamation-triangle me-1"></i>Force Delete (Removes All Data)
                                                </button>
                                            </form>
                                        </div>
                                    {% endif %}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i>Add Category
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Category Modal -->
<div class="modal fade" id="editCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header admin-primary text-white">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Category</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="editCategoryForm" method="post" action="{{ path('app_admin_job_categories_edit', {'id': 0}) }}">
                <div class="modal-body">
                    <input type="hidden" id="editCategoryId" name="id">
                    <div class="mb-3">
                        <label for="editCategoryName" class="form-label">Category Name *</label>
                        <input type="text" class="form-control" id="editCategoryName" name="name" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Force Delete Modal -->
<div class="modal fade" id="forceDeleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Force Delete Category</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="forceDeleteForm" method="post">
                <div class="modal-body">
                    <input type="hidden" id="forceDeleteCategoryId" name="id">
                    <div class="alert alert-warning">
                        <h6><i class="bi bi-exclamation-triangle me-2"></i>WARNING: This action cannot be undone!</h6>
                        <p class="mb-0">You are about to permanently delete the category <strong id="forceDeleteCategoryName"></strong> and all associated data:</p>
                        <ul class="mt-2">
                            <li><span id="forceDeleteJobCount"></span> job offers</li>
                            <li>All applications for these job offers</li>
                            <li>The category itself</li>
                        </ul>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="confirmForceDelete" required>
                        <label class="form-check-label" for="confirmForceDelete">
                            I understand that this action will permanently delete all data and cannot be undone
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-exclamation-triangle me-1"></i>Force Delete Everything
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.admin-primary {
    background: linear-gradient(135deg, #87a042 0%, #a8c066 100%);
}

.category-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(135, 160, 66, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
}

.card {
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    border: none;
}

.table-hover tbody tr:hover {
    background-color: rgba(135, 160, 66, 0.05);
}

.btn-group .btn {
    border-radius: 0;
}

.btn-group .btn:first-child {
    border-top-left-radius: 0.375rem;
    border-bottom-left-radius: 0.375rem;
}

.btn-group .btn:last-child {
    border-top-right-radius: 0.375rem;
    border-bottom-right-radius: 0.375rem}

.btn-group form {
    display: inline;
    margin: 0;
}

.btn-group form button {
    margin: 0;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log('Categories page loaded');

    // Search functionality
    const searchInput = document.getElementById('categorySearch');
    if (searchInput) {
        searchInput.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#categoriesTable tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });
    }

    // Status filter
    const statusFilter = document.getElementById('statusFilter');
    if (statusFilter) {
        statusFilter.addEventListener('change', function(e) {
            const status = e.target.value;
            const rows = document.querySelectorAll('#categoriesTable tr');
            
            rows.forEach(row => {
                if (!row.dataset.status) return; // Skip header row
                
                if (status === '') {
                    row.style.display = '';
                } else {
                    row.style.display = row.dataset.status === status ? '' : 'none';
                }
            });
        });
    }

    // Sort functionality
    const sortBy = document.getElementById('sortBy');
    if (sortBy) {
        sortBy.addEventListener('change', function(e) {
            const sortValue = e.target.value;
            console.log('Sort by:', sortValue);
        });
    }

    // Edit category functionality
    const editButtons = document.querySelectorAll('.edit-category');
    console.log('Found edit buttons:', editButtons.length);
    
    editButtons.forEach(button => {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            console.log('Edit button clicked');
            
            const categoryId = this.dataset.id;
            const categoryName = this.dataset.name;
            
            console.log('Category ID:', categoryId, 'Name:', categoryName);
            
            // Populate the edit form
            const editIdInput = document.getElementById('editCategoryId');
            const editNameInput = document.getElementById('editCategoryName');
            const editForm = document.getElementById('editCategoryForm');
            
            if (editIdInput && editNameInput && editForm) {
                editIdInput.value = categoryId;
                editNameInput.value = categoryName;
                
                // Set the form action using the correct path
                editForm.action = editForm.action.replace(/\/edit\/\d+/, '/edit/' + categoryId);
                if (!editForm.action.includes('/edit/')) {
                    editForm.action = '/admin/jobs/categories/edit/' + categoryId;
                }
                
                console.log('Edit form action:', editForm.action);
                
                // Show the modal
                const modal = new bootstrap.Modal(document.getElementById('editCategoryModal'));
                modal.show();
            } else {
                console.error('Edit form elements not found');
            }
        });
    });

    // Handle edit form submission
    const editForm = document.getElementById('editCategoryForm');
    if (editForm) {
        editForm.addEventListener('submit', function(e) {
            console.log('Edit form submitted');
            // Let the form submit normally to the backend
        });
    }

    // Force delete modal functionality
    const forceDeleteModal = document.getElementById('forceDeleteModal');
    if (forceDeleteModal) {
        forceDeleteModal.addEventListener('show.bs.modal', function(e) {
            const button = e.relatedTarget;
            const categoryId = button.dataset.id;
            const categoryName = button.dataset.name;
            const jobCount = button.dataset.jobCount;
            
            // Populate the modal
            document.getElementById('forceDeleteCategoryId').value = categoryId;
            document.getElementById('forceDeleteCategoryName').textContent = categoryName;
            document.getElementById('forceDeleteJobCount').textContent = jobCount;
            
            // Set the form action
            document.getElementById('forceDeleteForm').action = '/admin/jobs/categories/force-delete/' + categoryId;
        });
    }
});
</script>
{% endblock %}
