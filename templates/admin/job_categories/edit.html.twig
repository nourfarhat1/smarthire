{% extends 'admin/layout.html.twig' %}

{% block title %}Edit Job Category - SmartHire Admin{% endblock %}

{% block admin_page_title %}Edit Job Category{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Edit Job Category</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <a href="{{ path('app_admin_job_categories') }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Categories
            </a>
        </div>
    </div>
</div>

{% for flash in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ flash }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% for flash in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ flash }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Edit Job Category</h5>
            </div>
            <div class="card-body">
                <form method="POST" action="{{ path('app_admin_job_categories_edit', {'id': category.id}) }}">
                    <div class="mb-3">
                        <label for="name" class="form-label">Category Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="name" name="name" 
                               value="{{ category.name }}" placeholder="e.g. Technology, Healthcare, Finance" required>
                        <div class="form-text">Update the name for this job category.</div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Warning:</strong>
                        <p class="mb-0 mt-2">
                            Changing the category name may affect existing job offers that use this category. 
                            Make sure to update any related documentation if necessary.
                        </p>
                    </div>

                    <div class="d-flex justify-content-between">
                        <div>
                            <a href="{{ path('app_admin_job_categories') }}" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                        </div>
                        <div>
                            <form method="POST" action="{{ path('app_admin_job_categories_delete', {'id': category.id}) }}" class="d-inline" 
                                  onsubmit="return confirm('Are you sure you want to delete this job category? This action cannot be undone.')">
                                <button type="submit" class="btn btn-danger me-2">
                                    <i class="bi bi-trash me-2"></i>Delete Category
                                </button>
                            </form>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save me-2"></i>Update Category
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Category Information</h6>
            </div>
            <div class="card-body">
                <p class="mb-2"><strong>Category ID:</strong> {{ category.id }}</p>
                <p class="mb-2"><strong>Current Name:</strong> {{ category.name }}</p>
                <p class="mb-2"><strong>Job Offers:</strong> {{ category.jobOffers|length }}</p>
                <p class="mb-0"><strong>Status:</strong> <span class="badge bg-success">Active</span></p>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h6 class="mb-0">Edit Guidelines</h6>
            </div>
            <div class="card-body">
                <h6>What You Can Edit</h6>
                <ul class="small">
                    <li>Category name (must be unique)</li>
                </ul>

                <hr>

                <h6>Impact of Changes</h6>
                <ul class="small mb-0">
                    <li>Name changes affect existing job offers</li>
                    <li>Changes are immediately visible</li>
                    <li>Categories with job offers cannot be deleted</li>
                </ul>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h6 class="mb-0">Danger Zone</h6>
            </div>
            <div class="card-body">
                <p class="small mb-3">
                    Deleting this job category will permanently remove it from the system. 
                    Categories with associated job offers cannot be deleted.
                </p>
                <form method="POST" action="{{ path('app_admin_job_categories_delete', {'id': category.id}) }}" 
                      onsubmit="return confirm('Are you sure you want to delete this job category? This action cannot be undone.')">
                    <button type="submit" class="btn btn-danger w-100" {% if category.jobOffers|length > 0 %}disabled{% endif %}>
                        <i class="bi bi-trash me-2"></i>Delete Job Category
                        {% if category.jobOffers|length > 0 %}
                            <br><small>Cannot delete ({{ category.jobOffers|length }} job offers)</small>
                        {% endif %}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
