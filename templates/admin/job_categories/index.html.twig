{% extends 'admin/layout.html.twig' %}

{% block title %}Job Categories - SmartHire Admin{% endblock %}

{% block admin_page_title %}Job Categories{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Job Categories</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <a href="{{ path('app_admin_job_categories_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Add New Category
            </a>
        </div>
    </div>
</div>

{% for flash in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ flash }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% for flash in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ flash }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Manage Job Categories</h5>
    </div>
    <div class="card-body">
        {% if categories|length > 0 %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Job Offers Count</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for category in categories %}
                    <tr>
                        <td>{{ category.id }}</td>
                        <td>
                            <strong>{{ category.name }}</strong>
                        </td>
                        <td>
                            <span class="badge bg-primary">{{ category.jobOffers|length }}</span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_admin_job_categories_edit', {'id': category.id}) }}" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form method="POST" action="{{ path('app_admin_job_categories_delete', {'id': category.id}) }}" class="d-inline" 
                                      onsubmit="return confirm('Are you sure you want to delete this category?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
            <div class="text-center py-5">
                <i class="bi bi-tags fs-1 text-muted mb-3"></i>
                <h5 class="text-muted">No job categories found</h5>
                <p class="text-muted">
                    No job categories have been created yet. 
                    <a href="{{ path('app_admin_job_categories_new') }}">Add the first job category</a> to get started.
                </p>
            </div>
        {% endif %}
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Statistics</h6>
            </div>
            <div class="card-body">
                <p class="mb-2"><strong>Total Categories:</strong> {{ categories|length }}</p>
                <p class="mb-0"><strong>Total Job Offers:</strong> {{ categories|reduce((sum, cat) => sum + cat.jobOffers|length, 0) }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('app_admin_job_categories_new') }}" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i> Add New Category
                    </a>
                    <a href="{{ path('app_admin_dashboard') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
