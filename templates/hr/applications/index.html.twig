{% extends 'base.html.twig' %}

{% block title %}Applications Management - HR - SmartHire{% endblock %}

{% block page_title %}Application Management{% endblock %}

{% block page_actions %}
<a href="{{ path('app_hr_applications_dashboard') }}" class="btn btn-info">
    <i class="bi bi-graph-up me-2"></i>Dashboard
</a>
{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12">
        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="text-primary">{{ totalApplications }}</h3>
                        <p class="text-muted">Total Applications</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="text-warning">{{ pendingCount }}</h3>
                        <p class="text-muted">Pending Review</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="text-success">{{ approvedCount }}</h3>
                        <p class="text-muted">Approved</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h3 class="text-info">{{ interviewCount }}</h3>
                        <p class="text-muted">Interviews Scheduled</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter Section -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-funnel me-2"></i>Filter Applications
                </h5>
            </div>
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-3">
                        <label for="status" class="form-label">Status</label>
                        <select name="status" id="status" class="form-select">
                            <option value="">All Status</option>
                            <option value="PENDING" {{ app.request.query.get('status') == 'PENDING' ? 'selected' : '' }}>Pending</option>
                            <option value="APPROVED" {{ app.request.query.get('status') == 'APPROVED' ? 'selected' : '' }}>Approved</option>
                            <option value="REJECTED" {{ app.request.query.get('status') == 'REJECTED' ? 'selected' : '' }}>Rejected</option>
                            <option value="INTERVIEW_SCHEDULED" {{ app.request.query.get('status') == 'INTERVIEW_SCHEDULED' ? 'selected' : '' }}>Interview Scheduled</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="date_from" class="form-label">From Date</label>
                        <input type="date" name="date_from" id="date_from" class="form-control" 
                               value="{{ app.request.query.get('date_from') }}">
                    </div>
                    <div class="col-md-3">
                        <label for="date_to" class="form-label">To Date</label>
                        <input type="date" name="date_to" id="date_to" class="form-control" 
                               value="{{ app.request.query.get('date_to') }}">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">&nbsp;</label>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-funnel me-2"></i>Apply Filters
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Applications Table -->
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="bi bi-file-text me-2"></i>Job Applications
                </h4>
            </div>
            <div class="card-body">
                {% if applications|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Candidate</th>
                                <th>Job Title</th>
                                <th>Applied Date</th>
                                <th>Status</th>
                                <th>Interview</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for application in applications %}
                            <tr>
                                <td>
                                    <strong>{{ application.candidateName|default('N/A') }}</strong>
                                    <br>
                                    <small class="text-muted">{{ application.candidateEmail|default('N/A') }}</small>
                                </td>
                                <td>{{ application.jobTitle|default('N/A') }}</td>
                                <td>{{ application.submissionDate|date('M j, Y') }}</td>
                                <td>
                                    <span class="badge bg-{{ application.status == 'APPROVED' ? 'success' : application.status == 'REJECTED' ? 'danger' : application.status == 'INTERVIEW_SCHEDULED' ? 'info' : 'warning' }}">
                                        {{ application.status|replace({'_':' '})|title }}
                                    </span>
                                </td>
                                <td>
                                    {% if application.interviews|length > 0 %}
                                        <span class="badge bg-info">
                                            <i class="bi bi-calendar-check"></i> Scheduled
                                        </span>
                                        {% else %}
                                        <span class="text-muted">-</span>
                                        {% endif %}
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('app_hr_applications_show', {'id': application.id}) }}" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        {% if application.status == 'PENDING' %}
                                        <a href="{{ path('app_hr_applications_schedule_interview', {'id': application.id}) }}" 
                                           class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-calendar-plus"></i>
                                        </a>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="text-center py-5">
                    <i class="bi bi-file-x fs-1 text-muted"></i>
                    <h4 class="text-muted">No Applications Found</h4>
                    <p class="text-muted">No job applications match your current filters.</p>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
