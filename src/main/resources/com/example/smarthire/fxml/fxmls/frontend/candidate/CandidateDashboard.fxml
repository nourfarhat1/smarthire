<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" style="-fx-background-color: #f4f7f6;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.smarthire.controllers.candidate.CandidateDashboardController">

    <Label layoutX="30.0" layoutY="30.0" text="Candidate Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2f4188;" />

    <HBox layoutX="30.0" layoutY="80.0" spacing="20.0">
        <VBox prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0); -fx-padding: 20;">
            <Label text="Jobs Applied" textFill="#888" />
            <Label text="12" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        </VBox>
        <VBox prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0); -fx-padding: 20;">
            <Label text="Interviews" textFill="#888" />
            <Label text="2" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e91e63;" />
        </VBox>
    </HBox>
</AnchorPane>