<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.smarthire.controllers.application.SpontaneousAppFormController"
      style="-fx-padding: 20;">

    <Label text="New Spontaneous Application"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <!-- Job Title -->
    <Label text="Job Title:"/>
    <TextField fx:id="jobTitleField" promptText="Enter job title"/>

    <Label text="Category:"/>
    <TextField fx:id="categorieField" promptText="Enter job title"/>

    <!-- Location (Optional) -->
    <Label text="Location (optional):"/>
    <TextField fx:id="locationField" promptText="Enter location (optional)"/>


    <!-- Suggested Salary (Optional) -->
    <Label text="Suggested Salary (optional):"/>
    <HBox spacing="10">
        <TextField fx:id="salaryField" promptText="Enter suggested salary (optional)"/>
        <Button text="Generate Salary" onAction="#handleGenerateSalary"/>
    </HBox>

    <TextField fx:id="cvField" prefWidth="300" editable="false"/>
    <Button text="Upload CV" onAction="#handleUploadCV"/>

    <!-- Cover Letter -->
    <Label text="Cover Letter:"/>
    <TextArea fx:id="letterArea" promptText="Why do you want to join us?" prefRowCount="5"/>

    <!-- Generate Cover Letter Button -->
    <Button text="Generate Cover Letter" onAction="#handleGenerateCoverLetter"
            style="-fx-background-color: #2f4188; -fx-text-fill: white;"/>
    <!-- Buttons -->
    <HBox spacing="10">
        <Button text="Create" onAction="#handleCreate"
                style="-fx-background-color: #2f4188; -fx-text-fill: white;"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>

</VBox>