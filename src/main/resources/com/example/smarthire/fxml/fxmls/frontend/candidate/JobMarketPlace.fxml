<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="850.0" style="-fx-background-color: #f4f4f4;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.smarthire.controllers.application.JobMarketplaceController">

    <HBox alignment="CENTER_LEFT" layoutX="30.0" layoutY="20.0" prefWidth="790.0" spacing="450">
        <Label text="Job Market Place"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2f4188;" />

        <Button fx:id="btnSavedJobs" text="⭐ My Saved Jobs" onAction="#goToSavedJobs"
                style="-fx-background-color: white; -fx-border-color: #2f4188; -fx-border-radius: 20; -fx-background-radius: 20; -fx-text-fill: #2f4188; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 5 15 5 15;"/>
    </HBox>

    <ListView fx:id="jobListView" layoutX="30.0" layoutY="80.0" prefHeight="490.0" prefWidth="790.0"
              style="-fx-background-color: transparent;" />

    <StackPane mouseTransparent="true" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <children>
            <Label fx:id="toastLabel" visible="false" opacity="0.0"
                   text="Job Saved!"
                   style="-fx-background-color: #2f4188; -fx-text-fill: white; -fx-padding: 10 25;
                          -fx-background-radius: 30; -fx-font-size: 14px; -fx-font-weight: bold;
                          -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);" />
        </children>
    </StackPane>

</AnchorPane>