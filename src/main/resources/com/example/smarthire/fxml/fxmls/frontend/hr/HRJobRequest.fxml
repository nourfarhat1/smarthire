<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="850.0" style="-fx-background-color: #f4f4f4;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.smarthire.controllers.application.HRJobRequestController">

    <Label text="Job Requests" layoutX="30.0" layoutY="20.0"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2f4188;" />

    <ListView fx:id="appListView" layoutX="30.0" layoutY="70.0" prefHeight="500.0" prefWidth="790.0"
              style="-fx-background-color: transparent;" />
    <!-- Search Field -->
    <TextField fx:id="searchField" layoutX="30.0" layoutY="60.0" prefWidth="300.0" promptText="Search by job title or candidate..." />

</AnchorPane>