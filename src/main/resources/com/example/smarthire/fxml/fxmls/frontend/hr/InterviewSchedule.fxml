<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane dividerPositions="0.4" prefHeight="600.0" prefWidth="900.0"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.smarthire.controllers.job.InterviewScheduleController">

    <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #f4f4f4;">
        <Label text="Job Requests" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2f4188;"/>
        <Label text="Select a candidate to schedule" style="-fx-text-fill: #666;"/>

        <TableView fx:id="requestTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCandidate" text="Candidate" prefWidth="120"/>
                <TableColumn fx:id="colJobTitle" text="Job Title" prefWidth="130"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <VBox fx:id="formContainer" spacing="15" style="-fx-padding: 30; -fx-background-color: white;">
        <Label text="Schedule Interview" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

        <HBox spacing="10" style="-fx-background-color: #eef2ff; -fx-padding: 15; -fx-background-radius: 5;">
            <VBox>
                <Label text="Candidate Name" style="-fx-font-size: 10px; -fx-text-fill: #888;"/>
                <Label fx:id="selectedCandidateLabel" text="-" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            </VBox>
            <Separator orientation="VERTICAL"/>
            <VBox>
                <Label text="Applying For" style="-fx-font-size: 10px; -fx-text-fill: #888;"/>
                <Label fx:id="selectedJobLabel" text="-" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <Separator/>

        <GridPane vgap="15" hgap="10">
            <Label text="Date:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <DatePicker fx:id="datePicker" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Time:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="timeField" promptText="14:00" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Location:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="locationField" promptText="Room 302 / Google Meet" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Notes:" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
            <TextArea fx:id="notesArea" prefRowCount="4" promptText="Internal notes..." GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </GridPane>

        <Region VBox.vgrow="ALWAYS"/> <Button fx:id="btnSave" text="Confirm Schedule" onAction="#handleSaveInterview"
                                              maxWidth="Infinity" style="-fx-background-color: #2f4188; -fx-text-fill: white; -fx-padding: 12; -fx-font-size: 14px;"/>
    </VBox>

</SplitPane>