<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@../../../css/mainstyle.css" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.smarthire.controllers.test.AdminQuizController">
    <children>
        <VBox spacing="12.0" AnchorPane.topAnchor="15.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="15.0">
            <Label text="Quiz Management" styleClass="header-label" />

            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search by title or description..." prefWidth="300.0" styleClass="text-field" />
                <Button text="Search" onAction="#handleSearch" styleClass="button, button-primary" />
                <Button text="Show All" onAction="#handleShowAll" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="✨ Generate with AI" onAction="#handleGenerateAI" style="-fx-background-color: #2f4188; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 13px;" />
            </HBox>

            <ListView fx:id="quizListView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;" />

            <HBox spacing="10.0">
                <Button text="Delete Selected" onAction="#handleDelete" styleClass="button, button-secondary" />
                <Button text="View Results" onAction="#handleViewResults" styleClass="button, button-primary" />
            </HBox>
            <Label fx:id="statusLabel" style="-fx-font-size: 12px;" />
        </VBox>
    </children>
</AnchorPane>
