<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@../../../../css/mainstyle.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.smarthire.controllers.test.QuizController">
    <children>
        <TabPane prefHeight="600.0" prefWidth="800.0" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <tabs>
                <Tab text="My Quizzes">
                    <AnchorPane style="-fx-background-color: #f4f7f6;">
                        <children>
                            <Label layoutX="20.0" layoutY="15.0" text="My Quizzes" styleClass="header-label" />
                            <HBox layoutX="20.0" layoutY="42.0" spacing="10.0" alignment="CENTER_LEFT" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">
                                <TextField fx:id="quizSearchField" promptText="Search by title or description..." prefWidth="300" styleClass="text-field"/>
                                <Button text="Clear" onAction="#handleClearSearch" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 8 16; -fx-cursor: hand;"/>                                    <Region HBox.hgrow="ALWAYS" />
                                <Button text="✨ Generate with AI" onAction="#handleGenerateAI" style="-fx-background-color: #2f4188; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 12px;" />                            </HBox>
                            <ListView fx:id="quizListView" layoutX="20.0" layoutY="80.0" prefWidth="740.0" prefHeight="400.0" style="-fx-background-color: transparent;" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="80.0" AnchorPane.bottomAnchor="60.0" />
                            <HBox spacing="10.0" AnchorPane.leftAnchor="20.0" AnchorPane.bottomAnchor="15.0">
                                <Button fx:id="btnEdit" text="Edit Selected" onAction="#handleEditQuiz" styleClass="button, button-primary" minWidth="120" />
                                <Button fx:id="btnDelete" text="Delete Selected" onAction="#handleDelete" styleClass="button, button-secondary" minWidth="130" />
                                <Button text="Add Questions" onAction="#handleViewQuestions" styleClass="button, button-success" minWidth="130" />
                                <Button text="View Results" onAction="#handleViewResults" styleClass="button, button-primary" minWidth="110" />
                                <Button text="Refresh" onAction="#handleRefresh" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-cursor: hand; -fx-padding: 10 20;" />
                            </HBox>
                            <Label fx:id="statusLabel" style="-fx-font-size: 12px; -fx-font-weight: bold;" AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0" />
                        </children>
                    </AnchorPane>
                </Tab>

                <Tab text="Create Quiz">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: #f4f7f6;">
                        <VBox spacing="12.0" style="-fx-padding: 30;">
                            <Label text="Create New Quiz" styleClass="header-label" />

                            <VBox spacing="6.0" styleClass="card">
                                <Label text="Quiz Title" styleClass="sub-header" />
                                <TextField fx:id="titleField" promptText="e.g. Java Spring Boot Basics" styleClass="text-field" />
                                <Label fx:id="titleError" textFill="RED" style="-fx-font-size: 11px;" />

                                <Label text="Description" style="-fx-text-fill: #555; -fx-font-weight: bold;" />
                                <TextArea fx:id="descriptionField" promptText="Describe the quiz purpose..." prefRowCount="3" />
                                <Label fx:id="descriptionError" textFill="RED" style="-fx-font-size: 11px;" />

                                <HBox spacing="20.0">
                                    <VBox spacing="4.0">
                                        <Label text="Duration (Minutes)" style="-fx-text-fill: #555; -fx-font-weight: bold;" />
                                        <TextField fx:id="durationField" promptText="e.g. 30" prefWidth="150.0" styleClass="text-field" />
                                        <Label fx:id="durationError" textFill="RED" style="-fx-font-size: 11px;" />
                                    </VBox>
                                    <VBox spacing="4.0">
                                        <Label text="Passing Score" style="-fx-text-fill: #555; -fx-font-weight: bold;" />
                                        <TextField fx:id="passingScoreField" promptText="e.g. 70" prefWidth="150.0" styleClass="text-field" />
                                        <Label fx:id="passingScoreError" textFill="RED" style="-fx-font-size: 11px;" />
                                    </VBox>
                                </HBox>

                                <Label text="Related Job Offer (Optional)" style="-fx-text-fill: #555; -fx-font-weight: bold;" />
                                <ComboBox fx:id="jobCombo" promptText="Select a job offer" prefWidth="400.0" />

                                <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                                    <Button fx:id="btnAdd" text="Save Quiz" onAction="#handleAdd" styleClass="button, button-success" minWidth="100" />
                                    <Button fx:id="btnUpdate" text="Update Quiz" onAction="#handleUpdate" styleClass="button, button-primary" minWidth="110" />
                                    <Button text="Clear" onAction="#handleClear" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-cursor: hand; -fx-padding: 10 20;" />
                                </HBox>
                                <Label fx:id="createStatusLabel" style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                            </VBox>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab fx:id="questionsTab" text="Manage Questions">
                    <AnchorPane style="-fx-background-color: #f4f7f6;">
                        <children>
                            <ScrollPane fitToWidth="true" fitToHeight="true" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" style="-fx-background-color: transparent;">
                                <HBox spacing="20.0" style="-fx-padding: 25;">
                                    <VBox spacing="6.0" prefWidth="440.0" minWidth="440.0" styleClass="card">
                                        <Label text="Add / Edit Question" styleClass="sub-header" />

                                        <Label text="Question Text" style="-fx-text-fill: #555; -fx-font-weight: bold;" />
                                        <TextArea fx:id="questionTextField" promptText="Enter the question..." prefRowCount="2" />
                                        <Label fx:id="questionTextError" textFill="RED" style="-fx-font-size: 11px;" />

                                        <HBox spacing="15.0">
                                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                <Label text="Option A" style="-fx-text-fill: #555; -fx-font-weight: bold;" />
                                                <TextField fx:id="optionAField" promptText="Option A" styleClass="text-field" />
                                                <Label fx:id="optionAError" textFill="RED" style="-fx-font-size: 11px;" />
                                            </VBox>
                                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                <Label text="Option B" style="-fx-text-fill: #555; -fx-font-weight: bold;" />
                                                <TextField fx:id="optionBField" promptText="Option B" styleClass="text-field" />
                                                <Label fx:id="optionBError" textFill="RED" style="-fx-font-size: 11px;" />
                                            </VBox>
                                        </HBox>

                                        <HBox spacing="15.0">
                                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                <Label text="Option C" style="-fx-text-fill: #555; -fx-font-weight: bold;" />
                                                <TextField fx:id="optionCField" promptText="Option C" styleClass="text-field" />
                                                <Label fx:id="optionCError" textFill="RED" style="-fx-font-size: 11px;" />
                                            </VBox>
                                            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                <Label text="Correct Answer" style="-fx-text-fill: #555; -fx-font-weight: bold;" />
                                                <ComboBox fx:id="correctAnswerCombo" promptText="Select" prefWidth="200.0" maxWidth="1.7976931348623157E308" />
                                                <Label fx:id="correctAnswerError" textFill="RED" style="-fx-font-size: 11px;" />
                                            </VBox>
                                        </HBox>

                                        <HBox spacing="10.0" style="-fx-padding: 8 0 0 0;">
                                            <Button fx:id="btnAddQ" text="Add Question" onAction="#handleAddQuestion" styleClass="button, button-success" minWidth="120" />
                                            <Button fx:id="btnUpdateQ" text="Update" onAction="#handleUpdateQuestion" styleClass="button, button-primary" minWidth="80" />
                                            <Button fx:id="btnDeleteQ" text="Delete" onAction="#handleDeleteQuestion" styleClass="button, button-secondary" minWidth="80" />
                                            <Button text="Clear" onAction="#handleClearQuestion" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-cursor: hand; -fx-padding: 10 20;" minWidth="70" />
                                        </HBox>
                                        <Label fx:id="questionStatusLabel" style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                                    </VBox>

                                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                        <Label fx:id="questionsForLabel" text="Questions" styleClass="sub-header" />
                                        <ListView fx:id="questionListView" VBox.vgrow="ALWAYS" prefHeight="500.0" style="-fx-background-color: transparent;" />
                                    </VBox>
                                </HBox>
                            </ScrollPane>
                        </children>
                    </AnchorPane>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</AnchorPane>
