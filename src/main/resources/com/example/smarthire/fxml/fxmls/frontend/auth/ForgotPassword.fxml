<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            style="-fx-background-color: #f4f7f6;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.smarthire.controllers.auth.ForgotPasswordController">

    <!-- Left blue panel matching Login.fxml -->
    <AnchorPane prefHeight="600.0" prefWidth="400.0"
                style="-fx-background-color: #2f4188;">
        <Label layoutX="80.0" layoutY="230.0" text="SmartHire"
               textFill="WHITE"
               style="-fx-font-size: 40px; -fx-font-weight: bold;" />
        <Label layoutX="80.0" layoutY="285.0" text="Reset your password."
               textFill="#87a042"
               style="-fx-font-size: 18px;" />
        <Label layoutX="80.0" layoutY="320.0"
               text="We'll send you a code&#10;to verify your identity."
               textFill="WHITE"
               style="-fx-font-size: 13px;"
               wrapText="true" prefWidth="240.0"/>
    </AnchorPane>

    <!-- Right side — all stages in one VBox, shown/hidden dynamically -->
    <VBox fx:id="mainPanel" alignment="CENTER_LEFT"
          layoutX="450.0" layoutY="60.0"
          prefWidth="300.0" spacing="15.0">

        <Label text="Forgot Password" textFill="#2f4188"
               style="-fx-font-size: 26px; -fx-font-weight: bold;" />

        <!-- STAGE 1: Choose method -->
        <VBox fx:id="stageChoose" spacing="12.0">
            <Label text="How would you like to reset your password?"
                   wrapText="true" prefWidth="300.0"
                   style="-fx-text-fill: #666; -fx-font-size: 13px;" />

            <Button text="📱  Reset via SMS"
                    onAction="#handleChooseSms"
                    maxWidth="Infinity"
                    style="-fx-background-color: #2f4188; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 12;
                           -fx-background-radius: 5; -fx-cursor: hand;
                           -fx-font-size: 13px;" />

            <Button text="✉  Reset via Email"
                    onAction="#handleChooseEmail"
                    maxWidth="Infinity"
                    style="-fx-background-color: #4686c2; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 12;
                           -fx-background-radius: 5; -fx-cursor: hand;
                           -fx-font-size: 13px;" />
        </VBox>

        <!-- STAGE 2: Enter contact info + send OTP -->
        <VBox fx:id="stageSend" spacing="12.0"
              visible="false" managed="false">

            <Label fx:id="sendInstructionLabel"
                   text="Enter your phone number:"
                   wrapText="true" prefWidth="300.0"
                   style="-fx-text-fill: #666; -fx-font-size: 13px;" />

            <TextField fx:id="contactField"
                       promptText="Enter here..."
                       style="-fx-background-color: white; -fx-border-color: #d1d1d1;
                              -fx-border-radius: 5; -fx-padding: 10;" />

            <Button fx:id="sendOtpBtn" text="Send Code"
                    onAction="#handleSendOtp"
                    maxWidth="Infinity"
                    style="-fx-background-color: #e91e63; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10;
                           -fx-background-radius: 5; -fx-cursor: hand;" />

            <Label fx:id="sendStatusLabel" text=""
                   wrapText="true" prefWidth="300.0"
                   style="-fx-font-size: 12px;" />
        </VBox>

        <!-- STAGE 3: Enter OTP code -->
        <VBox fx:id="stageOtp" spacing="12.0"
              visible="false" managed="false">

            <Label fx:id="otpInstructionLabel"
                   text="Enter the 6-digit code we sent you:"
                   wrapText="true" prefWidth="300.0"
                   style="-fx-text-fill: #666; -fx-font-size: 13px;" />

            <TextField fx:id="otpField"
                       promptText="6-digit code"
                       style="-fx-background-color: white; -fx-border-color: #d1d1d1;
                              -fx-border-radius: 5; -fx-padding: 10;
                              -fx-font-size: 18px; -fx-alignment: center;" />

            <Button text="Verify Code"
                    onAction="#handleVerifyOtp"
                    maxWidth="Infinity"
                    style="-fx-background-color: #87a042; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10;
                           -fx-background-radius: 5; -fx-cursor: hand;" />

            <Label fx:id="otpStatusLabel" text=""
                   wrapText="true" prefWidth="300.0"
                   style="-fx-font-size: 12px;" />
        </VBox>

        <!-- STAGE 4: Set new password -->
        <VBox fx:id="stageReset" spacing="12.0"
              visible="false" managed="false">

            <Label text="Set your new password:"
                   style="-fx-text-fill: #666; -fx-font-size: 13px;" />

            <PasswordField fx:id="newPassField"
                           promptText="New Password"
                           style="-fx-background-color: white; -fx-border-color: #d1d1d1;
                                  -fx-border-radius: 5; -fx-padding: 10;" />

            <PasswordField fx:id="confirmPassField"
                           promptText="Confirm New Password"
                           style="-fx-background-color: white; -fx-border-color: #d1d1d1;
                                  -fx-border-radius: 5; -fx-padding: 10;" />

            <Button text="Reset Password"
                    onAction="#handleResetPassword"
                    maxWidth="Infinity"
                    style="-fx-background-color: #e91e63; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10;
                           -fx-background-radius: 5; -fx-cursor: hand;" />

            <Label fx:id="resetStatusLabel" text=""
                   wrapText="true" prefWidth="300.0"
                   style="-fx-font-size: 12px;" />
        </VBox>

        <!-- Always visible at bottom -->
        <Hyperlink text="Back to Login"
                   onAction="#goToLogin"
                   textFill="#4686c2" />

    </VBox>

</AnchorPane>