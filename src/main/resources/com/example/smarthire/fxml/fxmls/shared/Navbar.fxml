<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="1000.0"
      style="-fx-background-color: white; -fx-padding: 0 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 3);"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.smarthire.controllers.user.TopNavBarController">

    <Label fx:id="welcomeLabel" text="Welcome back" style="-fx-text-fill: #666; -fx-font-size: 14px;" />
    <Region HBox.hgrow="ALWAYS" />

    <Button fx:id="profileBtn" onAction="#handleGoToProfile" text="User Profile"
            style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-text-fill: #2f4188; -fx-cursor: hand; -fx-border-color: #2f4188; -fx-border-radius: 5;" />
</HBox>