<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.Color?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.smarthire.controllers.event.AdminEventController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Event Dashboard" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #1E293B;" />
                                <Label text="Manage and monitor all corporate events" style="-fx-font-size: 14px; -fx-text-fill: #64748B;" />
                            </children>
                        </VBox>
                        <Button onAction="#showStatistics" text="📊 Analytics"
                                style="-fx-background-color: #6366F1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12;">
                    <children>
                        <TextField fx:id="searchField" promptText="Search events..." prefWidth="300.0"
                                   style="-fx-background-color: #F1F5F9; -fx-border-color: transparent; -fx-background-radius: 8; -fx-padding: 10;" />

                        <Button onAction="#handleSearch" text="Search"
                                style="-fx-background-color: #1E293B; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;" />

                        <Region HBox.hgrow="ALWAYS" />

                        <MenuButton text="Filter By" style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8;">
                            <items>
                                <MenuItem text="Name (A-Z)" onAction="#sortByName" />
                                <MenuItem text="Recent First" onAction="#sortByDate" />
                                <MenuItem text="Max Capacity" onAction="#sortByCapacity" />
                            </items>
                        </MenuButton>
                    </children>
                    <effect>
                        <DropShadow blurType="THREE_PASS_BOX" color="#0000000a" height="10.0" radius="4.5" width="10.0" />
                    </effect>
                </HBox>

                <TableView fx:id="eventTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #E2E8F0; -fx-padding: 5;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="60.0" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colName" text="Event Name" prefWidth="250.0" />
                        <TableColumn fx:id="colHrId" text="HR Organizer" prefWidth="130.0" />
                        <TableColumn fx:id="colDate" text="Date" prefWidth="150.0" />
                        <TableColumn fx:id="colLocation" text="Location" prefWidth="180.0" />
                        <TableColumn fx:id="colMax" text="Capacity" prefWidth="120.0" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button onAction="#loadEvents" text="↻ Refresh"
                                style="-fx-background-color: white; -fx-text-fill: #475569; -fx-border-color: #CBD5E1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-weight: bold; -fx-padding: 12 25; -fx-cursor: hand;" />
                        <Button onAction="#handleDeleteEvent" text="Delete Event"
                                style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8; -fx-cursor: hand;" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>