<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #F4F7F6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.smarthire.controllers.admin.StatsDashboardController">
    <children>
        <Label layoutX="30.0" layoutY="20.0" text="System Statistics" textFill="#2b32b2" style="-fx-font-size: 24px; -fx-font-weight: bold;" />

        <HBox layoutX="30.0" layoutY="70.0" spacing="20.0">
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2); -fx-padding: 15;" prefWidth="200">
                <Label text="Total Users" textFill="#777" />
                <Label text="1,245" textFill="#2b32b2" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
            </VBox>
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2); -fx-padding: 15;" prefWidth="200">
                <Label text="Active Jobs" textFill="#777" />
                <Label text="54" textFill="#E91E63" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
            </VBox>
        </HBox>

        <HBox layoutX="30.0" layoutY="200.0" spacing="20.0" prefHeight="350.0" prefWidth="740.0">
            <BarChart title="Applications per Job" style="-fx-background-color: white; -fx-background-radius: 10;">
                <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                <yAxis><NumberAxis side="LEFT" /></yAxis>
            </BarChart>
            <PieChart title="Reclamation Status" style="-fx-background-color: white; -fx-background-radius: 10;" />
        </HBox>
    </children>
</AnchorPane>