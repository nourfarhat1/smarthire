<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane prefHeight="650.0" prefWidth="950.0" style="-fx-background-color: #F4F7F6; -fx-font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.smarthire.controllers.reclamation.AdminTypeController">

    <top>
        <VBox spacing="5.0" style="-fx-padding: 35 40 25 40;">
            <Label text="Reclamation Categories" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #1E293B;" />
            <Label text="Manage and configure category types and their urgency levels" style="-fx-font-size: 14px; -fx-text-fill: #64748B;" />
        </VBox>
    </top>

    <center>
        <HBox spacing="30.0" style="-fx-padding: 0 40 40 40;">

            <VBox spacing="15.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 15, 0, 0, 4); -fx-padding: 25;">
                <Label text="Existing Categories" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #334155;" />

                <ListView fx:id="typeListView" VBox.vgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-control-inner-background: #F8FAFC; -fx-padding: 5; -fx-font-size: 14px; -fx-text-inner-color: black;" />
            </VBox>

            <VBox spacing="25.0" prefWidth="380.0" minWidth="380.0" maxWidth="380.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 15, 0, 0, 4); -fx-padding: 30;">

                <Label text="Category Details" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #2f4188;" />

                <VBox spacing="20.0">
                    <VBox spacing="8.0">
                        <Label text="CATEGORY NAME" style="-fx-font-size: 11px; -fx-font-weight: 800; -fx-text-fill: #94A3B8; -fx-letter-spacing: 1px;" />
                        <TextField fx:id="nameField" promptText="e.g. Technical Bug" style="-fx-padding: 12; -fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: black; -fx-font-size: 14px;" />
                    </VBox>

                    <VBox spacing="8.0">
                        <Label text="URGENCY LEVEL" style="-fx-font-size: 11px; -fx-font-weight: 800; -fx-text-fill: #94A3B8; -fx-letter-spacing: 1px;" />
                        <ComboBox fx:id="urgencyComboBox" promptText="Select Urgency" maxWidth="Infinity" style="-fx-padding: 8; -fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 14px; -fx-text-base-color: black;" />
                    </VBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="12.0">
                    <Button onAction="#handleSave" text="Save Category" maxWidth="Infinity" style="-fx-background-color: #2f4188; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 700; -fx-padding: 12; -fx-background-radius: 6; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(47,65,136,0.3), 8, 0, 0, 3);" />

                    <Button onAction="#handleClear" text="Clear Selection" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #CBD5E1; -fx-text-fill: #64748B; -fx-font-size: 14px; -fx-font-weight: 600; -fx-padding: 11; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />

                    <Button onAction="#handleDelete" text="Delete Selected" maxWidth="Infinity" style="-fx-background-color: #FEF2F2; -fx-border-color: #FECACA; -fx-text-fill: #DC2626; -fx-font-size: 14px; -fx-font-weight: 700; -fx-padding: 11; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
                </VBox>

            </VBox>
        </HBox>
    </center>

</BorderPane>