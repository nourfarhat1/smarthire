<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.smarthire.controllers.application.AdminAppController">

    <Label text="All Applications (Admin)"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Filter + Delete Row -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Filter:" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="filterBox" prefWidth="200"/>
        <Button text="Delete Selected Application"
                onAction="#handleDelete"
                style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <!-- TableView -->
    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCandidate" text="Candidate"/>
            <TableColumn fx:id="colJob" text="Job Title"/>
            <TableColumn fx:id="colStatus" text="Status"/>
            <TableColumn fx:id="colDate" text="Submitted On"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

</VBox>