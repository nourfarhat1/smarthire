<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

                <AnchorPane style="-fx-background-color: white;">
                    <VBox layoutX="150.0" layoutY="40.0" spacing="20.0" prefWidth="500.0">
                        <Label text="Apply for this offer ? " textFill="#e91e63" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                        <Label text="Can't find the right offer? Send us your CV directly." textFill="#666" wrapText="true" />

                        <Label text="Target Role / Domain" textFill="#2f4188" style="-fx-font-weight: bold;" />
                        <TextField promptText="e.g. Full Stack Developer" style="-fx-padding: 10; -fx-border-color: #ddd; -fx-background-radius: 5;" />

                        <Label text="Cover Letter" textFill="#2f4188" style="-fx-font-weight: bold;" />
                        <TextArea promptText="Explain why you are a good fit..." prefHeight="150.0" style="-fx-border-color: #ddd; -fx-background-radius: 5;" />

                        <Label text="Resume (PDF)" textFill="#2f4188" style="-fx-font-weight: bold;" />
                        <Button text="Upload File..." maxWidth="Infinity" style="-fx-background-color: #f0f0f0; -fx-border-color: #aaa; -fx-border-style: dashed;" />

                        <Button text="Submit Application" maxWidth="Infinity" textFill="WHITE" style="-fx-background-color: #87a042; -fx-padding: 12; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" />
                    </VBox>
                </AnchorPane>
</AnchorPane>