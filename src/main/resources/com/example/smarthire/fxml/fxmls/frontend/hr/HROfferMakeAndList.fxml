<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.smarthire.controllers.job.JobOfferController">

    <Label text="Manage Job Offers" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <TextField fx:id="titleField" promptText="Job Title" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="categoryCombo" promptText="Category" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <TextField fx:id="locationField" promptText="Location" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="salaryField" promptText="Salary Range" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <ComboBox fx:id="typeCombo" promptText="Job Type" prefWidth="200" GridPane.columnIndex="0" GridPane.rowIndex="2"/>

        <TextArea fx:id="descArea" promptText="Description" prefHeight="80" GridPane.columnSpan="2" GridPane.rowIndex="3"/>

        <HBox spacing="10" GridPane.columnSpan="2" GridPane.rowIndex="4">
            <Button fx:id="btnAdd" text="Post Offer" onAction="#handleAddOffer" style="-fx-background-color: #2f4188; -fx-text-fill: white;"/>
            <Button fx:id="btnUpdate" text="Update" onAction="#handleUpdateOffer" style="-fx-background-color: #f0ad4e; -fx-text-fill: white;"/>
            <Button fx:id="btnDelete" text="Delete" onAction="#handleDeleteOffer" style="-fx-background-color: #d9534f; -fx-text-fill: white;"/>
            <Button text="Clear" onAction="#resetForm"/>
        </HBox>
    </GridPane>

    <TableView fx:id="offerTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTitle" text="Title" prefWidth="150"/>
            <TableColumn fx:id="colCategory" text="Category" prefWidth="120"/>
            <TableColumn fx:id="colSalary" text="Salary" prefWidth="120"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>