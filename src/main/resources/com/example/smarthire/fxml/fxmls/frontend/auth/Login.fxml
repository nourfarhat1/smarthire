<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.smarthire.controllers.auth.LoginController">
    <children>
        <AnchorPane prefHeight="600.0" prefWidth="400.0" style="-fx-background-color: #2f4188;">
            <children>
                <Label layoutX="100.0" layoutY="250.0" text="SmartHire" textFill="WHITE" style="-fx-font-size: 40px; -fx-font-weight: bold;" />
                <Label layoutX="100.0" layoutY="300.0" text="Find your dream job." textFill="#87a042" style="-fx-font-size: 18px;" />
            </children>
        </AnchorPane>
        <VBox alignment="CENTER_LEFT" layoutX="450.0" layoutY="100.0" prefHeight="400.0" prefWidth="300.0" spacing="20.0">
            <Label text="Login" textFill="#2f4188" style="-fx-font-size: 26px; -fx-font-weight: bold;" />

            <TextField fx:id="emailField" promptText="Email" style="-fx-background-color: white; -fx-border-color: #d1d1d1; -fx-border-radius: 5; -fx-padding: 10;" />

            <PasswordField fx:id="passField" promptText="Password" style="-fx-background-color: white; -fx-border-color: #d1d1d1; -fx-border-radius: 5; -fx-padding: 10;" />

            <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin" maxWidth="Infinity" textFill="WHITE" style="-fx-background-color: #e91e63; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;" />

            <HBox alignment="CENTER_LEFT">
                <Hyperlink text="Forgot Password?" onAction="#goToForgotPassword" textFill="#4686c2" />
                <Region HBox.hgrow="ALWAYS" />
                <Hyperlink text="Create Account" onAction="#goToRegister" textFill="#87a042" style="-fx-font-weight: bold;" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>