# Symfony Framework Bundle
APP_SECRET=your_app_secret_here

# Groq AI API
GROQ_API_KEY=your_groq_api_key_here

# FacePlus API
FACEPLUS_API_KEY=your_faceplus_api_key_here
FACEPLUS_API_SECRET=your_faceplus_api_secret_here

# Twilio SMS Service
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=your_twilio_phone_number_here

# OpenWeather Map API
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Face.io
FACEIO_APP_ID=your_faceio_app_id_here

# Gmail Configuration
GMAIL_ADDRESS=your_gmail_address_here
GMAIL_PASSWORD=your_gmail_app_password_here
MAILER_DSN=smtp://your_gmail_address:your_gmail_app_password@smtp.gmail.com:587?encryption=tls&verify_peer=0

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Adzuna Job API
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_API_KEY=your_adzuna_api_key_here

# Hugging Face API
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
